{
  "_id": "67b7788f20a33e9eae9b1b64",
  "name": "Import NetSuite customers (Guest)",
  "description": "Add or update customers in NetSuite using the customer ID as the lookup identifier.",
  "responseTransform": {
    "type": "expression",
    "expression": {
      "version": "1"
    }
  },
  "_connectionId": "6594453f4f7cab7c220b187a",
  "distributed": true,
  "apiIdentifier": "i958b13ca8",
  "ignoreExisting": false,
  "ignoreMissing": false,
  "oneToMany": false,
  "lookups": [],
  "aiDescription": {
    "summary": "The \"Import NetSuite customers (Guest)\" import is used to add or update customers in NetSuite using the customer ID as the lookup identifier. It is distributed, meaning it splits the data into multiple batches for faster processing. The import ignores existing data to prevent duplicates and is configured to work with the NetSuite application. The record type being imported is \"customer\" and the operation is set to \"addupdate\", which adds new records and updates existing ones. The import uses an internal ID lookup expression based on the email field to determine if a record already exists. Field mappings and additional address fields are defined, and a filter expression specifies conditions for importing records.",
    "detailed": "This import is named \"Import NetSuite customers (Guest)\" and its purpose is to add or update customers in NetSuite using the customer ID as the lookup identifier. \n\nThe import is distributed, which means it will split the data into multiple batches for faster processing. \n\nThe import is configured to ignore existing data in order to prevent duplicates. \n\nThe import is set to work with the NetSuite application and the record type being imported is \"customer\". \n\nThe import operation is set to \"addupdate\", which means it will add new records and update existing records in NetSuite. \n\nThe import uses an internal ID lookup expression to determine if a record already exists in NetSuite based on the email field. \n\nThe import has a set of field mappings that define how the data from the source application should be mapped to the fields in NetSuite. \n\nThe import also has two lists, \"_billing_addressbook\" and \"_shipping_addressbook\", which contain additional fields that will be mapped to the corresponding address fields in NetSuite. \n\nThe import has a filter expression that specifies certain conditions that need to be met for a record to be imported. In this case, the filter checks if the customer ID is equal to 0, the bill_email field is not empty, and the CustomerID field is empty. \n\nOverall, this import is designed to add or update customer records in NetSuite using the customer ID as the lookup identifier, with distributed processing for faster performance, and with a filter to only import certain records that meet specific conditions."
  },
  "netsuite_da": {
    "useSS2Restlets": false,
    "restletVersion": "suitebundle",
    "operation": "addupdate",
    "recordType": "customer",
    "internalIdLookup": {
      "expression": "[\"email\",\"is\",\"{{bill_email}}\"]"
    },
    "lookups": [],
    "mapping": {
      "fields": [
        {
          "generate": "isperson",
          "hardCodedValue": "true",
          "immutable": false,
          "internalId": false,
          "discardIfEmpty": false
        },
        {
          "extract": "bill_comp",
          "generate": "companyname",
          "immutable": false,
          "internalId": false,
          "discardIfEmpty": false
        },
        {
          "extract": "{{#if bill_fname}}{{bill_fname}}{{else}}Guest{{/if}}",
          "generate": "firstname",
          "immutable": false,
          "internalId": false,
          "discardIfEmpty": false
        },
        {
          "extract": "{{#if bill_lname}}{{bill_lname}}{{else}}Customer{{/if}}",
          "generate": "lastname",
          "immutable": false,
          "internalId": false,
          "discardIfEmpty": false
        },
        {
          "extract": "{{#compare cust_id \"==\" 0}}SO-{{id}}-Guest{{else}}{{cust_id}}{{/compare}}",
          "generate": "entityid",
          "immutable": false,
          "internalId": false,
          "discardIfEmpty": false,
          "conditional": {
            "when": "record_created"
          }
        },
        {
          "generate": "autoname",
          "hardCodedValue": "false",
          "immutable": false,
          "internalId": false,
          "discardIfEmpty": false
        },
        {
          "extract": "bill_email",
          "generate": "email",
          "internalId": false
        },
        {
          "generate": "subsidiary",
          "hardCodedValue": "1",
          "immutable": false,
          "internalId": true,
          "discardIfEmpty": false
        },
        {
          "generate": "isinactive",
          "hardCodedValue": "false",
          "immutable": false,
          "internalId": false,
          "discardIfEmpty": false
        },
        {
          "extract": "bill_phone",
          "generate": "phone",
          "internalId": false
        }
      ],
      "lists": [
        {
          "generate": "_billing_addressbook",
          "fields": [
            {
              "extract": "bill_addr1",
              "generate": "addr1",
              "internalId": false
            },
            {
              "extract": "bill_addr2",
              "generate": "addr2",
              "internalId": false
            },
            {
              "extract": "bill_city",
              "generate": "city",
              "internalId": false
            },
            {
              "extract": "bill_cntry",
              "generate": "country",
              "internalId": false
            },
            {
              "extract": "{{bill_fname}} {{bill_lname}}",
              "generate": "addressee",
              "immutable": false,
              "internalId": false,
              "discardIfEmpty": false
            },
            {
              "extract": "bill_phone",
              "generate": "addrphone",
              "internalId": false
            },
            {
              "extract": "bill_state",
              "generate": "state",
              "internalId": false
            },
            {
              "extract": "bill_zip",
              "generate": "zip",
              "internalId": false
            }
          ]
        },
        {
          "generate": "_shipping_addressbook",
          "fields": [
            {
              "extract": "ship_addr1",
              "generate": "addr1",
              "internalId": false
            },
            {
              "extract": "ship_addr2",
              "generate": "addr2",
              "internalId": false
            },
            {
              "extract": "ship_city",
              "generate": "city",
              "internalId": false
            },
            {
              "extract": "ship_cntry",
              "generate": "country",
              "internalId": false
            },
            {
              "extract": "{{ship_fname}} {{ship_lname}}",
              "generate": "addressee",
              "immutable": false,
              "internalId": false,
              "discardIfEmpty": false
            },
            {
              "extract": "ship_state",
              "generate": "state",
              "internalId": false
            },
            {
              "extract": "ship_zip",
              "generate": "zip",
              "internalId": false
            },
            {
              "extract": "ship_phone",
              "generate": "addrphone",
              "internalId": false
            }
          ]
        }
      ]
    }
  },
  "filter": {
    "type": "expression",
    "expression": {
      "version": "1",
      "rules": [
        "and",
        [
          "equals",
          [
            "string",
            [
              "extract",
              "cust_id"
            ]
          ],
          "0"
        ],
        [
          "notempty",
          [
            "string",
            [
              "extract",
              "bill_email"
            ]
          ]
        ],
        [
          "empty",
          [
            "string",
            [
              "extract",
              "CustomerID"
            ]
          ]
        ]
      ]
    },
    "rules": [
      "and",
      [
        "equals",
        [
          "string",
          [
            "extract",
            "cust_id"
          ]
        ],
        "0"
      ],
      [
        "notempty",
        [
          "string",
          [
            "extract",
            "bill_email"
          ]
        ]
      ],
      [
        "empty",
        [
          "string",
          [
            "extract",
            "CustomerID"
          ]
        ]
      ]
    ],
    "version": "1"
  },
  "adaptorType": "NetSuiteDistributedImport"
}