# ── sinister-forms-api configuration ──────────────────────────────
# Copy to .env on the server and fill in real values. NEVER commit .env.

# Server
PORT=3100
APP_ENV=production

# CORS — comma-separated list of allowed storefront origins (no trailing slash)
ALLOWED_ORIGINS=https://sinisterdiesel.com,https://www.sinisterdiesel.com

# monday.com
# Token is read ONLY from this server-side file. Never commit, print, or ship to the browser.
MONDAY_API_TOKEN=
MONDAY_API_VERSION=2024-10
MONDAY_BOARD_ID=2428283337
MONDAY_GROUP_ID=

# Notifications
INTERNAL_NOTIFICATION_EMAIL=
CUSTOMER_FROM_EMAIL=

# Anti-abuse
CAPTCHA_SECRET=

# Rate limiting (requests per window per IP)
RATE_LIMIT_MAX=20
RATE_LIMIT_WINDOW_MS=60000
