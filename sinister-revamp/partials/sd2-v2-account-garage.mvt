<mvt:comment>Account Garage V2 partial. Reuses Garage localStorage contract.</mvt:comment>
<section class="sd2-v2-account-card" aria-labelledby="sd2-v2-garage-title">
	<header class="sd2-v2-account-section-head"><h2 id="sd2-v2-garage-title">Saved Garage</h2><button class="sd2-btn sd2-btn--secondary" type="button" data-v2-garage-toggle>Add Vehicle</button></header>
	<div class="sd2-v2-account-garage" data-v2-account-garage-list>
		<article class="sd2-v2-account-vehicle-card is-active"><strong>[Placeholder] Active Vehicle</strong><span>Vehicle details render from Garage data.</span><div><span class="sd2-v2-badge sd2-v2-badge--fitment">Active</span><button class="sd2-v2-link-button" type="button" data-v2-garage-toggle>Edit</button><button class="sd2-v2-link-button" type="button">Remove</button></div></article>
	</div>
</section>
