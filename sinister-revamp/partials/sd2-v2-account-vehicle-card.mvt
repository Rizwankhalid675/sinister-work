<mvt:comment>Account Vehicle Card V2 partial.</mvt:comment>
<article class="sd2-v2-account-vehicle-card">
	<strong>[Placeholder] Vehicle Name</strong>
	<span>[Placeholder] Year, make, model, engine.</span>
	<div>
		<span class="sd2-v2-badge sd2-v2-badge--fitment">Saved</span>
		<button class="sd2-v2-link-button" type="button" data-v2-garage-toggle>Edit</button>
		<button class="sd2-v2-link-button" type="button">Remove</button>
	</div>
</article>
