<mvt:if expr="g.customer_session_verified EQ '1' AND g.customer:id NE '' AND int(g.customer:id) GT 0 ">
	<mvt:comment> 16 => Wholesale-1, 51 => Wholesale-2, 52 => Wholesale-3, 53 => Distributor, 54 => Distributor+</mvt:comment>
	<mvt:assign name="l.settings:pricegroup_array[1]" value="16"/>
	<mvt:assign name="l.settings:pricegroup_array[2]" value="51"/>
	<mvt:assign name="l.settings:pricegroup_array[3]" value="52"/>
	<mvt:assign name="l.settings:pricegroup_array[4]" value="53"/>
	<mvt:assign name="l.settings:pricegroup_array[5]" value="54"/>

	<mvt:foreach iterator="this_pricegroup" array="pricegroup_array">

		<mvt:do name="l.wholesale" file="g.Module_Feature_PGR_DB" value="PriceGroupXCustomer_Load( l.settings:this_pricegroup, g.Basket:cust_id, l.null )" />
		<mvt:if expr="l.wholesale">
			<mvt:assign name="l.settings:price_group_overlay" value="'WS'" />
			<mvt:foreachstop/>
		</mvt:if>
	</mvt:foreach>
		
	<mvt:if expr="NOT l.wholesale">
		<mvt:do name="l.return" file="g.Module_Feature_PGR_DB" value="PriceGroup_Load_Name( 'VIP Customer', l.vip_pricegroup )" />
		<mvt:if expr="l.return EQ 1">
			<mvt:do name="l.vip" file="g.Module_Feature_PGR_DB" value="PriceGroupXCustomer_Load( l.vip_pricegroup:id, g.Basket:cust_id, l.null )" />
			<mvt:if expr="l.vip">
				<mvt:assign name="l.settings:price_group_overlay" value="'VIP'" />
			</mvt:if>
		</mvt:if>
	</mvt:if>
	<style>
		.account_container {
			position: relative;
			text-align: center;
			color: white;
		}
		.top-right {
			position: absolute;
			top: -14px;
			right: -12px;
		}
		.price_group_overlay{
			background-color:black;
			font-size: 10px;
			color:white;
			border-radius:5px;
			border:0px;
			padding:4px;
		}
	</style>
		
	<div class="account_container">
		<a class="x-show-related__link t-primary-link" href="&mvte:urls:ACLN:secure;">
			<svg width="19" height="20" viewBox="0 0 19 20" fill="none" xmlns="http://www.w3.org/2000/svg">
