	<mvt:if expr="l.settings:readytheme:storefront_hero_image4:link_type EQ 'G'">
		<mvt:do file="g.Module_Feature_TUI_DB" name="l.success" value="Page_Load_Code( l.settings:readytheme:storefront_hero_image4:link_dest, l.settings:rt_page )" />
		<mvt:do file="g.Module_Feature_URI_UT" name="l.settings:readytheme:storefront_hero_image4:uri" value="Store_Page_URL(l.settings:rt_page, NULL)" />
	<mvt:elseif expr="l.settings:readytheme:storefront_hero_image4:link_type EQ 'C'">
		<mvt:do file="g.Module_Library_DB" name="l.success" value="Category_Load_Code( l.settings:readytheme:storefront_hero_image4:link_dest, l.settings:rt_category )" />
		<mvt:do file="g.Module_Feature_URI_UT" name="l.settings:readytheme:storefront_hero_image4:uri" value="Store_Category_URL(l.settings:rt_category, NULL)" />
	<mvt:elseif expr="l.settings:readytheme:storefront_hero_image4:link_type EQ 'P'">
		<mvt:do file="g.Module_Library_DB" name="l.success" value="Product_Load_Code( l.settings:readytheme:storefront_hero_image4:link_dest, l.settings:rt_product )" />
		<mvt:do file="g.Module_Feature_URI_UT" name="l.settings:readytheme:storefront_hero_image4:uri" value="Store_Product_URL(l.settings:rt_product, NULL)" />
	<mvt:elseif expr="l.settings:readytheme:storefront_hero_image4:link_type EQ 'U'">
