		<mvt:do file="g.Module_Feature_URI_UT" name="l.settings:readytheme:storefront_hero_image3:uri" value="Store_Product_URL(l.settings:rt_product, NULL)" />
	<mvt:elseif expr="l.settings:readytheme:storefront_hero_image3:link_type EQ 'U'">
		<mvt:assign name="l.settings:readytheme:storefront_hero_image3:uri" value="l.settings:readytheme:storefront_hero_image3:link_dest" />
	<mvt:else>
		<mvt:assign name="l.settings:readytheme:storefront_hero_image3:uri" value="NULL" />
