		<mvt:do file="g.Module_Feature_URI_UT" name="l.settings:readytheme:storefront_hero_image3:uri" value="Store_Category_URL(l.settings:rt_category, NULL)" />
	<mvt:elseif expr="l.settings:readytheme:storefront_hero_image3:link_type EQ 'P'">
