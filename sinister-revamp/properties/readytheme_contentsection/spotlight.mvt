        <p>At Sinister Diesel, we believe that exceptional products deserve exceptional support. That’s why we offer a dedicated customer service help center and are always just a phone call or text away, ready to assist you with any questions, concerns, or needs. Whether you’re a seasoned diesel enthusiast or new to performance upgrades, our team is here to provide fast, friendly, and knowledgeable support.<br><br> We understand that your time is valuable, which is why we take pride in responding promptly and efficiently. From helping you choose the right part for your diesel engine to troubleshooting an issue or tracking an order, we’re committed to making your experience with Sinister Diesel as seamless as possible. With an unmatched 4.8-star rating from over 18,000 customer service reviews, our dedication to top-tier support speaks for itself.<br><br>For us, it’s not just about selling parts—it’s about building relationships and supporting your journey every step of the way. Your success is our success, and we’re here to ensure you get the most out of your diesel performance.</p>
      </div>
    </div>
  </section>
</div>

<script>
  document.addEventListener("DOMContentLoaded", function () {
    const observer = new IntersectionObserver(entries => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add("animate");
          observer.unobserve(entry.target);
        }
      });
    }, { threshold: 0.2 });

    document.querySelectorAll('.t-two-column-wrapper .t-two-column-row').forEach(row => {
      observer.observe(row);
    });
  });
</script>
<script>
  document.addEventListener("DOMContentLoaded", function () {
    // ===== existing animation observer =====
    const observer = new IntersectionObserver(entries => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add("animate");
          observer.unobserve(entry.target);
        }
      });
    }, { threshold: 0.2 });

    document.querySelectorAll('.t-two-column-wrapper .t-two-column-row').forEach(row => {
      observer.observe(row);
    });

    // ===== mobile read more toggles (fixed) =====
    const mobileMq = window.matchMedia("(max-width: 768px)");

    function isOverflowing(el) {
      return el.scrollHeight > (el.clientHeight + 1);
    }

    function setupReadMore() {
      // Remove existing buttons (safe re-run)
      document.querySelectorAll('.t-two-column-wrapper .t-read-more').forEach(b => b.remove());

      // Only add on mobile
      if (!mobileMq.matches) return;

      document.querySelectorAll('.t-two-column-wrapper .t-two-column-text').forEach(textBlock => {
        const p = textBlock.querySelector('p');
        if (!p) return;

        // Create button
        const btn = document.createElement('button');
        btn.type = 'button';
        btn.className = 't-read-more';

        // Insert right after paragraph (so it stays with the text)
        p.insertAdjacentElement('afterend', btn);

        // Determine if it needs a toggle:
        // Temporarily ensure it's in "collapsed" state for measurement
        const wasExpanded = p.classList.contains('is-expanded');
        if (wasExpanded) p.classList.remove('is-expanded');

        // Wait a tick so clamp/layout applies before measuring
        requestAnimationFrame(() => {
          const needsToggle = isOverflowing(p);

          // Restore expanded state if it was expanded
          if (wasExpanded) p.classList.add('is-expanded');

          // If expanded OR it needs toggle, show button. Otherwise hide it.
          if (!needsToggle && !wasExpanded) {
            btn.hidden = true;
            return;
          }

          // Set correct label
          btn.textContent = p.classList.contains('is-expanded') ? 'Read less' : 'Read more';

          btn.addEventListener('click', () => {
            const expanded = p.classList.toggle('is-expanded');
            btn.textContent = expanded ? 'Read less' : 'Read more';
          });
        });
      });
    }

    setupReadMore();

    // Only rebuild when crossing the breakpoint (not on scroll-induced resize)
    mobileMq.addEventListener?.("change", setupReadMore);
  });
</script>