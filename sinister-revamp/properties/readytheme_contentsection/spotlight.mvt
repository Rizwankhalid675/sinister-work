<!-- Load Play font -->
<link href="https://fonts.googleapis.com/css2?family=Play&display=swap" rel="stylesheet">

<style>
  .t-two-column-wrapper {
    font-family: 'Play', sans-serif;
  }

  .t-two-column-wrapper .t-two-column-section {
    padding: 4rem 1rem;
    max-width: 1200px;
    margin: 0 auto;
  }

  .t-two-column-wrapper .t-two-column-row {
    display: flex;
    flex-wrap: wrap;
    margin-bottom: 4rem;
    opacity: 0;
    transform: translateY(40px);
    transition: opacity 1s ease-out, transform 1s ease-out;
  }

  .t-two-column-wrapper .t-two-column-row.animate {
    opacity: 1;
    transform: translateY(0);
  }

  .t-two-column-wrapper .t-two-column-row--reverse {
    flex-direction: row-reverse;
  }

  .t-two-column-wrapper .t-two-column-image,
  .t-two-column-wrapper .t-two-column-text {
    flex: 1;
    padding: 1.5rem;
    box-sizing: border-box;
  }

  .t-two-column-wrapper .t-two-column-image img {
    width: 100%;
    height: auto;
    border-radius: 12px;
    box-shadow: 0 8px 20px rgba(0,0,0,0.08);
  }

  .t-two-column-wrapper .t-two-column-text {
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  .t-two-column-wrapper .t-two-column-text h2 {
    font-size: 2rem;
    margin-bottom: 1rem;
    color: #1833B8;
  }

  .t-two-column-wrapper .t-two-column-text p {
    font-size: 1.15rem;
    line-height: 1.6;
    color: #333;
  }

  .t-two-column-wrapper .c-button {
    margin-top: 1.5rem;
    padding: 0.75rem 1.5rem;
    font-size: 1rem;
    font-weight: bold;
    border: none;
    border-radius: 6px;
    color: #fff;
    background-color: #1833B8;
    transition: background-color 0.3s ease;
    text-decoration: none;
    display: inline-block;
    max-width: fit-content;
  }

  .t-two-column-wrapper .c-button:hover {
    background-color: #102280;
  }

  @media (max-width: 768px) {
    .t-two-column-wrapper .t-two-column-row,
    .t-two-column-wrapper .t-two-column-row--reverse {
      flex-direction: column;
    }
  }
</style>
<style>
  /* Mobile "Read more" clamp */
  @media (max-width: 768px) {
    .t-two-column-wrapper .t-two-column-text p {
      display: -webkit-box;
      -webkit-box-orient: vertical;
      -webkit-line-clamp: 6; /* <- change to 5-7 lines */
      overflow: hidden;
    }

    .t-two-column-wrapper .t-two-column-text p.is-expanded {
      -webkit-line-clamp: unset;
      display: block;
      overflow: visible;
    }

    .t-two-column-wrapper .t-read-more {
      margin-top: 0.75rem;
      background: none;
      border: none;
      padding: 0;
      color: #1833B8;
      font-weight: 700;
      font-size: 1rem;
      cursor: pointer;
      text-decoration: underline;
    }

    .t-two-column-wrapper .t-read-more[hidden] {
      display: none !important;
    }
  }

@media (max-width: 768px) {

  .t-two-column-wrapper .t-read-more {
    margin: 1rem 0 0 0;
    width: 100%;
    display: flex;
    align-items: center;
    justify-content: center;

    background: none;
    border: none;
    padding: 0;

    color: #1833B8;
    font-weight: 700;
    font-size: 0.95rem;
    letter-spacing: .5px;
    text-transform: uppercase;
    cursor: pointer;
  }

  /* the lines */
  .t-two-column-wrapper .t-read-more::before,
  .t-two-column-wrapper .t-read-more::after {
    content: "";
    flex: 1;
    height: 1px;
    background: rgba(24, 51, 184, 0.35);
  }

  /* spacing between text and lines */
  .t-two-column-wrapper .t-read-more::before {
    margin-right: 12px;
  }

  .t-two-column-wrapper .t-read-more::after {
    margin-left: 12px;
  }

  /* subtle hover polish */
  .t-two-column-wrapper .t-read-more:hover {
    color: #102280;
  }

}






