}
@media (max-width: 560px) {
	body#js-CTGY main.o-wrapper,
	body#js-CTGY main.t-wrapper {
		padding-top: 14px !important;
	}
	body#js-CTGY section.u-bg-white.t-expanded-block > .o-wrapper.t-wrapper,
	body#js-CTGY .sd2-ctgy-shell,
	body#js-CTGY .sd2-ctgy-layout {
		width: calc(100% - 24px) !important;
	}
	body#js-CTGY h1,
	body#js-CTGY .t-page-title,
	body#js-CTGY .page-title {
		font-size: clamp(23px, 6.8vw, 32px) !important;
		line-height: 1.08 !important;
		margin-bottom: 18px !important;
	}
	body#js-CTGY #filter-items-container {
		grid-template-columns: 1fr !important;
	}
	body#js-CTGY #filter-items-container > .sorting,
	body#js-CTGY #filter-items-container > .per-page,
	body#js-CTGY #filter-items-container > .page-links {
		justify-content: stretch !important;
		width: 100% !important;
	}
	body#js-CTGY #filter-items-container form {
		display: grid !important;
		grid-template-columns: 58px minmax(0, 1fr) !important;
		align-items: center !important;
	}
	body#js-CTGY #filter-items-container .page-links-container,
	body#js-CTGY #filter-items-container .page-disp {
		flex-wrap: wrap !important;
		justify-content: center !important;
	}
	body#js-CTGY .expanded {
		grid-template-columns: 1fr !important;
		gap: 16px !important;
	}
	body#js-CTGY .expanded .product-thumbnail {
		aspect-ratio: 16 / 10 !important;
	}
	body#js-CTGY .expanded .product-details {
		padding: 14px 14px 4px !important;
	}
	body#js-CTGY .expanded .product-name {
		font-size: 14px !important;
		min-height: 0;
	}
	body#js-CTGY .expanded .purchase-buttons {
		grid-template-columns: 1fr 1fr;
		padding: 12px 14px 14px !important;
	}
	body#js-CTGY .expanded .purchase-buttons input[type="submit"],
	body#js-CTGY .expanded .purchase-buttons button {
		font-size: 11px !important;
		min-height: 40px;
	}
	body#js-CTGY .expanded .page-links,
	body#js-CTGY .sd2-ctgy-pagination {
		gap: 6px;
		margin-top: 28px;
	}
}
@media (max-width: 380px) {
	body#js-CTGY .expanded .purchase-buttons {
		grid-template-columns: 1fr;
	}
}
</style>

</head>
<body id="js-&mvte:page:code;" class="o-site-wrapper t-page-&mvt:global:pageClass;<mvt:if expr="g.ss_enable EQ 'true' AND l.settings:page:code EQ 'CTGY' AND l.settings:category:code EQ g.ss_search_url"> ss-shop</mvt:if>">
	<mvt:item name="hdft" param="global_header" />

<mvt:comment>
	HIDE CAROUSEL and TITLE IMAGE 3/11/22 SMV
	<mvt:foreach array="cattree_categories" iterator="category_children">
		<mvt:if expr="l.settings:category_children:parent_id EQ l.settings:category:id">
			<mvt:assign name="l.null" value="miva_array_insert(l.settings:subcategories, l.settings:category_children, -1)" />
		</mvt:if>
	</mvt:foreach>
	<mvt:assign name="l.settings:subcategory_count" value="miva_array_elements(l.settings:subcategories)" />
	
	<mvt:if expr="l.settings:subcategories GT 0">
		<section class="u-bg-white t-expanded-block t-subcategory-navigation-block" data-hook="subcategory-navigation-block">
			<nav class="o-wrapper t-wrapper t-subcategory-navigation" data-hook="subcategory-navigation-slider"></nav>
		</section>
		<template data-hook="subcategory-navigation">
			<mvt:foreach iterator="subcategory" array="subcategories">
				<div class="u-text-center t-subcategory-navigation__item">
					<a class="u-block u-color-black t-subcategory-navigation__link" href="&mvte:subcategory:link;">
						<figure class="t-subcategory-navigation__figure">
							<mvt:if expr="l.settings:subcategory:image">
								<!-- Image: 240x315 -->
								<picture class="t-subcategory-navigation__picture">
									<img class="t-subcategory-navigation__image" data-lazy="&mvte:subcategory:image;" src="" alt="&mvte:subcategory:name;">
								</picture>
							</mvt:if>
							<figcaption class="t-subcategory-navigation__figure-caption">
								<span class="t-subcategory-navigation__name">&mvte:subcategory:name;</span>
							</figcaption>
						</figure>
					</a>
				</div>
			</mvt:foreach>
		</template>
	</mvt:if>

	<mvt:item name="customfields" param="Read_Category_Code(g.Category_Code, 'secondary_title_image', l.settings:secondary_title_image)" />
	<mvt:if expr="NOT ISNULL l.settings:category_title:image OR NOT ISNULL l.settings:secondary_title_image">
		<mvt:if expr="NOT ISNULL l.settings:category_title:image AND NOT ISNULL l.settings:secondary_title_image">
			<mvt:assign name="l.settings:category_title:image_grid" value="'u-grids-1 u-grids-2--l'"/>
		</mvt:if>
		<section class="o-layout o-layout--justify-between o-layout--wide &mvte:category_title:image_grid; t-category-title-images">
			<mvt:if expr="NOT ISNULL l.settings:category_title:image">
				<div class="o-layout__item">
					<div class="x-hero">
						<img src="&mvte:category_title:image;" alt="&mvte:category:name;" loading="lazy" decoding="async">
					</div>
				</div>
			</mvt:if>
			<mvt:if expr="NOT ISNULL l.settings:secondary_title_image">
				<div class="o-layout__item">
					<div class="x-hero">
						<img src="&mvte:secondary_title_image;" alt="&mvte:category:name;" loading="lazy" decoding="async">
					</div>
				</div>
			</mvt:if>
		</section>
	</mvt:if>
</mvt:comment>

	<mvt:if expr="NOT ISNULL l.settings:category:description">
		<div class="sd2-ctgy-shell">
			<div class="sd2-ctgy-desc">&mvt:category:description;</div>
		</div>
	</mvt:if>

	<section class="u-bg-white t-expanded-block">
		<div class="o-wrapper t-wrapper">

			<div class="sd2-ctgy-layout">
				<mvt:comment>
					No custom mobile Filters button is added here — the real theme
					already renders one (.t-filters-trigger, data-hook="open-refinery-annex",
					in cssui-global-header.mvt's CTGY toolbar block) which opens the same
					refinery-annex drawer. Adding a second one here caused a visible
					duplicate "Filters" button on mobile.
				</mvt:comment>
				<mvt:comment>
					facets renders as a HORIZONTAL bar by default (see cssui-prodlist-facets.mvt,
					data-hook="horizontal-refinery", template cloned by ReadyTheme's core JS into
					[data-hook="add-refinery"]) — mounting the div here, inside a real sidebar
					column, and restyling its internal .x-refinery__list to stack vertically
					(see CSS below) turns it into a genuine left-column filter sidebar.
				</mvt:comment>
				<aside class="sd2-ctgy-sidebar">
					<mvt:item name="facets" />
				</aside>

				<div class="sd2-ctgy-products">
					<mvt:item name="category_listing" />
				</div>
			</div>

<mvt:comment>
				<!-- Shopper Approved - CTGY -->
<div class="o-layout o-layout--row-reverse--l o-layout--wide">
<div class="o-layout__item u-width-12">
    <div id="abqacat"></div><div style="clear:both; height: 50px;"></div>
    <script type="text/javascript" src="https://sinisterdiesel.services.answerbase.com/javascript/widget/full-featured-widget.min.js" 
              data-external-product-category-id="&mvt:category:id;"
              data-product-category-title="&mvt:category:name;"
              data-product-category-image="&mvt:category:image;"
              data-product-category-url="&mvt:category:link;"
              data-insert-after="#abqacat" data-open-ask="expand" defer></script>

</div>
</div>
<style>
.answerbase-widget{
  font-size: 1rem;
}
.answerbase-widget h5{
  font-size: 1.25rem;
}
.answerbase-widget h5, .answerbase-widget a{
    font-weight: bold;
}
.answerbase-widget .button, .answerbase-widget [type='text'], .answerbase-widget [type='password'], .answerbase-widget [type='date'], .answerbase-widget [type='datetime'], .answerbase-widget [type='datetime-local'], .answerbase-widget [type='month'], .answerbase-widget [type='week'], .answerbase-widget [type='email'], .answerbase-widget [type='number'], .answerbase-widget [type='search'], .answerbase-widget [type='tel'], .answerbase-widget [type='time'], .answerbase-widget [type='url'], .answerbase-widget [type='color'], .answerbase-widget textarea{
  font-size: 1rem;
}
</style>
				<!-- END Shopper Approved - CTGY -->
</mvt:comment>

		</div>
	</section>
	<br>

	<script>
	(function() {
		/* sd2: fallback missing category-grid thumbnails to each product's real
		   Main image (scraped from that product page's og:image meta tag),
		   since the Thumbnail image type is unset for most of the catalog and
		   the live category_listing module output (a.thumbnail-not-available)
		   cannot be edited server-side (unregistered/internal item template). */
		var placeholders = document.querySelectorAll('.product-thumbnail a.thumbnail-not-available');
		placeholders.forEach(function(placeholder) {
			var href = placeholder.getAttribute('href');
			if (!href) { return; }
			fetch(href, { credentials: 'same-origin' })
				.then(function(res) { return res.text(); })
				.then(function(html) {
					var match = html.match(/<meta property="og:image" content="([^"]+)"/i);
					if (!match || !match[1]) { return; }
					var img = document.createElement('img');
					img.src = match[1];
					img.alt = placeholder.getAttribute('title') || '';
					img.loading = 'lazy';
					placeholder.replaceWith(img);
				})
				.catch(function() { /* leave placeholder as-is on failure */ });
		});

		function collapseEmptyFacets() {
			var sets = document.querySelectorAll('.sd2-ctgy-sidebar .x-refinery-set');
			sets.forEach(function(set) {
				var list = set.querySelector('.x-refinery-set__list');
				if (!list) { return; }
				var visibleOptions = Array.prototype.slice.call(list.querySelectorAll('.c-form-checkbox__input, select option')).filter(function(option) {
					if (option.disabled) { return false; }
					if (option.tagName === 'OPTION' && option.value === '') { return false; }
					var style = window.getComputedStyle(option);
					if (style.display === 'none' || style.visibility === 'hidden') { return false; }
					if (option.tagName === 'INPUT') { return true; }
					return option.textContent.trim().length > 0;
				});
				if (!visibleOptions.length) {
					set.classList.add('sd2-empty-facet');
					var trigger = set.querySelector('.x-refinery-set__trigger');
					if (trigger) { trigger.checked = false; }
				} else {
					set.classList.remove('sd2-empty-facet');
				}
			});
		}

		collapseEmptyFacets();
		setTimeout(collapseEmptyFacets, 350);
		setTimeout(collapseEmptyFacets, 1000);
	})();
	</script>

	<mvt:item name="hdft" param="global_footer" />
</body>
</html>
