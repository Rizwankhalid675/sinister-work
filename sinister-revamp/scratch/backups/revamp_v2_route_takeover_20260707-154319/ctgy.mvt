	}
	body#js-CTGY #filter-items-container .page-links-container,
	body#js-CTGY #filter-items-container .page-disp {
		display: inline-flex !important;
		max-width: 100% !important;
		flex-wrap: wrap !important;
		justify-content: center !important;
		gap: 6px !important;
	}
	body#js-CTGY #filter-items-container .page-links a,
	body#js-CTGY #filter-items-container .page-links span {
