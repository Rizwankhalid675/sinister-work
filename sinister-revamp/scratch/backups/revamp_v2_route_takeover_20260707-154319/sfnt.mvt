		<script>
			(function () {
				var toggle = document.getElementById('sd-finder-toggle');
				var widget = document.getElementById('sd-finder-widget');
				var form = document.getElementById('sd-truck-finder');

				if (!toggle || !widget) return;

				toggle.addEventListener('click', function () {
					var isOpen = widget.classList.toggle('is-open');
					toggle.classList.toggle('is-open', isOpen);
					toggle.setAttribute('aria-expanded', isOpen ? 'true' : 'false');
				});

				if (form) {
					form.addEventListener('submit', function (event) {
						var make = form.querySelector('select[name="make"]');
						var selected = make && make.options[make.selectedIndex];
						var url = selected && selected.getAttribute('data-url');
						var values = Array.prototype.slice.call(form.querySelectorAll('select')).map(function (select) {
							return select.value;
						}).filter(Boolean);

						if (url && values.length <= 1) {
							event.preventDefault();
							window.location.href = url;
							return;
						}

						form.querySelector('input[name="Search"]').value = values.join(' ');
					});
				}
			})();
		</script>

