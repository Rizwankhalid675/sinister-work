<!DOCTYPE html>
<html lang="en">
<mvt:item name="html_profile" />

<head itemscope itemtype="http://schema.org/WebSite">
	<meta charset="utf-8">
	<meta http-equiv="X-UA-Compatible" content="IE=edge">
	<meta name="viewport" content="width=device-width, initial-scale=1">
	<base href="&mvt:global:basehref;" />
	<mvt:if expr="NOT ISNULL l.settings:page:title">
		<title itemprop="name">&mvt:page:title;</title>
	<mvt:else>
		<title itemprop="name">&mvt:store:name;</title>
	</mvt:if>
	<mvt:if expr="g.useDevResources EQ 1"><mvt:item name="head" param="css_list_dev" /><mvt:else><mvt:item name="head" param="css_list" /></mvt:if>
	<mvt:item name="head" param="head_tag" />

	<link rel="preconnect" href="https://fonts.googleapis.com">
	<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
	<link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Oswald:wght@300;400;500;600;700&family=Inter:wght@300;400;500;600;700&display=swap">

	<style>

		/* ═══════════════════════════════════════════
		   sd2 DESIGN TOKENS — v3 Premium
		   ═══════════════════════════════════════════ */
		:root {
			--sd2-blue:        #1833B8;
			--sd2-blue-mid:    #2244d4;
			--sd2-blue-light:  #e8edff;
			--sd2-blue-glow:   rgba(24,51,184,0.18);
			--sd2-gold:        #D4A017;
			--sd2-gold-light:  #fff8e6;

			--sd2-bg:          #f5f6fa;
			--sd2-bg-white:    #ffffff;
			--sd2-bg-subtle:   #eef0f8;

			--sd2-text:        #0d0f1a;
			--sd2-text-mid:    #3a3f5c;
			--sd2-text-muted:  #7a80a0;

			--sd2-border:      rgba(24,51,184,0.10);
			--sd2-border-mid:  rgba(24,51,184,0.20);
			--sd2-shadow-sm:   0 2px 12px rgba(24,51,184,0.07);
			--sd2-shadow-md:   0 8px 32px rgba(24,51,184,0.12);
			--sd2-shadow-lg:   0 20px 60px rgba(24,51,184,0.16);
			--sd2-shadow-xl:   0 32px 80px rgba(24,51,184,0.20);

			--sd2-ease-out:    cubic-bezier(0.16, 1, 0.3, 1);
			--sd2-ease-spring: cubic-bezier(0.34, 1.56, 0.64, 1);
			--sd2-max:         1280px;
			--sd2-r:           16px;
			--sd2-r-sm:        10px;
		}

		/* Scope a mini-reset to sd2- markup only, per safety rule: never touch global tags */
		[class^="sd2-"], [class*=" sd2-"] { box-sizing: border-box; }

		/* ═══════════════════════════════════════════
		   sd2-hero — new hero section
		   ═══════════════════════════════════════════ */
		#sd2-canvas {
			position: fixed;
			inset: 0;
			z-index: 0;
			pointer-events: none;
		}

		.sd2-hero {
			position: relative;
			min-height: 86vh;
			max-height: 1040px;
			background: linear-gradient(135deg, rgba(233,236,255,0.80) 0%, rgba(245,246,250,0.72) 50%, rgba(255,248,232,0.80) 100%);
			overflow: hidden;
			display: flex;
			align-items: center;
		}
		.sd2-hero-geo { position: absolute; inset: 0; pointer-events: none; overflow: hidden; }
		.sd2-geo-circle-1 {
			position: absolute; width: 700px; height: 700px; border-radius: 50%;
			border: 1.5px solid rgba(24,51,184,0.07);
			top: -200px; right: -180px;
			animation: sd2GeoSpin 40s linear infinite;
		}
		.sd2-geo-circle-2 {
			position: absolute; width: 450px; height: 450px; border-radius: 50%;
			border: 1.5px solid rgba(24,51,184,0.05);
			top: -100px; right: -80px;
			animation: sd2GeoSpin 28s linear infinite reverse;
		}
		@keyframes sd2GeoSpin { from { transform: rotate(0deg); } to { transform: rotate(360deg); } }

		.sd2-hero-orb { position: absolute; border-radius: 50%; filter: blur(60px); pointer-events: none; }
		.sd2-hero-orb-1 {
			width: 420px; height: 420px;
			background: radial-gradient(circle, rgba(24,51,184,0.13) 0%, transparent 70%);
			top: -60px; right: 15%;
			animation: sd2OrbPulse 8s ease-in-out infinite;
		}
		.sd2-hero-orb-2 {
			width: 280px; height: 280px;
			background: radial-gradient(circle, rgba(212,160,23,0.12) 0%, transparent 70%);
			bottom: 60px; right: 25%;
			animation: sd2OrbPulse 11s ease-in-out infinite 3s;
		}
		@keyframes sd2OrbPulse {
			0%, 100% { transform: scale(1) translate(0,0); opacity: 1; }
			50%       { transform: scale(1.12) translate(12px,-16px); opacity: 0.7; }
		}
		.sd2-hero-dots-bg {
			position: absolute; inset: 0;
			background-image: radial-gradient(circle, rgba(24,51,184,0.08) 1px, transparent 1px);
			background-size: 32px 32px;
			mask-image: radial-gradient(ellipse 70% 70% at 80% 50%, black 20%, transparent 80%);
			-webkit-mask-image: radial-gradient(ellipse 70% 70% at 80% 50%, black 20%, transparent 80%);
			pointer-events: none;
		}

		.sd2-hero-content {
			position: relative; z-index: 10; width: 100%; max-width: 1400px;
			margin: 0 auto; padding: 64px 60px;
			display: grid; grid-template-columns: 1fr 1.15fr; gap: 48px; align-items: center;
		}

		.sd2-hero-badge {
			display: inline-flex; align-items: center; gap: 8px;
			padding: 5px 14px 5px 8px;
			background: var(--sd2-blue-light);
			border: 1.5px solid rgba(24,51,184,0.2);
			border-radius: 100px;
			font-size: 10px; font-weight: 700; letter-spacing: 3px; text-transform: uppercase;
			color: var(--sd2-blue); margin-bottom: 22px;
		}
		.sd2-badge-dot {
			width: 6px; height: 6px; border-radius: 50%; background: var(--sd2-blue);
			animation: sd2DotPulse 2s ease-in-out infinite;
		}
		@keyframes sd2DotPulse {
			0%, 100% { box-shadow: 0 0 0 0 rgba(24,51,184,0.4); }
			50%       { box-shadow: 0 0 0 5px rgba(24,51,184,0); }
		}

		.sd2-hero-title {
			font-family: 'Oswald', sans-serif;
			font-size: clamp(40px, 5.5vw, 72px);
			font-weight: 700; color: var(--sd2-text);
			text-transform: uppercase; letter-spacing: -1px; line-height: 0.95;
			margin-bottom: 20px;
		}
		.sd2-hero-title .sd2-accent { color: var(--sd2-blue); display: block; }

		.sd2-hero-sub {
			font-size: 16px; color: var(--sd2-text-mid); line-height: 1.68;
			max-width: 420px; margin-bottom: 36px;
		}

		.sd2-hero-ctas { display: flex; gap: 12px; flex-wrap: wrap; }

		.sd2-btn {
			display: inline-flex; align-items: center; gap: 8px;
			padding: 13px 26px; border-radius: var(--sd2-r-sm);
			font-family: 'Oswald', sans-serif; font-size: 13px; font-weight: 600;
			letter-spacing: 1.5px; text-transform: uppercase; border: none; cursor: pointer;
			transition: transform 0.25s var(--sd2-ease-spring), box-shadow 0.25s ease;
		}
		.sd2-btn svg { width: 15px; height: 15px; flex-shrink: 0; }
		.sd2-btn-primary {
			background: var(--sd2-blue); color: #fff;
			box-shadow: 0 4px 18px rgba(24,51,184,0.35), inset 0 1px 0 rgba(255,255,255,0.12);
		}
		.sd2-btn-primary:hover { transform: translateY(-3px); box-shadow: 0 10px 30px rgba(24,51,184,0.4); }
		.sd2-btn-outline {
			background: transparent; color: var(--sd2-blue); border: 2px solid var(--sd2-blue);
		}
		.sd2-btn-outline:hover { background: var(--sd2-blue-light); transform: translateY(-2px); }

		.sd2-hero-right { display: flex; align-items: center; justify-content: center; position: relative; }
		.sd2-device-wrap {
			transform: perspective(1100px) rotateY(-8deg) rotateX(2deg);
			transition: transform 0.6s var(--sd2-ease-out);
			filter: drop-shadow(-20px 28px 44px rgba(24,51,184,0.22)) drop-shadow(-6px 8px 18px rgba(0,0,0,0.10));
			border-radius: 14px; position: relative;
		}
		.sd2-device-wrap:hover { transform: perspective(1100px) rotateY(-2deg) rotateX(1deg) translateY(-6px); }

		.sd2-browser-shell {
			width: clamp(420px, 42vw, 600px);
			border-radius: 14px; overflow: hidden;
			border: 1.5px solid rgba(24,51,184,0.15); background: #fff;
		}
		.sd2-browser-bar {
			height: 40px; background: #f0f2fb; border-bottom: 1px solid rgba(24,51,184,0.10);
			display: flex; align-items: center; gap: 10px; padding: 0 14px;
		}
		.sd2-browser-dots { display: flex; gap: 6px; }
		.sd2-browser-dot { width: 12px; height: 12px; border-radius: 50%; }
		.sd2-bd-red   { background: #ff5f57; }
		.sd2-bd-amber { background: #ffbd2e; }
		.sd2-bd-green { background: #28c840; }
		.sd2-browser-url {
			flex: 1; height: 24px; background: rgba(255,255,255,0.85);
			border: 1px solid rgba(24,51,184,0.12); border-radius: 6px;
			display: flex; align-items: center; padding: 0 10px; gap: 6px;
			font-size: 11px; color: var(--sd2-text-muted); overflow: hidden;
		}
		.sd2-browser-url svg { width: 10px; height: 10px; color: #16a34a; flex-shrink: 0; }

		.sd2-browser-viewport { position: relative; height: clamp(280px, 34vh, 400px); overflow: hidden; background: #0d0f1a; }
		.sd2-bv-slide { position: absolute; inset: 0; opacity: 0; transition: opacity 1s ease; }
		.sd2-bv-slide.sd2-active { opacity: 1; }
		.sd2-bv-overlay {
			position: absolute; inset: 0;
			background: linear-gradient(105deg, rgba(2,3,12,0.60) 0%, rgba(2,3,12,0.18) 55%, transparent 100%);
		}
		.sd2-bv-link { position: absolute; inset: 0; display: block; }
		.sd2-bv-link img { width: 100%; height: 100%; object-fit: cover; display: block; }
		.sd2-bv-dots { position: absolute; bottom: 10px; right: 12px; display: flex; gap: 5px; z-index: 3; }
		.sd2-bv-dot {
			width: 6px; height: 6px; border-radius: 50%; background: rgba(255,255,255,0.35);
			cursor: pointer; border: none; padding: 0; transition: all 0.2s ease;
		}
		.sd2-bv-dot.sd2-active { width: 18px; border-radius: 3px; background: #fff; }

		.sd2-browser-stats { display: grid; grid-template-columns: repeat(3,1fr); border-top: 1px solid rgba(24,51,184,0.08); }
		.sd2-bstat { padding: 12px; border-right: 1px solid rgba(24,51,184,0.08); display: flex; align-items: center; gap: 9px; }
		.sd2-bstat:last-child { border-right: none; }
		.sd2-bstat-icon { width: 28px; height: 28px; border-radius: 7px; display: flex; align-items: center; justify-content: center; flex-shrink: 0; }
		.sd2-bstat-icon svg { width: 13px; height: 13px; }
		.sd2-bstat-num { font-family: 'Oswald', sans-serif; font-size: 15px; font-weight: 700; color: var(--sd2-text); line-height: 1; }
		.sd2-bstat-label { font-size: 9px; color: var(--sd2-text-muted); margin-top: 1px; }

		.sd2-device-badge {
			position: absolute; top: -14px; right: -20px;
			background: var(--sd2-blue); color: #fff; border-radius: 12px; padding: 9px 14px;
			font-family: 'Oswald', sans-serif; font-size: 12px; font-weight: 600; letter-spacing: 0.5px;
			box-shadow: 0 8px 24px rgba(24,51,184,0.40);
			display: flex; align-items: center; gap: 7px;
			animation: sd2BadgeFloat 3s ease-in-out infinite; z-index: 10; white-space: nowrap;
		}
		@keyframes sd2BadgeFloat { 0%,100% { transform: translateY(0); } 50% { transform: translateY(-6px); } }
		.sd2-device-badge-dot { width: 8px; height: 8px; border-radius: 50%; background: #4ade80; }

		.sd2-device-rating {
			position: absolute; bottom: -14px; left: -24px;
			background: rgba(255,255,255,0.97); backdrop-filter: blur(12px);
			border: 1.5px solid rgba(24,51,184,0.12); border-radius: 14px; padding: 12px 14px;
			display: flex; align-items: center; gap: 11px; box-shadow: var(--sd2-shadow-lg); z-index: 10;
		}
		.sd2-dr-info-big { font-family: 'Oswald', sans-serif; font-size: 19px; font-weight: 700; color: var(--sd2-text); line-height: 1; }
		.sd2-dr-info-big span { color: var(--sd2-blue); font-size: 13px; }
		.sd2-dr-info-stars { color: var(--sd2-gold); font-size: 11px; margin-top: 2px; letter-spacing: 1px; }
		.sd2-dr-info-label { font-size: 9.5px; color: var(--sd2-text-muted); margin-top: 2px; }

		@media (max-width: 1100px) {
			.sd2-hero-content { grid-template-columns: 1fr; padding: 56px 40px; }
			.sd2-hero-right { display: none; }
		}
		@media (max-width: 768px) {
			.sd2-hero-content { padding: 44px 20px; }
		}

		/* ═══════════════════════════════════════════
		   sd2-counters — new counter ribbon
		   ═══════════════════════════════════════════ */
		.sd2-counter-ribbon { background: var(--sd2-blue); padding: 44px 28px; position: relative; overflow: hidden; }
		.sd2-counter-grid {
			max-width: var(--sd2-max); margin: 0 auto;
			display: grid; grid-template-columns: repeat(4, 1fr);
			position: relative; z-index: 1;
		}
		.sd2-counter-item { text-align: center; padding: 8px 16px; border-right: 1px solid rgba(255,255,255,0.12); }
		.sd2-counter-item:last-child { border-right: none; }
		.sd2-counter-num { font-family: 'Oswald', sans-serif; font-size: clamp(32px, 4.5vw, 50px); font-weight: 700; color: #fff; line-height: 1; margin-bottom: 6px; }
		.sd2-counter-num .sd2-suf { color: #FFD966; }
		.sd2-counter-label { font-size: 11px; font-weight: 500; letter-spacing: 2px; text-transform: uppercase; color: rgba(255,255,255,0.55); }
		@media (max-width: 1100px) {
			.sd2-counter-grid { grid-template-columns: repeat(2, 1fr); }
			.sd2-counter-item { border-bottom: 1px solid rgba(255,255,255,0.10); }
		}
		@media (max-width: 480px) { .sd2-counter-grid { grid-template-columns: 1fr 1fr; } }

		/* ═══════════════════════════════════════════
		   sd2-categories — restyle the existing
		   readytheme featured-categories block only
		   ═══════════════════════════════════════════ */
		.sd2-categories-card {
			max-width: 1320px; margin: 56px auto 64px; padding: 0 28px; background: transparent;
		}
		.sd2-categories-card .t-featured-categories {
			display: grid; grid-template-columns: repeat(4, minmax(0, 1fr));
			gap: 18px; align-items: stretch; max-width: none; margin: 0; padding: 0;
		}
		.sd2-categories-card .t-featured-categories > div:first-child { grid-column: 1 / -1; width: 100%; padding: 0 0 28px; text-align: center; }
		.sd2-categories-card .t-featured-categories__heading {
			margin: 0; font-family: 'Oswald', sans-serif; font-size: clamp(26px, 3.5vw, 40px);
			font-weight: 700; letter-spacing: 0.5px; text-transform: uppercase; color: var(--sd2-text);
		}
		.sd2-categories-card .x-product-list__item { width: 100% !important; max-width: none; padding: 0; margin: 0; display: flex; }
		.sd2-categories-card .x-product-list__link {
			position: relative; display: block; width: 100%; overflow: hidden;
			min-height: clamp(250px, 23vw, 360px);
			background: rgba(255,255,255,0.76); border: 1px solid rgba(24,51,184,0.16);
			border-radius: 14px; box-shadow: 0 16px 42px rgba(24,51,184,0.14);
			transition: transform 0.4s var(--sd2-ease-out), box-shadow 0.4s ease, border-color 0.2s ease;
		}
		.sd2-categories-card .x-product-list__link:hover,
		.sd2-categories-card .x-product-list__link:focus-visible {
			transform: translateY(-8px); border-color: rgba(24,51,184,0.25); box-shadow: var(--sd2-shadow-xl);
		}
		.sd2-categories-card .x-product-list__figure { position: absolute; inset: 0; height: 100%; margin: 0; padding: 0; background: #fff; }
		.sd2-categories-card .x-product-list__figure::after {
			content: ''; position: absolute; inset: auto 0 0; height: 44%;
			background: linear-gradient(180deg, rgba(255,255,255,0) 0%, rgba(255,255,255,0.86) 54%, rgba(255,255,255,0.98) 100%);
			pointer-events: none;
		}
		.sd2-categories-card .x-product-list__image {
			display: block; width: 100%; height: 100%; aspect-ratio: auto; object-fit: cover;
			transition: transform 0.5s var(--sd2-ease-out);
		}
		.sd2-categories-card .x-product-list__link:hover .x-product-list__image { transform: scale(1.06); }
		.sd2-categories-card .t-featured-categories > a,
		.sd2-categories-card .t-featured-categories > li > a,
		.sd2-categories-card .t-featured-categories > div:not(:first-child) > a {
			position: relative !important;
			display: block !important;
			min-height: clamp(250px, 23vw, 360px) !important;
			overflow: hidden !important;
			border: 1px solid rgba(24,51,184,0.16) !important;
			border-radius: 14px !important;
			background: rgba(255,255,255,0.76) !important;
			box-shadow: 0 16px 42px rgba(24,51,184,0.14) !important;
			text-decoration: none !important;
		}
		.sd2-categories-card .t-featured-categories > a::after,
		.sd2-categories-card .t-featured-categories > li > a::after,
		.sd2-categories-card .t-featured-categories > div:not(:first-child) > a::after {
			content: ''; position: absolute; inset: auto 0 0; height: 44%;
			background: linear-gradient(180deg, rgba(255,255,255,0) 0%, rgba(255,255,255,0.86) 54%, rgba(255,255,255,0.98) 100%);
			pointer-events: none;
		}
		.sd2-categories-card .t-featured-categories img {
			width: 100% !important;
			height: 100% !important;
			object-fit: cover !important;
			display: block !important;
		}
		.sd2-categories-card .t-featured-categories a span,
		.sd2-categories-card .t-featured-categories a strong {
			position: absolute !important;
			left: 18px !important;
			right: 18px !important;
			bottom: 28px !important;
			z-index: 2 !important;
			color: #0d0f1a !important;
			font-family: 'Oswald', sans-serif !important;
			font-size: 18px !important;
			font-weight: 800 !important;
			line-height: 1.05 !important;
			text-transform: uppercase !important;
		}
		.sd2-categories-card .t-featured-categories a span + span,
		.sd2-categories-card .t-featured-categories a small {
			bottom: 12px !important;
			color: rgba(13,15,26,0.58) !important;
			font-family: 'Inter', system-ui, sans-serif !important;
			font-size: 11px !important;
			font-weight: 700 !important;
			text-decoration: underline !important;
		}
		.sd2-categories-card .x-product-list__figure-caption,
		.sd2-categories-card .x-product-list__name,
		.sd2-categories-card .x-product-list__price,
		.sd2-categories-card figcaption {
			position: absolute !important;
			left: 18px !important;
			right: 18px !important;
			bottom: 18px !important;
			z-index: 2 !important;
			margin: 0 !important;
			padding: 0 !important;
			background: transparent !important;
			color: #0d0f1a !important;
			font-family: 'Oswald', sans-serif !important;
			font-size: 18px !important;
			font-weight: 800 !important;
			line-height: 1.05 !important;
			letter-spacing: 0 !important;
			text-transform: uppercase !important;
			text-align: left !important;
			text-shadow: 0 1px 18px rgba(255,255,255,0.9) !important;
		}
		.sd2-categories-card .x-product-list__figure-caption::after,
		.sd2-categories-card figcaption::after {
			content: 'Shop Now';
			display: block;
			margin-top: 5px;
			color: rgba(13,15,26,0.58);
			font-family: 'Inter', system-ui, sans-serif;
			font-size: 11px;
			font-weight: 700;
			letter-spacing: 0.3px;
			text-decoration: underline;
			text-transform: uppercase;
		}

		@media (max-width: 960px) { .sd2-categories-card .t-featured-categories { grid-template-columns: repeat(3, minmax(0, 1fr)); } }
		@media (max-width: 640px) {
			.sd2-categories-card { margin: 32px auto; padding: 0 14px; }
			.sd2-categories-card .t-featured-categories { grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 12px; }
			.sd2-categories-card .x-product-list__link { min-height: 190px; }
		}

		/* ═══════════════════════════════════════════
		   sd2-reviews
		   ═══════════════════════════════════════════ */
		.sd2-reviews-section { background: var(--sd2-bg-subtle); padding: 64px 28px; }
		.sd2-reviews-section__header { text-align: center; margin-bottom: 32px; }
		.sd2-reviews-section__stars { color: var(--sd2-gold); font-size: 18px; margin-bottom: 8px; letter-spacing: 2px; }
		.sd2-reviews-section__header h2 {
			font-family: 'Oswald', sans-serif; font-size: clamp(26px, 3.5vw, 40px); font-weight: 700;
			color: var(--sd2-text); text-transform: uppercase; letter-spacing: 0.5px; margin: 0 0 8px;
		}
		.sd2-reviews-section__header p { color: var(--sd2-text-muted); font-size: 13.5px; margin: 4px 0 0; }
		.sd2-review-carousel { max-width: var(--sd2-max); margin: 0 auto; padding: 0 8px; }
		.sd2-review-card {
			background: var(--sd2-bg-white); border: 1px solid var(--sd2-border); border-radius: var(--sd2-r);
			padding: 22px 20px; margin: 4px 8px; box-shadow: var(--sd2-shadow-sm);
			min-height: 170px; display: flex !important; flex-direction: column; justify-content: space-between;
			transition: transform 0.35s var(--sd2-ease-out), box-shadow 0.35s ease;
		}
		.sd2-review-card:hover { transform: translateY(-5px); box-shadow: var(--sd2-shadow-lg); }
		.sd2-review-card__top { display: flex; align-items: center; gap: 12px; margin-bottom: 12px; }
		.sd2-review-card__avatar {
			width: 42px; height: 42px; border-radius: 50%; background: var(--sd2-blue); color: #fff;
			font-family: 'Oswald', sans-serif; font-size: 18px; font-weight: 600;
			display: flex; align-items: center; justify-content: center; flex-shrink: 0;
		}
		.sd2-review-card__avatar.sd2-verified { background: linear-gradient(135deg, var(--sd2-blue), #4a6cf7); }
		.sd2-review-card__name { font-weight: 700; font-size: 14px; color: var(--sd2-text); }
		.sd2-review-card__meta { font-size: 11px; color: var(--sd2-text-muted); margin-top: 2px; }
		.sd2-review-card__meta .sd2-verified-badge { color: var(--sd2-blue); font-weight: 600; }
		.sd2-review-card__stars { color: var(--sd2-gold); font-size: 13px; letter-spacing: 1px; margin-bottom: 9px; }
		.sd2-review-card__text {
			font-size: 13.5px; color: var(--sd2-text-mid); line-height: 1.72; flex-grow: 1;
			display: -webkit-box; -webkit-line-clamp: 4; line-clamp: 4; -webkit-box-orient: vertical; overflow: hidden;
		}
		.sd2-review-card__date { font-size: 11px; color: var(--sd2-text-muted); margin-top: 10px; }
		.sd2-review-carousel .slick-prev, .sd2-review-carousel .slick-next { display: none !important; }
		.sd2-reviews-section__footer { text-align: center; margin-top: 36px; }
		.sd2-reviews-section__footer .sd2-btn { display: inline-flex; }

		/* ═══════════════════════════════════════════
		   sd2-brand — brand split sections
		   ═══════════════════════════════════════════ */
		.sd2-brand-wrap { overflow: hidden; }
		.sd2-brand-wrap--white { background: var(--sd2-bg-white); }
		.sd2-brand-wrap--light { background: var(--sd2-bg-subtle); }
		.sd2-brand-section { max-width: var(--sd2-max); margin: 0 auto; padding: 64px 32px; display: flex; align-items: center; gap: 52px; }
		.sd2-brand-section--reverse { flex-direction: row-reverse; }
		.sd2-brand-section__img {
			flex: 0 0 48%; max-width: 48%; border-radius: var(--sd2-r); overflow: hidden; position: relative;
			box-shadow: 0 4px 24px rgba(0,0,0,0.09);
		}
		.sd2-brand-section__img img { width: 100%; height: 100%; display: block; object-fit: cover; aspect-ratio: 16/10; transition: transform 0.55s ease; }
		.sd2-brand-section__img:hover img { transform: scale(1.04); }
		.sd2-brand-section__img::after { content: ''; position: absolute; bottom: 0; left: 0; width: 48px; height: 3px; background: var(--sd2-gold); }
		.sd2-brand-section--reverse .sd2-brand-section__img::after { left: auto; right: 0; }
		.sd2-brand-section__body { flex: 1; min-width: 0; }
		.sd2-brand-eyebrow {
			font-size: 9px; font-weight: 700; letter-spacing: 4px; text-transform: uppercase; color: var(--sd2-blue);
			display: flex; align-items: center; gap: 10px; margin-bottom: 14px;
		}
		.sd2-brand-eyebrow::before { content: ''; width: 20px; height: 2px; background: var(--sd2-blue); border-radius: 2px; }
		.sd2-brand-section__body h2 {
			font-family: 'Oswald', sans-serif; font-size: clamp(26px, 3.2vw, 38px); font-weight: 700; color: var(--sd2-text);
			text-transform: uppercase; letter-spacing: 1px; line-height: 1.05; position: relative; padding-bottom: 18px; margin: 0;
		}
		.sd2-brand-section__body h2::after {
			content: ''; position: absolute; bottom: 0; left: 0; width: 36px; height: 3px; background: var(--sd2-gold);
			border-radius: 2px; transition: width 0.35s ease;
		}
		.sd2-brand-section__body:hover h2::after { width: 64px; }
		.sd2-brand-section__body p { font-size: 14.5px; color: var(--sd2-text-mid); line-height: 1.78; margin: 18px 0 0; }
		.sd2-brand-stats { display: flex; gap: 28px; margin-top: 26px; flex-wrap: wrap; }
		.sd2-bs-num { font-family: 'Oswald', sans-serif; font-size: 28px; font-weight: 700; color: var(--sd2-blue); }
		.sd2-bs-label { font-size: 11px; color: var(--sd2-text-muted); text-transform: uppercase; letter-spacing: 0.5px; margin-top: 2px; }

		@media (max-width: 960px) {
			.sd2-brand-section, .sd2-brand-section--reverse { flex-direction: column; gap: 28px; padding: 40px 20px; }
			.sd2-brand-section__img { flex: unset; max-width: 100%; width: 100%; }
			.sd2-brand-section__img img { aspect-ratio: 16/7; }
		}

		/* ═══════════════════════════════════════════
		   sd2-reveal (scroll-in animation, reused sitewide)
		   ═══════════════════════════════════════════ */
		.sd2-reveal { opacity: 0; transform: translateY(24px); transition: opacity 0.65s ease, transform 0.65s var(--sd2-ease-out); }
		.sd2-reveal--left  { transform: translateX(-24px); }
		.sd2-reveal--right { transform: translateX(24px); }
		.sd2-reveal.sd2-in { opacity: 1; transform: none; }

		@media (prefers-reduced-motion: reduce) {
			.sd2-hero *, .sd2-hero *::before, .sd2-hero *::after {
				animation-duration: 0.01ms !important; animation-iteration-count: 1 !important; transition-duration: 0.01ms !important;
			}
		}

		/* sd2 homepage final polish: match homepage-v3-premium mockup proportions */
		body#js-SFNT .sd2-hero {
			min-height: clamp(560px, 68vh, 720px);
			max-height: 760px;
		}
		body#js-SFNT .sd2-hero-content {
			max-width: 1280px;
			padding: 64px 48px 58px;
			grid-template-columns: minmax(0, 0.9fr) minmax(420px, 1.1fr);
