		@media (max-width: 640px) {
			body#js-SFNT .sd2-hero-content {
				padding: 38px 18px;
			}
			body#js-SFNT .sd2-counter-ribbon {
				padding: 28px 16px;
			}
			body#js-SFNT .sd-finder__mobile-toggle {
				display: inline-flex !important;
				align-items: center !important;
				justify-content: space-between !important;
