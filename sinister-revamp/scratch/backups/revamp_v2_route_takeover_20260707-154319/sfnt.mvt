		<script>
			(function initReviewCarousel() {
				function run($) {
					if (!$.fn.slick) { return; }
					setTimeout(function () {
						$('.sd2-review-carousel').slick({
							slidesToShow: 3,
							slidesToScroll: 1,
							autoplay: true,
							autoplaySpeed: 4000,
							dots: false,
							arrows: false,
							infinite: true,
							speed: 500,
							pauseOnHover: true,
							waitForAnimate: false,
							responsive: [
								{ breakpoint: 1024, settings: { slidesToShow: 2 } },
								{ breakpoint: 640,  settings: { slidesToShow: 1 } }
							]
						});
					}, 0);
				}
				if (typeof jQuery !== 'undefined') {
					jQuery(document).ready(function ($) { run($); });
				} else {
					document.addEventListener('DOMContentLoaded', function () {
						if (typeof jQuery !== 'undefined') { jQuery(document).ready(function ($) { run($); }); }
					});
				}
			})();
		</script>

