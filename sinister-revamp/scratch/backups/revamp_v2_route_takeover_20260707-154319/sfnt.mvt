			padding: 0 24px;
		}
		body#js-SFNT .sd2-categories-card .t-featured-categories {
			grid-template-columns: repeat(4, minmax(0, 1fr)) !important;
			gap: 18px !important;
		}
		body#js-SFNT .sd2-categories-card .x-product-list__link {
			border-radius: 12px;
			min-height: clamp(250px, 23vw, 360px) !important;
			background: rgba(255,255,255,0.66) !important;
			border: 1px solid rgba(255,255,255,0.5) !important;
			backdrop-filter: blur(16px) saturate(140%) !important;
			-webkit-backdrop-filter: blur(16px) saturate(140%) !important;
			box-shadow: 0 14px 38px rgba(24,51,184,0.13), inset 0 1px 0 rgba(255,255,255,0.52) !important;
		}
		body#js-SFNT .sd2-reviews-section {
			padding: 58px 28px;
