<body id="js-&mvte:page:code;" class="o-site-wrapper t-page-&mvt:global:pageClass; u-bg-gray-10">

	<canvas id="sd2-canvas" aria-hidden="true"></canvas>

	<mvt:item name="hdft" param="global_header" />
	<section class="o-layout">
		<div class="o-layout__item">
			<mvt:item name="hdft" param="header" />
		</div>
	</section>

	<!-- sd2 HERO -->
	<section class="sd2-hero" id="sd2-hero" aria-label="Hero">
		<div class="sd2-hero-geo" aria-hidden="true">
			<div class="sd2-geo-circle-1"></div>
			<div class="sd2-geo-circle-2"></div>
		</div>
		<div class="sd2-hero-orb sd2-hero-orb-1" aria-hidden="true"></div>
		<div class="sd2-hero-orb sd2-hero-orb-2" aria-hidden="true"></div>
		<div class="sd2-hero-dots-bg" aria-hidden="true"></div>

		<div class="sd2-hero-content">
			<div>
				<div class="sd2-hero-badge">
					<span class="sd2-badge-dot" aria-hidden="true"></span>
					Experience Diesel Done Right
				</div>
				<h1 class="sd2-hero-title">
					Built to Perform<br>
					<span class="sd2-accent">Engineered to Last</span>
				</h1>
				<p class="sd2-hero-sub">Premium diesel performance parts for Power Stroke, Duramax &amp; Cummins &mdash; proudly built in the USA since 2008.</p>
				<div class="sd2-hero-ctas">
					<a href="#sd2-finder" class="sd2-btn sd2-btn-primary">
						<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>
						Shop by Truck
					</a>
					<a href="#sd2-categories" class="sd2-btn sd2-btn-outline">Browse All Parts</a>
				</div>
			</div>

			<div class="sd2-hero-right">
				<div class="sd2-device-wrap" id="sd2-device-wrap">

					<div class="sd2-device-badge" aria-hidden="true">
						<span class="sd2-device-badge-dot"></span>
						20,000+ Verified Reviews
					</div>

					<div class="sd2-device-rating" aria-label="4.8 star rating from 20,000+ reviews">
						<div>
							<div class="sd2-dr-info-big">20K<span>+</span></div>
							<div class="sd2-dr-info-stars">&#9733;&#9733;&#9733;&#9733;&#9733;</div>
							<div class="sd2-dr-info-label">Verified Reviews</div>
						</div>
					</div>

					<div class="sd2-browser-shell">
						<div class="sd2-browser-bar">
							<div class="sd2-browser-dots">
								<div class="sd2-browser-dot sd2-bd-red"></div>
								<div class="sd2-browser-dot sd2-bd-amber"></div>
								<div class="sd2-browser-dot sd2-bd-green"></div>
							</div>
							<div class="sd2-browser-url">
								<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
								<span>sinisterdiesel.com</span>
							</div>
						</div>

						<div class="sd2-browser-viewport" id="sd2-bv-viewport">
							<!-- Slides reuse the real admin-managed banner images below (sd2-hero-banner-source), duplicated here via JS so content stays admin-editable in one place -->
						</div>

						<div class="sd2-browser-stats">
							<div class="sd2-bstat">
								<div class="sd2-bstat-icon" style="background:var(--sd2-blue-light)">
									<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="color:var(--sd2-blue)"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
								</div>
								<div><div class="sd2-bstat-num">17+ Yrs</div><div class="sd2-bstat-label">In Business</div></div>
							</div>
							<div class="sd2-bstat">
								<div class="sd2-bstat-icon" style="background:#fff8e6">
									<svg viewBox="0 0 24 24" fill="currentColor" style="color:var(--sd2-gold)"><path d="M12 17.27L18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z"/></svg>
								</div>
								<div><div class="sd2-bstat-num">4.8 &#9733;</div><div class="sd2-bstat-label">Shopper Approved</div></div>
							</div>
							<div class="sd2-bstat">
								<div class="sd2-bstat-icon" style="background:#e8fff2">
									<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="color:#16a34a"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
								</div>
