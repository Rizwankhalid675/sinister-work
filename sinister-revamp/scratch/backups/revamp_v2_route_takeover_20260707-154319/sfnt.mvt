				gap: 10px !important;
			}
			body#js-SFNT .sd2-btn {
				justify-content: center !important;
				padding: 12px 10px !important;
				font-size: 11px !important;
			}
			body#js-SFNT .sd2-counter-ribbon {
				padding: 28px 12px !important;
			}
			body#js-SFNT .sd2-counter-grid {
