	<script>
	(function () {
		'use strict';

		/* ── sd2 PARTICLE CANVAS ─────────────────────── */
		var canvas = document.getElementById('sd2-canvas');
		var reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

		if (canvas && !reduced) {
			var ctx = canvas.getContext('2d');
			var W, H, pts = [];
			var BLUE_C = 'rgba(24,51,184,';
			var GOLD_C = 'rgba(180,120,0,';

			function resize() {
				W = canvas.width  = window.innerWidth;
				H = canvas.height = window.innerHeight;
			}
			function Dot() { this.init(); }
			Dot.prototype.init = function () {
				this.x  = Math.random() * W;
				this.y  = Math.random() * H;
				this.r  = Math.random() * 3 + 1.2;
				this.vx = (Math.random() - 0.5) * 0.35;
				this.vy = (Math.random() - 0.5) * 0.35;
				this.a  = Math.random() * 0.45 + 0.25;
				this.c  = Math.random() > 0.88 ? GOLD_C : BLUE_C;
			};
			Dot.prototype.step = function () {
				this.x += this.vx;
				this.y += this.vy;
				if (this.x < -10 || this.x > W + 10 || this.y < -10 || this.y > H + 10) { this.init(); }
			};
			function initDots(n) {
				pts = [];
				for (var i = 0; i < n; i++) { pts.push(new Dot()); }
			}
			function draw() {
				ctx.clearRect(0, 0, W, H);
				var len = pts.length;
				for (var i = 0; i < len; i++) {
					pts[i].step();
					ctx.beginPath();
					ctx.arc(pts[i].x, pts[i].y, pts[i].r, 0, Math.PI * 2);
					ctx.fillStyle = pts[i].c + pts[i].a + ')';
					ctx.fill();
				}
				for (var a = 0; a < len; a++) {
					for (var b = a + 1; b < len; b++) {
						var dx = pts[a].x - pts[b].x;
						var dy = pts[a].y - pts[b].y;
						var d  = Math.sqrt(dx * dx + dy * dy);
						if (d < 130) {
							ctx.beginPath();
							ctx.moveTo(pts[a].x, pts[a].y);
							ctx.lineTo(pts[b].x, pts[b].y);
							ctx.strokeStyle = BLUE_C + (0.22 * (1 - d / 130)) + ')';
							ctx.lineWidth = 1;
							ctx.stroke();
						}
					}
				}
				requestAnimationFrame(draw);
			}
			resize();
			initDots(70);
			draw();
			window.addEventListener('resize', function () { resize(); initDots(70); }, { passive: true });
		}

		/* ── sd2 HERO BANNER (mirrors #sd2-hero-banner-source, kept admin-editable) ── */
		var source = document.getElementById('sd2-hero-banner-source');
		var viewport = document.getElementById('sd2-bv-viewport');
		if (source && viewport) {
			var slides = source.querySelectorAll(':scope > div');
			var dotsWrap = document.createElement('div');
			dotsWrap.className = 'sd2-bv-dots';
			dotsWrap.setAttribute('role', 'tablist');
			dotsWrap.setAttribute('aria-label', 'Banner slides');

			slides.forEach(function (slide, i) {
				var link = slide.querySelector('a');
				var img  = slide.querySelector('img');
				if (!link || !img) { return; }

				var bvSlide = document.createElement('div');
				bvSlide.className = 'sd2-bv-slide' + (i === 0 ? ' sd2-active' : '');

				var bvLink = document.createElement('a');
				bvLink.className = 'sd2-bv-link';
				bvLink.href = link.getAttribute('href');

				var bvImg = document.createElement('img');
				bvImg.src = img.getAttribute('src');
				bvImg.alt = img.getAttribute('alt') || '';
				bvLink.appendChild(bvImg);

				var overlay = document.createElement('div');
				overlay.className = 'sd2-bv-overlay';

				bvSlide.appendChild(bvLink);
				bvSlide.appendChild(overlay);
				viewport.appendChild(bvSlide);

				var dot = document.createElement('button');
				dot.className = 'sd2-bv-dot' + (i === 0 ? ' sd2-active' : '');
				dot.type = 'button';
				dot.dataset.bv = i;
				dot.setAttribute('aria-label', 'Slide ' + (i + 1));
				dotsWrap.appendChild(dot);
			});
			viewport.appendChild(dotsWrap);

			var bvSlideEls = viewport.querySelectorAll('.sd2-bv-slide');
			var bvDotEls   = viewport.querySelectorAll('.sd2-bv-dot');
			var bvCur = 0, bvTimer;

			function bvGo(n) {
				if (!bvSlideEls.length) return;
				bvSlideEls[bvCur].classList.remove('sd2-active');
				bvDotEls[bvCur].classList.remove('sd2-active');
				bvCur = (n + bvSlideEls.length) % bvSlideEls.length;
				bvSlideEls[bvCur].classList.add('sd2-active');
				bvDotEls[bvCur].classList.add('sd2-active');
			}
			bvDotEls.forEach(function (d) {
				d.addEventListener('click', function () {
					bvGo(parseInt(this.dataset.bv, 10));
					clearInterval(bvTimer);
					bvTimer = setInterval(function () { bvGo(bvCur + 1); }, 4000);
				});
			});
			if (!reduced && bvSlideEls.length > 1) {
				bvTimer = setInterval(function () { bvGo(bvCur + 1); }, 4000);
			}
		}

		/* ── sd2 DEVICE FRAME MOUSE PARALLAX TILT ────── */
		var dw = document.getElementById('sd2-device-wrap');
		var heroEl = document.getElementById('sd2-hero');
		if (dw && heroEl && !reduced && window.innerWidth > 900) {
			heroEl.addEventListener('mousemove', function (e) {
				var r  = heroEl.getBoundingClientRect();
				var cx = r.left + r.width  / 2;
				var cy = r.top  + r.height / 2;
				var dx = (e.clientX - cx) / (r.width  / 2);
				var dy = (e.clientY - cy) / (r.height / 2);
				var ry = -8 + dx * 5;
				var rx =  2 - dy * 3;
				dw.style.transform = 'perspective(1100px) rotateY(' + ry + 'deg) rotateX(' + rx + 'deg)';
			});
			heroEl.addEventListener('mouseleave', function () {
				dw.style.transform = 'perspective(1100px) rotateY(-8deg) rotateX(2deg)';
			});
		}

		/* ── sd2 COUNTER ANIMATION ────────────────────── */
		var counters = document.querySelectorAll('.sd2-counter-num[data-target]');
		var counted  = false;
		var ribbon   = document.querySelector('.sd2-counter-ribbon');

		function runCounters() {
			counters.forEach(function (el) {
				var target = parseInt(el.dataset.target, 10);
				var suf    = el.dataset.suf || '';
				var dur    = 1800;
				var fps    = 60;
				var steps  = (dur / 1000) * fps;
				var inc    = target / steps;
				var t      = 0;
				var id = setInterval(function () {
					t += inc;
					if (t >= target) { t = target; clearInterval(id); }
					el.innerHTML = Math.round(t) + '<span class="sd2-suf">' + suf + '</span>';
				}, 1000 / fps);
			});
		}
		if (ribbon && 'IntersectionObserver' in window) {
			var co = new IntersectionObserver(function (entries) {
				if (entries[0].isIntersecting && !counted) {
					counted = true;
					runCounters();
					co.disconnect();
				}
			}, { threshold: 0.4 });
			co.observe(ribbon);
		} else if (ribbon) {
			runCounters();
		}

		/* ── sd2 SCROLL REVEAL ─────────────────────────── */
		var revealEls = document.querySelectorAll('.sd2-reveal');
		if ('IntersectionObserver' in window) {
			var io = new IntersectionObserver(function (entries) {
				entries.forEach(function (e) {
					if (e.isIntersecting) {
						e.target.classList.add('sd2-in');
						io.unobserve(e.target);
					}
				});
			}, { threshold: 0.12, rootMargin: '0px 0px -36px 0px' });
			revealEls.forEach(function (el) { io.observe(el); });
		} else {
			revealEls.forEach(function (el) { el.classList.add('sd2-in'); });
		}

	})();
	</script>

</body>
</html>
