			backdrop-filter: blur(18px) saturate(145%) !important;
			-webkit-backdrop-filter: blur(18px) saturate(145%) !important;
			box-shadow: 0 18px 52px rgba(24,51,184,0.16), inset 0 1px 0 rgba(255,255,255,0.5) !important;
		}
		body#js-SFNT .sd-finder__mobile-toggle {
			display: none !important;
		}
		body#js-SFNT .sd-finder__widget {
			display: block !important;
		}
		body#js-SFNT .sd-truck-finder {
			width: 100% !important;
