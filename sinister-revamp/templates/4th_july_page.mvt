</div>

<div class="toast" id="toast">🧨 Code <span class="t-code">JULY4SD</span> copied to clipboard!</div>

<script>
(function(){
'use strict';

var sky=document.getElementById('sky');
var sctx=sky.getContext('2d');
function resizeSky(){sky.width=window.innerWidth;sky.height=window.innerHeight;}
resizeSky();
window.addEventListener('resize',resizeSky);

var FW_COLORS=['#ef4444','#f97316','#ffffff','#3b82f6','#f5c518','#a855f7','#10b981','#ec4899'];
var particles=[];

function Spark(x,y,col){
  this.x=x;this.y=y;this.col=col;
  var a=Math.random()*Math.PI*2,s=1+Math.random()*5;
  this.vx=Math.cos(a)*s;this.vy=Math.sin(a)*s;
  this.life=1;this.decay=0.008+Math.random()*0.018;
  this.r=1.5+Math.random()*3;this.gravity=0.04;
  this.trail=[];
}
Spark.prototype.update=function(){
  this.trail.push({x:this.x,y:this.y});
  if(this.trail.length>6)this.trail.shift();
  this.x+=this.vx;this.y+=this.vy;
  this.vy+=this.gravity;this.vx*=0.98;
  this.life-=this.decay;
};
Spark.prototype.draw=function(){
  for(var t=0;t<this.trail.length;t++){
    var a=this.life*(t/this.trail.length)*0.4;
    sctx.beginPath();
    sctx.arc(this.trail[t].x,this.trail[t].y,this.r*(t/this.trail.length),0,Math.PI*2);
    sctx.fillStyle=this.col;
    sctx.globalAlpha=Math.max(0,a);
    sctx.fill();
  }
  sctx.globalAlpha=Math.max(0,this.life);
  sctx.beginPath();
  sctx.arc(this.x,this.y,this.r,0,Math.PI*2);
  sctx.fillStyle=this.col;
  sctx.fill();
  sctx.globalAlpha=1;
};

function burst(x,y){
  var col=FW_COLORS[Math.floor(Math.random()*FW_COLORS.length)];
  var n=60+Math.floor(Math.random()*80);
  for(var i=0;i<n;i++)particles.push(new Spark(x,y,col));
  var col2=FW_COLORS[Math.floor(Math.random()*FW_COLORS.length)];
  for(var j=0;j<20;j++)particles.push(new Spark(x,y,col2));
}

var lastBurst=0;
var active=false;
function skyLoop(ts){
  sctx.fillStyle='rgba(0,0,0,0.18)';
  sctx.fillRect(0,0,sky.width,sky.height);
  if(active&&ts-lastBurst>900+Math.random()*1400){
    burst(sky.width*(.1+Math.random()*.8),sky.height*(.05+Math.random()*.45));
    lastBurst=ts;
  }
  for(var i=particles.length-1;i>=0;i--){
    particles[i].update();particles[i].draw();
    if(particles[i].life<=0)particles.splice(i,1);
  }
  requestAnimationFrame(skyLoop);
}
requestAnimationFrame(skyLoop);

document.getElementById('introBtn').addEventListener('click',function(){
  var intro=document.getElementById('intro');
  var main=document.getElementById('main');
  intro.classList.add('gone');
  main.classList.add('visible');
  active=true;
  document.getElementById('navbar').classList.add('visible');
  setTimeout(function(){
    for(var i=0;i<4;i++){
      (function(delay){
        setTimeout(function(){
          burst(sky.width*(.2+Math.random()*.6),sky.height*(.1+Math.random()*.4));
        },delay);
      })(i*300);
    }
  },400);
});

var navbar=document.getElementById('navbar');
var main=document.getElementById('main');
main.addEventListener('scroll',function(){
  if(main.scrollTop>60){navbar.classList.add('solid');}
  else{navbar.classList.remove('solid');}
},{passive:true});

var hamburgerBtn=document.getElementById('hamburgerBtn');
var mobileMenu=document.getElementById('mobileMenu');
hamburgerBtn.addEventListener('click',function(){
  mobileMenu.classList.toggle('open');
});

function scrollToSection(id){
  var el=document.getElementById(id);
  if(el)el.scrollIntoView({behavior:'smooth'});
  mobileMenu.classList.remove('open');
}
document.getElementById('navDeals').addEventListener('click',function(e){e.preventDefault();scrollToSection('sec-deals');});
document.getElementById('navGetCode').addEventListener('click',function(e){e.preventDefault();scrollToSection('s2');});
document.getElementById('mobDeals').addEventListener('click',function(e){e.preventDefault();scrollToSection('sec-deals');});
document.getElementById('mobGetCode').addEventListener('click',function(e){e.preventDefault();scrollToSection('s2');});

var sectionLabels={
  s1:'Sale Hero',
  'sec-highlights':'Featured Deals',
  s3:'Shop by Truck',
  'sec-deals':'Best Deals',
  'sec-cat':'Shop by Category',
  'sec-oem':'OEM Solutions',
  'sec-fav':'Fan Favorites',
  'sec-why':'Why Sinister Diesel',
  s2:'Get Discount Code',
  'sec-u250':'Upgrades Under $250',
  'sec-rev':'Customer Reviews',
  s4:'Shop the Sale'
};
var dotTargets=[];
var dotsWrap=document.getElementById('navDots');
var pageSections=[];
for(var childIndex=0;childIndex<main.children.length;childIndex++){
  var mainChild=main.children[childIndex];
  if(mainChild.tagName==='SECTION'&&mainChild.id)pageSections.push(mainChild);
}

for(var dotIndex=0;dotIndex<pageSections.length;dotIndex++){
  var sectionId=pageSections[dotIndex].id;
  dotTargets.push(sectionId);
  var dot=document.createElement('button');
  dot.type='button';
  dot.className='nav-dot'+(dotIndex===0?' active':'');
  dot.setAttribute('data-target',sectionId);
  dot.setAttribute('aria-label','Go to '+(sectionLabels[sectionId]||'section'));
  dot.setAttribute('title',sectionLabels[sectionId]||'Section');
  dotsWrap.appendChild(dot);
}
var dots=dotsWrap.querySelectorAll('.nav-dot');

function updateDots(){
  var scrollTop=main.scrollTop;
  var viewH=main.clientHeight;
  var midY=scrollTop+viewH/2;
  var best=0;
  var bestDist=Infinity;
  dotTargets.forEach(function(id,i){
    var el=document.getElementById(id);
    if(!el)return;
    var elTop=el.offsetTop;
    var elH=el.offsetHeight||viewH;
    var elMid=elTop+elH/2;
    var dist=Math.abs(midY-elMid);
    if(dist<bestDist){bestDist=dist;best=i;}
  });
  dots.forEach(function(d,i){
    d.classList.toggle('active',i===best);
  });
}
main.addEventListener('scroll',updateDots,{passive:true});

dots.forEach(function(d){
  d.addEventListener('click',function(){
    var id=d.getAttribute('data-target');
    scrollToSection(id);
  });
});

var end=new Date('2026-07-08T00:00:00').getTime();
var circ=2*Math.PI*44;
function setRing(el,val,max){
  if(!el)return;
  el.style.strokeDashoffset=circ-(circ*(val/max));
}
function pad(n){return n<10?'0'+n:''+n;}
function tick(){
  var now=Date.now();
  var diff=Math.max(0,end-now);
  var d=Math.floor(diff/86400000);
  var h=Math.floor((diff%86400000)/3600000);
  var m=Math.floor((diff%3600000)/60000);
  var s=Math.floor((diff%60000)/1000);
  var dEl=document.getElementById('cdDays');
  var hEl=document.getElementById('cdHours');
  var mEl=document.getElementById('cdMins');
  var sEl=document.getElementById('cdSecs');
  if(dEl)dEl.textContent=pad(d);
  if(hEl)hEl.textContent=pad(h);
  if(mEl)mEl.textContent=pad(m);
  if(sEl)sEl.textContent=pad(s);
  setRing(document.getElementById('rD'),d,365);
  setRing(document.getElementById('rH'),h,24);
  setRing(document.getElementById('rM'),m,60);
  setRing(document.getElementById('rS'),s,60);
}
tick();setInterval(tick,1000);

var toastEl=document.getElementById('toast');
var toastTimer;
function showToast(){
  clearTimeout(toastTimer);
  toastEl.classList.add('show');
  toastTimer=setTimeout(function(){toastEl.classList.remove('show');},2400);
}
function copyCode(){
  var code='JULY4SD';
  if(navigator.clipboard&&navigator.clipboard.writeText){
    navigator.clipboard.writeText(code).then(showToast).catch(fb);
  }else{fb();}
  function fb(){
    var ta=document.createElement('textarea');
    ta.value=code;ta.style.cssText='position:fixed;left:-9999px;opacity:0';
    document.body.appendChild(ta);ta.select();
    try{document.execCommand('copy');showToast();}catch(e){}
    document.body.removeChild(ta);
  }
}

var detBtn=document.getElementById('detBtn');
var detDisplay=document.getElementById('detDisplay');
var detHint=document.getElementById('detHint');
var detUseBtn=document.getElementById('detUseBtn');
var detonated=false;
var scrambleChars='ABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789!@#$%';
var code='JULY4SD';

function scramble(progress){
  var result='';
  for(var i=0;i<code.length;i++){
    if(i<Math.floor(progress*code.length)){
      result+=code[i];
    }else{
      result+=scrambleChars[Math.floor(Math.random()*scrambleChars.length)];
    }
  }
  return result;
}

detBtn.addEventListener('click',function(){
  if(detonated)return;
  detonated=true;
  detBtn.classList.add('detonated');
  for(var i=0;i<6;i++){
    (function(delay){
      setTimeout(function(){
        burst(sky.width*(.15+Math.random()*.7),sky.height*(.05+Math.random()*.5));
      },delay);
    })(i*200);
  }
  var start=null;
  var duration=2000;
  function frame(ts){
    if(!start)start=ts;
    var p=Math.min(1,(ts-start)/duration);
    var ep=p<.5?2*p*p:(1-(Math.pow(-2*p+2,2)/2));
    detDisplay.textContent=scramble(ep);
    if(p<1){
      requestAnimationFrame(frame);
    }else{
      detDisplay.textContent=code;
      detHint.textContent='✓ Tap below to copy & shop';
      detHint.classList.add('revealed');
      detDisplay.style.textShadow='0 0 20px rgba(59,130,246,.8),0 0 60px rgba(59,130,246,.4)';
      detDisplay.style.color='#93c5fd';
      detUseBtn.classList.add('show');
      copyCode();
      setTimeout(function(){
        var prev=detDisplay.style.color;
        detDisplay.style.transition='color .15s,text-shadow .15s';
        detDisplay.style.color='#4ade80';
        detDisplay.style.textShadow='0 0 20px rgba(74,222,128,.8),0 0 40px rgba(74,222,128,.4)';
        detDisplay.textContent='✓ COPIED!';
        setTimeout(function(){
          detDisplay.style.color=prev;
          detDisplay.style.textShadow='0 0 20px rgba(59,130,246,.8),0 0 60px rgba(59,130,246,.4)';
          detDisplay.textContent=code;
        },1400);
      },200);
    }
  }
  requestAnimationFrame(frame);
});

detUseBtn.addEventListener('click',function(){
  copyCode();
  if(detonated){
    detDisplay.style.transition='color .15s,text-shadow .15s';
    detDisplay.style.color='#4ade80';
    detDisplay.style.textShadow='0 0 20px rgba(74,222,128,.8),0 0 40px rgba(74,222,128,.4)';
    detDisplay.textContent='✓ COPIED!';
    setTimeout(function(){
      detDisplay.style.color='#93c5fd';
      detDisplay.style.textShadow='0 0 20px rgba(59,130,246,.8),0 0 60px rgba(59,130,246,.4)';
      detDisplay.textContent=code;
    },1400);
  }
});

}());
</script>
</body>
</html>
