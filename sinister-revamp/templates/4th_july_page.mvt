<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>4th of July Sale — Sinister Diesel</title>
<meta name="description" content="Sinister Diesel 4th of July Sale: July 4–7. Save 12% sitewide on Powerstroke, Cummins, and Duramax parts. Use code JULY4SD.">
<meta name="theme-color" content="#000000">
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
html,body{width:100%;height:100%;overflow:hidden;background:#f8f9fb;font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',sans-serif}
canvas#sky{position:fixed;inset:0;z-index:0}
#intro{
  position:fixed;inset:0;z-index:50;
  display:flex;flex-direction:column;align-items:center;justify-content:center;
  background:radial-gradient(ellipse at center,#0a1628 0%,#000 100%);
  transition:opacity 1.2s ease,visibility 1.2s ease;
}
#intro.gone{opacity:0;visibility:hidden;pointer-events:none}
.intro-flag{font-size:clamp(60px,12vw,120px);margin-bottom:24px;animation:wave 3s ease-in-out infinite}
@keyframes wave{0%,100%{transform:rotate(-4deg)}50%{transform:rotate(4deg)}}
.intro-title{
  font-size:clamp(36px,8vw,96px);font-weight:900;letter-spacing:-4px;
  background:linear-gradient(to right,#ef4444,#fff 40%,#3b82f6);
  -webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;
  margin-bottom:16px;text-align:center;line-height:.95;
}
.intro-sub{font-size:clamp(13px,2vw,18px);color:rgba(255,255,255,.5);letter-spacing:4px;text-transform:uppercase;margin-bottom:56px;text-align:center}
.intro-btn{
  background:linear-gradient(135deg,#b91c1c,#dc2626);
  color:#fff;font-size:clamp(16px,2.5vw,22px);font-weight:800;letter-spacing:2px;
  padding:clamp(14px,2vw,20px) clamp(32px,5vw,56px);border-radius:100px;border:none;cursor:pointer;
  box-shadow:0 0 60px rgba(185,28,28,.6),0 0 120px rgba(185,28,28,.3);
  transition:transform .2s,box-shadow .2s;font-family:inherit;text-transform:uppercase;
  animation:glow-btn 2s ease-in-out infinite alternate;
}
@keyframes glow-btn{0%{box-shadow:0 0 40px rgba(185,28,28,.5)}100%{box-shadow:0 0 80px rgba(185,28,28,.9),0 0 30px rgba(255,100,100,.4)}}
.intro-btn:hover{transform:scale(1.04)}
#navbar{
  position:fixed;top:0;left:0;right:0;z-index:200;
  height:64px;display:flex;align-items:center;
  padding:0 clamp(16px,3vw,40px);gap:24px;
  background:rgba(0,0,0,.65);
  backdrop-filter:blur(16px);-webkit-backdrop-filter:blur(16px);
  border-bottom:1px solid rgba(255,255,255,.06);
  opacity:0;pointer-events:none;transform:translateY(-100%);
  transition:opacity .6s ease,transform .6s ease,background .3s ease;
}
#navbar.visible{opacity:1;pointer-events:auto;transform:translateY(0)}
#navbar.solid{background:rgba(0,0,0,.97)}
.nav-logo{flex-shrink:0}
.nav-logo img{height:36px;object-fit:contain;display:block}
.nav-links{display:flex;align-items:center;gap:clamp(16px,2.5vw,32px);flex:1;justify-content:center}
.nav-links a{color:rgba(255,255,255,.7);text-decoration:none;font-size:13px;font-weight:600;letter-spacing:.5px;transition:color .2s;white-space:nowrap}
.nav-links a:hover{color:#fff}
.nav-badge{flex-shrink:0;margin-left:auto;background:linear-gradient(135deg,#b91c1c,#dc2626);color:#fff;font-size:11px;font-weight:800;letter-spacing:1px;padding:7px 16px;border-radius:100px;white-space:nowrap;box-shadow:0 0 20px rgba(239,68,68,.4)}
.nav-hamburger{display:none;flex-direction:column;gap:5px;cursor:pointer;background:none;border:none;padding:6px}
.nav-hamburger span{display:block;width:22px;height:2px;background:#fff;border-radius:2px;transition:all .3s}
@media(max-width:700px){.nav-links{display:none}.nav-hamburger{display:flex}.nav-badge{font-size:10px;padding:6px 12px}}
#mobileMenu{
  position:fixed;top:64px;left:0;right:0;z-index:199;
  background:rgba(0,0,0,.97);border-bottom:1px solid rgba(255,255,255,.08);
  padding:20px 24px;display:flex;flex-direction:column;gap:16px;
  transform:translateY(-100%);transition:transform .3s ease;pointer-events:none;
}
#mobileMenu.open{transform:translateY(0);pointer-events:auto}
#mobileMenu a{color:rgba(255,255,255,.8);text-decoration:none;font-size:15px;font-weight:600;padding:4px 0}
#main{
  position:fixed;inset:0;z-index:10;
  overflow-y:scroll;overflow-x:hidden;
  opacity:0;transition:opacity 1s ease;
  scroll-snap-type:y mandatory;
  scrollbar-width:none;
}
#main::-webkit-scrollbar{display:none}
#main.visible{opacity:1}
.slide{
  width:100%;height:100vh;min-height:100vh;
  position:relative;display:flex;align-items:center;justify-content:center;
  scroll-snap-align:start;overflow:hidden;
  flex-shrink:0;
}
#s1{background:transparent}
.s1-inner{position:relative;z-index:2;text-align:center;padding:80px 24px 0}
.s1-badge{display:inline-flex;align-items:center;gap:10px;background:rgba(255,255,255,.07);border:1px solid rgba(255,255,255,.15);padding:8px 24px;border-radius:100px;font-size:11px;font-weight:800;letter-spacing:3px;text-transform:uppercase;color:rgba(255,255,255,.7);margin-bottom:32px}
.s1-live{width:8px;height:8px;border-radius:50%;background:#ef4444;animation:blink 1s ease-in-out infinite}
@keyframes blink{0%,100%{opacity:1;box-shadow:0 0 0 0 rgba(239,68,68,.7)}50%{opacity:.5;box-shadow:0 0 0 6px rgba(239,68,68,0)}}
.s1-h1{font-size:clamp(52px,10vw,140px);font-weight:900;line-height:.85;letter-spacing:-6px;color:#fff;margin-bottom:24px;text-shadow:0 0 80px rgba(239,68,68,.3),0 0 160px rgba(59,130,246,.2)}
.s1-h1 span.r{color:#ef4444;display:block}
.s1-h1 span.b{color:#93c5fd;display:block}
.s1-dates{font-size:clamp(14px,2.5vw,22px);color:rgba(255,255,255,.45);letter-spacing:6px;text-transform:uppercase;margin-bottom:48px}
.cd-rings{display:flex;gap:clamp(12px,3vw,40px);justify-content:center;margin-bottom:48px}
.cd-ring-wrap{display:flex;flex-direction:column;align-items:center;gap:10px}
.cd-ring{position:relative;width:clamp(70px,10vw,110px);height:clamp(70px,10vw,110px)}
.cd-ring svg{position:absolute;inset:0;width:100%;height:100%;transform:rotate(-90deg)}
.cd-ring-track{fill:none;stroke:rgba(255,255,255,.06);stroke-width:4}
.cd-ring-prog{fill:none;stroke-width:4;stroke-linecap:round;transition:stroke-dashoffset .5s ease}
.cd-ring-d .cd-ring-prog{stroke:#ef4444}
.cd-ring-h .cd-ring-prog{stroke:#fff}
.cd-ring-m .cd-ring-prog{stroke:#3b82f6}
.cd-ring-s .cd-ring-prog{stroke:#f5c518}
.cd-ring-num{position:absolute;inset:0;display:flex;align-items:center;justify-content:center;font-size:clamp(20px,3.5vw,36px);font-weight:900;color:#fff;font-variant-numeric:tabular-nums}
.cd-ring-lbl{font-size:9px;font-weight:700;letter-spacing:2px;text-transform:uppercase;color:rgba(255,255,255,.35)}
.s1-scroll{position:absolute;bottom:32px;left:50%;transform:translateX(-50%);display:flex;flex-direction:column;align-items:center;gap:8px;color:rgba(255,255,255,.3);font-size:10px;letter-spacing:2px;text-transform:uppercase;animation:bob .2s ease-in-out infinite alternate}
@keyframes bob{0%{transform:translateX(-50%) translateY(0)}100%{transform:translateX(-50%) translateY(6px)}}
.s1-scroll-line{width:1px;height:40px;background:linear-gradient(to bottom,rgba(255,255,255,.3),transparent)}
.sec-nosnap{scroll-snap-align:start;min-height:100vh;width:100%;position:relative;flex-shrink:0;overflow-y:visible;overflow-x:hidden;display:flex;flex-direction:column;justify-content:flex-start}
.sec-nosnap>.hl-inner,
.sec-nosnap>.deals-inner,
.sec-nosnap>.cat-inner,
.sec-nosnap>.oem-wrap,
.sec-nosnap>.fav-inner,
.sec-nosnap>.why-inner,
.sec-nosnap>.u250-inner,
.sec-nosnap>.rev-inner{margin-top:auto;margin-bottom:auto}
.xsec{padding:clamp(60px,8vw,100px) clamp(20px,5vw,80px);max-width:1280px;margin:0 auto}
.xsec-eyebrow{font-size:11px;font-weight:800;letter-spacing:3px;text-transform:uppercase;color:#ef4444;margin-bottom:12px}
.xsec-h2{font-size:clamp(28px,5vw,56px);font-weight:900;letter-spacing:-2px;color:#0a1628;line-height:1;margin-bottom:40px}
.xsec-h2 em{font-style:normal;color:#ef4444}
.xsec-split{display:flex;align-items:baseline;justify-content:space-between;gap:16px;flex-wrap:wrap;margin-bottom:40px}
.xsec-split .xsec-h2{margin-bottom:0}
.xsec-link{font-size:13px;font-weight:800;color:#ef4444;text-decoration:none;letter-spacing:.5px;white-space:nowrap;border:1.5px solid rgba(239,68,68,.4);padding:10px 20px;border-radius:100px;transition:background .2s,border-color .2s}
.xsec-link:hover{background:rgba(239,68,68,.1);border-color:#ef4444}
#sec-cat{background:linear-gradient(180deg,#f0f5ff 0%,#fff 40%,#f7f9ff 100%);position:relative;overflow:hidden}
#sec-cat::before{content:'';position:absolute;top:0;left:0;right:0;height:6px;background:linear-gradient(to right,#3b82f6 0%,#3b82f6 33%,#fff 33%,#fff 66%,#ef4444 66%,#ef4444 100%)}
#sec-cat::after{content:'★ ★ ★';position:absolute;top:clamp(60px,8vw,100px);right:clamp(20px,3vw,40px);font-size:clamp(18px,3vw,32px);color:rgba(59,130,246,.12);letter-spacing:8px;pointer-events:none;font-weight:900}
.cat-inner{max-width:1280px;margin:0 auto;padding:clamp(72px,8vh,96px) clamp(20px,5vw,80px) clamp(24px,4vh,48px);position:relative;z-index:1;width:100%}
.cat-eyebrow{font-size:11px;font-weight:800;letter-spacing:3px;text-transform:uppercase;color:#3b82f6;margin-bottom:12px}
.cat-h2{font-size:clamp(24px,4vw,48px);font-weight:900;letter-spacing:-2px;color:#0a1628;line-height:1;margin-bottom:clamp(16px,3vh,28px)}
.cat-h2 em{font-style:normal;color:#ef4444}
.cat-grid{display:grid;grid-template-columns:repeat(6,1fr);gap:clamp(8px,1.2vh,14px)}
@media(max-width:1100px){.cat-grid{grid-template-columns:repeat(4,1fr)}}
@media(max-width:700px){.cat-grid{grid-template-columns:repeat(3,1fr)}}
.cat-card{position:relative;display:flex;flex-direction:column;align-items:center;text-decoration:none;border-radius:16px;overflow:hidden;border:1px solid #dde8f5;background:#fff;box-shadow:0 2px 8px rgba(59,130,246,.06);transition:transform .3s,border-color .3s,box-shadow .3s}
.cat-card:hover{transform:translateY(-4px);border-color:rgba(59,130,246,.4);box-shadow:0 8px 24px rgba(59,130,246,.14)}
.cat-img-wrap{width:100%;aspect-ratio:1;overflow:hidden;position:relative}
.cat-img{width:100%;height:100%;object-fit:cover;display:block;transition:transform .4s;filter:saturate(.8)}
.cat-card:hover .cat-img{transform:scale(1.07);filter:saturate(1)}
.cat-underline{position:absolute;bottom:0;left:0;width:0;height:2px;background:#ef4444;transition:width .3s}
.cat-card:hover .cat-underline{width:100%}
.cat-body{padding:12px 10px 14px;text-align:center;width:100%}
.cat-name{font-size:12px;font-weight:800;color:#0a1628;letter-spacing:.2px}
#sec-highlights{background:#fff;position:relative;overflow:hidden}
#sec-highlights::before{content:'';position:absolute;top:0;left:0;right:0;height:6px;background:linear-gradient(to right,#ef4444 0%,#ef4444 33%,#fff 33%,#fff 66%,#3b82f6 66%,#3b82f6 100%)}
#sec-highlights::after{content:'★';position:absolute;bottom:-20px;right:clamp(20px,5vw,60px);font-size:clamp(120px,18vw,220px);color:rgba(239,68,68,.05);line-height:1;pointer-events:none;font-weight:900}
.hl-inner{max-width:1280px;margin:0 auto;padding:clamp(72px,8vh,96px) clamp(20px,4vw,48px) clamp(24px,4vh,48px);position:relative;z-index:1;width:100%}
.hl-eyebrow{font-size:11px;font-weight:800;letter-spacing:3px;text-transform:uppercase;color:#ef4444;margin-bottom:12px}
.hl-h2{font-size:clamp(24px,4vw,48px);font-weight:900;letter-spacing:-2px;color:#0a1628;line-height:1;margin-bottom:clamp(16px,3vh,32px)}
.hl-h2 em{font-style:normal;color:#ef4444}
.hl-grid{display:grid;grid-template-columns:repeat(5,1fr);gap:clamp(10px,1.5vh,16px)}
@media(max-width:1100px){.hl-grid{display:flex;overflow-x:auto;scroll-snap-type:x mandatory;-webkit-overflow-scrolling:touch;scrollbar-width:none;gap:16px;padding-right:40px}}
.hl-grid::-webkit-scrollbar{display:none}
.hl-card{display:flex;flex-direction:column;text-decoration:none;border-radius:16px;overflow:hidden;background:#fff;border:1px solid #e8edf5;box-shadow:0 2px 12px rgba(10,22,40,.06);transition:transform .3s,border-color .3s,box-shadow .3s;flex-shrink:0}
@media(max-width:1100px){.hl-card{min-width:260px;scroll-snap-align:start}}
.hl-card:hover{transform:translateY(-5px);border-color:rgba(239,68,68,.35);box-shadow:0 10px 32px rgba(239,68,68,.12)}
.hl-img{width:100%;aspect-ratio:4/3;object-fit:cover;display:block;transition:transform .4s}
.hl-card:hover .hl-img{transform:scale(1.04)}
.hl-body{padding:10px 14px 14px;display:flex;flex-direction:column;flex:1}
.hl-name{font-size:13px;font-weight:700;color:#0a1628;line-height:1.4;margin-bottom:8px;flex:1}
.price-wrap{display:flex;flex-direction:column;gap:1px;margin-bottom:0}
.price-orig{font-size:12px;font-weight:600;text-decoration:line-through;line-height:1.2;color:rgba(150,150,150,.7)}
.hl-price{font-size:22px;font-weight:900;color:#ef4444;margin-bottom:6px}
.hl-ship{font-size:10px;font-weight:800;letter-spacing:1px;color:#4ade80;margin-bottom:12px}
.hl-btn{display:inline-block;font-size:11px;font-weight:800;letter-spacing:1px;text-transform:uppercase;color:#ef4444;border:1.5px solid rgba(239,68,68,.4);padding:8px 14px;border-radius:8px;transition:background .2s;text-decoration:none;text-align:center}
.hl-card:hover .hl-btn{background:rgba(239,68,68,.12)}
#sec-deals{background:linear-gradient(160deg,#1a0000 0%,#2d0505 30%,#1a0505 60%,#0d0000 100%);position:relative;overflow:hidden}
#sec-deals::before{content:'';position:absolute;inset:0;background:radial-gradient(ellipse 100% 80% at 50% 0%,rgba(239,68,68,.18) 0%,transparent 65%),radial-gradient(ellipse 40% 50% at 0% 100%,rgba(185,28,28,.12) 0%,transparent 60%);pointer-events:none}
#sec-deals::after{content:'SALE';position:absolute;bottom:-20px;right:-10px;font-size:clamp(120px,18vw,220px);font-weight:900;color:rgba(239,68,68,.05);letter-spacing:-8px;line-height:1;pointer-events:none}
.deals-inner{max-width:1280px;margin:0 auto;padding:clamp(72px,8vh,96px) clamp(20px,4vw,48px) clamp(24px,4vh,48px);position:relative;z-index:1;width:100%}
.deals-eyebrow{font-size:11px;font-weight:800;letter-spacing:3px;text-transform:uppercase;color:#fca5a5;margin-bottom:12px}
.deals-h2{font-size:clamp(24px,4vw,48px);font-weight:900;letter-spacing:-2px;color:#fff;line-height:1;margin-bottom:clamp(16px,3vh,28px)}
.deals-h2 em{font-style:normal;color:#b91c1c}
.deals-grid{display:grid;grid-template-columns:repeat(6,1fr);gap:14px}
@media(max-width:1200px){.deals-grid{grid-template-columns:repeat(3,1fr)}}
@media(max-width:700px){.deals-grid{grid-template-columns:repeat(2,1fr)}}
.deal-card{position:relative;display:flex;flex-direction:column;text-decoration:none;border-radius:16px;overflow:hidden;background:rgba(255,255,255,.07);border:1px solid rgba(255,255,255,.1);backdrop-filter:blur(8px);transition:transform .3s,border-color .3s,box-shadow .3s}
.deal-card:hover{transform:translateY(-6px);border-color:rgba(239,68,68,.6);box-shadow:0 12px 40px rgba(239,68,68,.25),0 0 0 1px rgba(239,68,68,.25)}
.deal-badge{position:absolute;top:12px;left:12px;z-index:2;background:#ef4444;color:#fff;font-size:10px;font-weight:800;letter-spacing:1.5px;text-transform:uppercase;padding:5px 12px;border-radius:100px}
.deal-carb{position:absolute;top:12px;right:12px;z-index:2;background:rgba(234,88,12,.9);color:#fff;font-size:9px;font-weight:800;letter-spacing:.5px;padding:4px 10px;border-radius:6px}
.deal-img{width:100%;aspect-ratio:1;object-fit:contain;background:#fff;display:block;transition:transform .4s}
.deal-card:hover .deal-img{transform:scale(1.04)}
.deal-body{padding:9px 11px 11px;display:flex;flex-direction:column;flex:1}
.deal-name{font-size:13px;font-weight:700;color:#e2e8f0;line-height:1.35;margin-bottom:7px;flex:1}
.deal-price{font-size:19px;font-weight:900;color:#fff;margin-bottom:4px}
.deal-ship{font-size:10px;font-weight:800;letter-spacing:1px;color:#4ade80;margin-bottom:12px}
.deal-cta{display:block;text-align:center;font-size:9px;font-weight:800;letter-spacing:1px;text-transform:uppercase;color:#ef4444;border:1.5px solid rgba(239,68,68,.4);padding:7px 5px;border-radius:8px;transition:background .2s}
.deal-card:hover .deal-cta{background:rgba(239,68,68,.12)}
#sec-fav{background:linear-gradient(160deg,#f0f7ff 0%,#fff 45%,#f5f0ff 100%);position:relative;overflow:hidden}
#sec-fav::before{content:'★';position:absolute;top:clamp(30px,6vw,80px);left:clamp(10px,3vw,40px);font-size:clamp(80px,12vw,160px);color:rgba(59,130,246,.06);line-height:1;pointer-events:none;font-weight:900}
#sec-fav::after{content:'★';position:absolute;bottom:clamp(20px,4vw,60px);right:clamp(10px,3vw,40px);font-size:clamp(60px,10vw,120px);color:rgba(239,68,68,.05);line-height:1;pointer-events:none;font-weight:900}
.fav-inner{max-width:1280px;margin:0 auto;padding:clamp(72px,8vh,96px) clamp(20px,4vw,48px) clamp(24px,4vh,48px);position:relative;z-index:1;width:100%}
.fav-eyebrow{font-size:11px;font-weight:800;letter-spacing:3px;text-transform:uppercase;color:#3b82f6;margin-bottom:12px}
.fav-h2{font-size:clamp(24px,4vw,48px);font-weight:900;letter-spacing:-2px;color:#0a1628;line-height:1;margin-bottom:clamp(16px,3vh,28px)}
.fav-h2 em{font-style:normal;color:#3b82f6}
.fav-grid{display:grid;grid-template-columns:repeat(6,1fr);gap:14px}
@media(max-width:1200px){.fav-grid{grid-template-columns:repeat(3,1fr)}}
@media(max-width:700px){.fav-grid{grid-template-columns:repeat(2,1fr)}}
.fav-card{display:flex;flex-direction:column;text-decoration:none;border-radius:16px;overflow:hidden;background:#fff;border:1px solid #dde8f8;box-shadow:0 2px 12px rgba(59,130,246,.07);transition:transform .3s,border-color .3s,box-shadow .3s}
.fav-card:hover{transform:translateY(-5px);border-color:rgba(59,130,246,.4);box-shadow:0 10px 32px rgba(59,130,246,.15)}
.fav-img-wrap{position:relative;overflow:hidden}
.fav-img-wrap img{width:100%;aspect-ratio:1;object-fit:contain;padding:8px;display:block;transition:transform .4s}
.fav-card:hover .fav-img-wrap img{transform:scale(1.04)}
.fav-ship-tag{position:absolute;top:10px;left:10px;background:rgba(59,130,246,.9);color:#fff;font-size:9px;font-weight:800;letter-spacing:1px;padding:4px 10px;border-radius:6px}
.fav-body{padding:10px 12px 12px;display:flex;flex-direction:column;flex:1}
.fav-name{font-size:13px;font-weight:700;color:#0a1628;line-height:1.4;margin-bottom:8px;flex:1}
.fav-price{font-size:20px;font-weight:900;color:#0a1628;margin-bottom:10px}
.fav-cta{display:block;text-align:center;font-size:9px;font-weight:800;letter-spacing:1px;text-transform:uppercase;color:#3b82f6;border:1.5px solid rgba(59,130,246,.4);padding:8px 6px;border-radius:8px;transition:background .2s}
.fav-card:hover .fav-cta{background:rgba(59,130,246,.12)}
#sec-oem{background:linear-gradient(160deg,#fffbf0 0%,#fff 50%,#fdfbf5 100%);position:relative;overflow:hidden;padding:clamp(72px,8vh,96px) clamp(20px,5vw,80px) clamp(24px,4vh,48px)}
#sec-oem::before{content:'';position:absolute;left:0;top:0;bottom:0;width:6px;background:linear-gradient(to bottom,#ef4444,#f5c518,#3b82f6)}
#sec-oem::after{content:'⚙';position:absolute;bottom:-20px;right:clamp(20px,4vw,60px);font-size:clamp(140px,20vw,260px);color:rgba(245,197,24,.06);line-height:1;pointer-events:none}
.oem-wrap{max-width:1280px;margin:0 auto;display:grid;grid-template-columns:1fr 1fr;gap:clamp(24px,4vw,52px);align-items:start;position:relative;z-index:1;width:100%}
@media(max-width:900px){.oem-wrap{grid-template-columns:1fr}}
.oem-eyebrow{font-size:11px;font-weight:800;letter-spacing:3px;text-transform:uppercase;color:#f5c518;margin-bottom:12px}
.oem-h2{font-size:clamp(24px,4vw,48px);font-weight:900;letter-spacing:-2px;color:#0a1628;line-height:1;margin-bottom:12px}
.oem-h2 em{font-style:normal;color:#ef4444}
.oem-sub{font-size:15px;color:#475569;line-height:1.7;margin-bottom:28px;max-width:420px}
@media(max-width:900px){.oem-sub{max-width:100%}}
.oem-btn{display:inline-flex;align-items:center;gap:8px;background:rgba(59,130,246,.15);color:#60a5fa;border:1.5px solid rgba(59,130,246,.4);font-size:13px;font-weight:800;padding:12px 24px;border-radius:100px;text-decoration:none;transition:background .2s,border-color .2s;letter-spacing:.5px}
.oem-btn:hover{background:rgba(59,130,246,.25);border-color:#3b82f6}
.oem-grid{display:grid;grid-template-columns:1fr 1fr;gap:clamp(10px,1.5vh,14px)}
@media(max-width:480px){.oem-grid{grid-template-columns:1fr}}
.oem-card{display:block;text-decoration:none;border-radius:14px;overflow:hidden;background:#fff;border:1px solid #e8edf5;box-shadow:0 2px 10px rgba(10,22,40,.06);transition:border-color .3s,transform .3s,box-shadow .3s}
.oem-card:hover{border-color:rgba(245,197,24,.6);transform:translateY(-4px);box-shadow:0 10px 28px rgba(245,197,24,.18)}
.oem-card img{width:100%;aspect-ratio:3/2;object-fit:cover;display:block;transition:transform .4s}
.oem-card:hover img{transform:scale(1.04)}
.oem-body{padding:12px 14px 16px}
.oem-name{font-size:12px;font-weight:800;color:#0a1628;margin-bottom:6px}
.oem-problem{display:flex;align-items:flex-start;gap:8px;font-size:11px;color:#dc2626;margin-bottom:6px;line-height:1.4}
.oem-problem span:first-child{font-weight:900;flex-shrink:0}
.oem-solution{display:flex;align-items:flex-start;gap:8px;font-size:11px;color:#16a34a;font-weight:700;line-height:1.4;margin-bottom:6px}
.oem-solution span:first-child{flex-shrink:0}
.oem-price{font-size:16px;font-weight:900;color:#0a1628}
#sec-u250{background:linear-gradient(150deg,#0c0800 0%,#1a1000 35%,#120d00 65%,#080600 100%);position:relative;overflow:hidden}
#sec-u250::before{content:'';position:absolute;inset:0;background:radial-gradient(ellipse 70% 60% at 100% 0%,rgba(245,197,24,.1) 0%,transparent 65%),radial-gradient(ellipse 50% 40% at 0% 100%,rgba(180,83,9,.1) 0%,transparent 60%);pointer-events:none}
#sec-u250::after{content:'$';position:absolute;top:-30px;right:-10px;font-size:clamp(150px,22vw,280px);font-weight:900;color:rgba(245,197,24,.04);line-height:1;pointer-events:none}
.u250-inner{max-width:1280px;margin:0 auto;padding:clamp(72px,8vh,96px) clamp(20px,4vw,48px) clamp(24px,4vh,48px);position:relative;z-index:1;width:100%}
.u250-eyebrow{font-size:11px;font-weight:800;letter-spacing:3px;text-transform:uppercase;color:#fcd34d;margin-bottom:12px}
.u250-h2{font-size:clamp(24px,4vw,48px);font-weight:900;letter-spacing:-2px;color:#fff;line-height:1;margin-bottom:clamp(16px,3vh,28px)}
.u250-h2 em{font-style:normal;color:#f5c518}
.u250-grid{display:grid;grid-template-columns:repeat(6,1fr);gap:14px}
@media(max-width:1200px){.u250-grid{grid-template-columns:repeat(3,1fr)}}
@media(max-width:700px){.u250-grid{grid-template-columns:repeat(2,1fr)}}
.u250-card{display:flex;flex-direction:column;text-decoration:none;border-radius:14px;overflow:hidden;background:rgba(255,255,255,.06);border:1px solid rgba(245,197,24,.15);backdrop-filter:blur(6px);transition:transform .3s,border-color .3s,box-shadow .3s}
.u250-card:hover{transform:translateY(-5px);border-color:rgba(245,197,24,.5);box-shadow:0 10px 32px rgba(245,197,24,.15)}
.u250-img{width:100%;aspect-ratio:1;object-fit:contain;background:#fff;display:block;transition:transform .4s}
.u250-card:hover .u250-img{transform:scale(1.04)}
.u250-body{padding:9px 11px 11px;display:flex;flex-direction:column;flex:1}
.u250-name{font-size:13px;font-weight:700;color:#e2e8f0;line-height:1.35;margin-bottom:7px;flex:1}
.u250-note{font-size:10px;font-weight:700;color:#fcd34d;margin-bottom:4px}
.u250-price{font-size:19px;font-weight:900;color:#fff;margin-bottom:6px}
.u250-cta{display:block;text-align:center;font-size:9px;font-weight:800;letter-spacing:1px;text-transform:uppercase;color:#fff;border:1.5px solid rgba(255,255,255,.3);padding:7px 5px;border-radius:8px;transition:background .2s,border-color .2s;margin-top:auto}
.u250-card:hover .u250-cta{background:rgba(255,255,255,.1);border-color:rgba(255,255,255,.6)}
#s2{background:linear-gradient(135deg,#030812 0%,#0a1628 50%,#030812 100%)}
.detonator{position:relative;z-index:2;display:flex;flex-direction:column;align-items:center;text-align:center;padding:0 clamp(20px,4vw,60px)}
.det-title{font-size:clamp(28px,5vw,64px);font-weight:900;letter-spacing:-3px;color:#fff;margin-bottom:12px}
.det-sub{font-size:clamp(13px,1.8vw,17px);color:rgba(255,255,255,.4);margin-bottom:60px}
.det-box{background:linear-gradient(180deg,#1a1a1a,#111);border:2px solid rgba(255,255,255,.1);border-radius:24px;padding:40px;box-shadow:0 40px 80px rgba(0,0,0,.8),inset 0 1px 0 rgba(255,255,255,.05);width:clamp(280px,50vw,440px)}
.det-box-label{font-size:9px;font-weight:800;letter-spacing:3px;text-transform:uppercase;color:rgba(255,255,255,.2);margin-bottom:20px}
.det-display{background:#000;border:2px solid #333;border-radius:10px;padding:20px;margin-bottom:28px;font-size:clamp(28px,5vw,48px);font-weight:900;letter-spacing:10px;color:#ef4444;font-family:'Courier New',monospace;text-shadow:0 0 20px rgba(239,68,68,.8),0 0 40px rgba(239,68,68,.4);text-align:center;min-height:80px;display:flex;align-items:center;justify-content:center;position:relative;overflow:hidden}
.det-display::before{content:'';position:absolute;inset:0;background:repeating-linear-gradient(0deg,rgba(0,0,0,.12) 0px,rgba(0,0,0,.12) 1px,transparent 1px,transparent 3px);pointer-events:none}
.det-display-text{position:relative;z-index:1;transition:opacity .1s}
.det-wire-wrap{display:flex;align-items:center;gap:16px;margin-bottom:28px}
.det-wire{flex:1;height:6px;border-radius:3px;position:relative;overflow:hidden}
.det-wire-r{background:linear-gradient(to right,#7f1d1d,#ef4444)}
.det-wire-b{background:linear-gradient(to right,#1e3a8a,#3b82f6)}
.det-wire-pulse{position:absolute;top:0;left:-100%;width:100%;height:100%;background:linear-gradient(to right,transparent,rgba(255,255,255,.6),transparent);animation:wire-pulse 2s ease-in-out infinite}
@keyframes wire-pulse{0%{left:-100%}100%{left:100%}}
.det-cap{width:28px;height:28px;border-radius:50%;border:3px solid rgba(255,255,255,.2);display:flex;align-items:center;justify-content:center;font-size:12px}
.det-btn-wrap{position:relative;display:inline-flex;align-items:center;justify-content:center}
.det-btn-shadow{width:120px;height:30px;border-radius:50%;background:rgba(185,28,28,.4);filter:blur(12px);position:absolute;bottom:-10px;z-index:0}
.det-btn{position:relative;z-index:1;width:120px;height:120px;border-radius:50%;background:radial-gradient(circle at 35% 35%,#ef4444,#7f1d1d);border:4px solid #450a0a;cursor:pointer;font-family:inherit;box-shadow:0 8px 0 #450a0a,0 12px 40px rgba(185,28,28,.5),inset 0 2px 0 rgba(255,255,255,.2);transition:transform .1s,box-shadow .1s;display:flex;align-items:center;justify-content:center;font-size:11px;font-weight:800;letter-spacing:2px;text-transform:uppercase;color:rgba(255,255,255,.8);text-shadow:0 1px 2px rgba(0,0,0,.5)}
.det-btn:hover{box-shadow:0 8px 0 #450a0a,0 20px 60px rgba(239,68,68,.7),inset 0 2px 0 rgba(255,255,255,.2)}
.det-btn:active{transform:translateY(6px);box-shadow:0 2px 0 #450a0a,0 4px 20px rgba(185,28,28,.4),inset 0 2px 0 rgba(255,255,255,.1)}
.det-btn.detonated{animation:det-shake .4s ease-in-out}
@keyframes det-shake{0%,100%{transform:rotate(0)}25%{transform:rotate(-5deg) scale(1.05)}75%{transform:rotate(5deg) scale(1.05)}}
.det-copy-hint{margin-top:24px;font-size:11px;color:rgba(255,255,255,.25);letter-spacing:1px}
.det-copy-hint.revealed{color:rgba(255,255,255,.6)}
.det-use-btn{display:none;margin-top:20px;background:linear-gradient(135deg,#b91c1c,#dc2626);color:#fff;font-size:14px;font-weight:800;letter-spacing:1px;padding:14px 36px;border-radius:10px;border:none;cursor:pointer;font-family:inherit;text-decoration:none;box-shadow:0 4px 20px rgba(185,28,28,.4);transition:transform .2s,box-shadow .2s}
.det-use-btn:hover{transform:translateY(-2px);box-shadow:0 10px 32px rgba(185,28,28,.5)}
.det-use-btn.show{display:inline-flex;align-items:center;gap:8px}
#s3{background:#030812}
.s3-inner{width:100%;max-width:1200px;padding:clamp(20px,4vh,48px) clamp(20px,4vw,60px)}
.truck-rail{display:grid;grid-template-columns:repeat(3,1fr);gap:20px}
.truck-rail::-webkit-scrollbar{display:none}
.truck-tile{height:clamp(260px,40vh,440px);border-radius:24px;overflow:hidden;position:relative;text-decoration:none;color:inherit;border:1px solid rgba(255,255,255,.06);transition:transform .3s ease,border-color .3s}
@media(max-width:900px){
  .truck-rail{display:flex;overflow-x:auto;scroll-snap-type:x mandatory;-webkit-overflow-scrolling:touch;scrollbar-width:none;gap:14px;padding-bottom:10px}
  .truck-tile{flex:0 0 78vw;max-width:360px;height:clamp(200px,50vw,320px);scroll-snap-align:start}
}
.truck-tile:hover{transform:translateY(-8px);border-color:rgba(239,68,68,.4)}
.truck-tile-img{width:100%;height:100%;object-fit:cover;display:block;transition:transform .5s ease,filter .5s}
.truck-tile:hover .truck-tile-img{transform:scale(1.06);filter:brightness(1.1) saturate(1.1)}
.truck-tile-overlay{position:absolute;inset:0;background:linear-gradient(to top,rgba(0,0,0,.85) 0%,rgba(0,0,0,.2) 50%,transparent 100%)}
.truck-tile-body{position:absolute;bottom:0;left:0;right:0;padding:24px}
.truck-tile-maker{font-size:10px;font-weight:800;letter-spacing:2.5px;text-transform:uppercase;color:#fca5a5;margin-bottom:4px}
.truck-tile-name{font-size:clamp(22px,3vw,32px);font-weight:900;color:#fff;letter-spacing:-1.5px;margin-bottom:4px}
.truck-tile-eng{font-size:11px;color:rgba(255,255,255,.4);font-weight:600;margin-bottom:16px}
.truck-tile-cta{display:inline-flex;align-items:center;gap:6px;font-size:11px;font-weight:800;letter-spacing:1.5px;text-transform:uppercase;color:#ef4444}
.truck-tile-arrow{transition:transform .2s ease}
.truck-tile:hover .truck-tile-arrow{transform:translateX(5px)}
.rail-hint{display:none;font-size:10px;color:rgba(255,255,255,.2);letter-spacing:2px;text-transform:uppercase;margin-top:16px;text-align:right}
@media(max-width:768px){.rail-hint{display:block}}
.slide-eyebrow{font-size:10px;font-weight:800;letter-spacing:4px;text-transform:uppercase;color:rgba(255,255,255,.3);margin-bottom:16px}
.slide-h2{font-size:clamp(32px,5vw,68px);font-weight:900;letter-spacing:-3px;color:#fff;line-height:.95;margin-bottom:clamp(20px,3vh,36px)}
.slide-h2 em{font-style:normal;color:#ef4444}
#s4{background:linear-gradient(135deg,#000 0%,#0a0014 40%,#000 100%)}
.s4-inner{position:relative;z-index:2;text-align:center;padding:0 clamp(20px,4vw,60px)}
.s4-kicker{font-size:clamp(48px,10vw,120px);line-height:1;margin-bottom:8px;display:block;font-family:Apple Color Emoji,Segoe UI Emoji,Noto Color Emoji,sans-serif}
.s4-h2{font-size:clamp(36px,6vw,80px);font-weight:900;letter-spacing:-4px;color:#fff;line-height:.9;margin-bottom:20px}
.s4-h2 em{font-style:normal;color:#ef4444}
.s4-sub{font-size:clamp(13px,2vw,18px);color:rgba(255,255,255,.35);letter-spacing:3px;text-transform:uppercase;margin-bottom:48px}
.s4-actions{display:flex;gap:16px;justify-content:center;flex-wrap:wrap}
.btn{display:inline-flex;align-items:center;gap:8px;font-size:clamp(13px,1.8vw,16px);font-weight:700;padding:clamp(12px,2vw,16px) clamp(24px,3vw,36px);border-radius:100px;text-decoration:none;transition:transform .2s,box-shadow .2s,background .2s;cursor:pointer;border:none;white-space:nowrap;letter-spacing:.5px;font-family:inherit}
.btn-fire{background:linear-gradient(135deg,#b91c1c,#ef4444);color:#fff;box-shadow:0 4px 30px rgba(185,28,28,.5)}
.btn-fire:hover{transform:translateY(-3px) scale(1.02);box-shadow:0 12px 50px rgba(239,68,68,.6);color:#fff}
.btn-ghost{background:rgba(255,255,255,.06);color:#fff;border:1.5px solid rgba(255,255,255,.2)}
.btn-ghost:hover{background:rgba(255,255,255,.12);border-color:rgba(255,255,255,.5);transform:translateY(-2px);color:#fff}
.s4-disclaimer{margin-top:32px;font-size:10px;color:rgba(255,255,255,.18);line-height:1.8;max-width:600px;margin-left:auto;margin-right:auto}
.s4-disclaimer a{color:rgba(255,255,255,.3)}
#sec-rev{background:linear-gradient(160deg,#fffdf0 0%,#fff 50%,#fffbf0 100%);position:relative;overflow:hidden}
#sec-rev::before{content:'★★★★★';position:absolute;top:-10px;left:50%;transform:translateX(-50%);font-size:clamp(100px,18vw,220px);color:rgba(245,197,24,.07);letter-spacing:12px;white-space:nowrap;pointer-events:none;line-height:1}
#sec-rev::after{content:'';position:absolute;bottom:0;left:0;right:0;height:5px;background:linear-gradient(to right,#ef4444 0%,#ef4444 33%,#fff 33%,#fff 66%,#3b82f6 66%,#3b82f6 100%)}
.rev-inner{max-width:1280px;margin:0 auto;padding:clamp(72px,8vh,96px) clamp(20px,5vw,80px) clamp(32px,4vh,56px);position:relative;z-index:1;width:100%}
.rev-eyebrow{font-size:11px;font-weight:800;letter-spacing:3px;text-transform:uppercase;color:#d97706;margin-bottom:12px}
.rev-h2{font-size:clamp(24px,4vw,48px);font-weight:900;letter-spacing:-2px;color:#0a1628;line-height:1;margin-bottom:clamp(14px,2.5vh,24px)}
.rev-h2 em{font-style:normal;color:#d97706}
.rev-agg{display:inline-flex;align-items:center;gap:10px;text-decoration:none;margin-bottom:clamp(16px,2.5vh,28px);background:rgba(245,197,24,.1);border:1px solid rgba(245,197,24,.35);padding:10px 20px;border-radius:100px;transition:background .2s}
.rev-agg:hover{background:rgba(245,197,24,.2)}
.rev-stars-big{color:#d97706;font-size:18px;letter-spacing:1px}
.rev-agg-text{font-size:13px;font-weight:700;color:#0a1628}
.rev-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:clamp(10px,1.5vh,16px)}
@media(max-width:900px){.rev-grid{grid-template-columns:1fr 1fr}}
@media(max-width:560px){.rev-grid{grid-template-columns:1fr}}
.rev-card{background:#fff;border:1px solid #f0e8c8;border-radius:16px;padding:24px;box-shadow:0 2px 12px rgba(217,119,6,.06);transition:border-color .3s,transform .3s,box-shadow .3s}
.rev-card:hover{border-color:rgba(217,119,6,.4);transform:translateY(-4px);box-shadow:0 8px 28px rgba(217,119,6,.12)}
.rev-stars{color:#d97706;font-size:16px;letter-spacing:1px;margin-bottom:14px}
.rev-text{font-size:14px;color:#475569;line-height:1.65;margin-bottom:20px;font-style:italic}
.rev-author{display:flex;align-items:center;gap:12px}
.rev-avatar{width:38px;height:38px;border-radius:50%;background:linear-gradient(135deg,#1d4ed8,#3b82f6);display:flex;align-items:center;justify-content:center;font-size:12px;font-weight:800;color:#fff;flex-shrink:0}
.rev-name{font-size:13px;font-weight:800;color:#0a1628}
#sec-why{background:linear-gradient(160deg,#06091a 0%,#0a1020 50%,#080d1c 100%);position:relative;overflow:hidden}
#sec-why::before{content:'';position:absolute;inset:0;background:radial-gradient(ellipse 80% 50% at 50% 0%,rgba(59,130,246,.08) 0%,transparent 70%),radial-gradient(ellipse 40% 40% at 0% 100%,rgba(239,68,68,.05) 0%,transparent 60%);pointer-events:none}
.why-inner{max-width:1100px;margin:0 auto;padding:clamp(72px,8vh,96px) clamp(20px,5vw,80px) clamp(24px,4vh,48px);position:relative;z-index:1;width:100%;text-align:center}
.why-eyebrow{font-size:11px;font-weight:800;letter-spacing:3px;text-transform:uppercase;color:#f5c518;margin-bottom:16px}
.why-h2{font-size:clamp(28px,4.5vw,60px);font-weight:900;letter-spacing:-2px;color:#fff;line-height:1.05;margin-bottom:clamp(32px,5vh,64px)}
.why-grid{display:grid;grid-template-columns:repeat(5,1fr);gap:clamp(12px,2vw,24px)}
@media(max-width:900px){.why-grid{grid-template-columns:repeat(3,1fr)}}
@media(max-width:560px){.why-grid{grid-template-columns:repeat(2,1fr)}}
.why-card{background:rgba(255,255,255,.04);border:1px solid rgba(255,255,255,.07);border-radius:16px;padding:clamp(20px,3vh,36px) clamp(14px,2vw,24px);display:flex;flex-direction:column;align-items:center;gap:12px;transition:background .3s,border-color .3s,transform .3s}
.why-card:hover{background:rgba(255,255,255,.07);border-color:rgba(255,255,255,.14);transform:translateY(-4px)}
.why-icon{font-size:clamp(32px,4vw,48px);line-height:1}
.why-title{font-size:clamp(13px,1.4vw,16px);font-weight:800;color:#fff;letter-spacing:-.2px;text-align:center}
.why-sub{font-size:clamp(11px,1.1vw,13px);color:rgba(255,255,255,.4);line-height:1.5;text-align:center}
.rev-vehicle{font-size:11px;color:#94a3b8;margin-top:2px}
.nav-dots{position:fixed;right:24px;top:50%;transform:translateY(-50%);display:flex;flex-direction:column;gap:10px;z-index:30}
.nav-dot{width:8px;height:8px;border-radius:50%;background:rgba(255,255,255,.2);cursor:pointer;transition:background .3s,transform .3s;border:2px solid rgba(10,22,40,.25);padding:0;box-shadow:0 0 0 1px rgba(255,255,255,.5),0 1px 4px rgba(0,0,0,.3)}
.nav-dot.active{background:#ef4444;transform:scale(1.4);border-color:#ef4444;box-shadow:0 0 0 1px rgba(239,68,68,.4),0 1px 6px rgba(239,68,68,.5)}
.toast{position:fixed;bottom:32px;left:50%;transform:translateX(-50%) translateY(100px);background:#fff;color:#111;font-size:14px;font-weight:800;padding:14px 28px;border-radius:100px;z-index:999;transition:transform .4s cubic-bezier(.22,1,.36,1),opacity .4s;opacity:0;pointer-events:none;white-space:nowrap;box-shadow:0 8px 40px rgba(0,0,0,.4);letter-spacing:.5px}
.toast.show{transform:translateX(-50%) translateY(0);opacity:1}
.toast .t-code{color:#b91c1c;font-weight:900}
@media(max-width:768px){.nav-dots{display:none}.hl-grid{display:flex;overflow-x:auto;scrollbar-width:none}.hl-card{min-width:260px;scroll-snap-align:start}}

/* ── BALANCED DESKTOP SECTIONS ── */
@media(min-width:601px){
  .sec-nosnap{
    justify-content:center;
    padding-top:64px;
  }
  .sec-nosnap>.hl-inner,
  .sec-nosnap>.deals-inner,
  .sec-nosnap>.cat-inner,
  .sec-nosnap>.fav-inner,
  .sec-nosnap>.why-inner,
  .sec-nosnap>.u250-inner,
  .sec-nosnap>.rev-inner{
    margin:0 auto;
    padding-top:42px;
    padding-bottom:42px;
  }

  .hl-inner,.deals-inner,.cat-inner,.fav-inner,.u250-inner,.rev-inner{max-width:1180px}
  .why-inner{max-width:1040px}
  .hl-h2,.deals-h2,.cat-h2,.fav-h2,.u250-h2,.rev-h2{margin-bottom:24px}

  .hl-grid{max-width:1080px;margin:0 auto}
  .deals-grid,.fav-grid,.u250-grid,.cat-grid{max-width:1080px;margin:0 auto}
  .deal-card,.fav-card,.u250-card,.cat-card{border-radius:13px}

  #sec-oem{
    display:flex;
    align-items:center;
    justify-content:center;
    padding:90px 48px 42px;
  }
  .sec-nosnap>.oem-wrap{
    width:100%;
    max-width:1080px;
    margin:0 auto;
    grid-template-columns:300px minmax(0,1fr);
    gap:52px;
    align-items:center;
  }
  .oem-text{align-self:center}
  .oem-sub{font-size:14px;margin-bottom:22px}
  .oem-grid{
    width:100%;
    max-width:680px;
    justify-self:end;
    gap:10px;
  }
  .oem-card{border-radius:12px}
  .oem-card img{aspect-ratio:2/1}
  .oem-body{padding:9px 10px 10px}
  .oem-name{font-size:10px;line-height:1.3;margin-bottom:5px}
  .oem-problem,.oem-solution{font-size:9px;line-height:1.35}

  #s2{padding-top:64px}
  .detonator{max-width:720px;margin:0 auto}
  .det-title{font-size:clamp(34px,4vw,52px);letter-spacing:-2px;margin-bottom:8px}
  .det-sub{font-size:14px;margin-bottom:26px}
  .det-box{
    width:380px;
    padding:26px 28px 28px;
    border-radius:20px;
  }
  .det-box-label{margin-bottom:14px}
  .det-display{
    min-height:62px;
    padding:12px;
    margin-bottom:20px;
    font-size:32px;
    letter-spacing:6px;
  }
  .det-wire-wrap{margin-bottom:18px}
  .det-btn{width:92px;height:92px;font-size:9px;box-shadow:0 6px 0 #450a0a,0 10px 30px rgba(185,28,28,.45),inset 0 2px 0 rgba(255,255,255,.2)}
  .det-btn-shadow{width:96px;height:24px}
  .det-copy-hint{margin-top:16px}

  .rev-inner{max-width:1120px}
  .rev-grid{gap:14px}
  .rev-card{padding:20px}
  .rev-text{margin-bottom:16px}

  .why-h2{margin-bottom:34px}
  .why-grid{gap:14px}
  .why-card{padding:24px 14px}
}
@media(min-width:601px) and (max-width:900px){
  .sec-nosnap{
    height:auto;
    min-height:100vh;
    overflow-y:visible;
    padding-top:84px;
    padding-bottom:44px;
  }
  .sec-nosnap>.hl-inner,
  .sec-nosnap>.deals-inner,
  .sec-nosnap>.cat-inner,
  .sec-nosnap>.fav-inner,
  .sec-nosnap>.why-inner,
  .sec-nosnap>.u250-inner,
  .sec-nosnap>.rev-inner{
    padding-top:24px;
    padding-bottom:24px;
  }
  .sec-nosnap>.oem-wrap{
    max-width:720px;
    grid-template-columns:1fr;
    gap:24px;
  }
  .oem-grid{
    max-width:640px;
    justify-self:center;
  }
  .oem-card img{aspect-ratio:16/9}
  .oem-text{text-align:center}
  .oem-sub{max-width:620px;margin-left:auto;margin-right:auto}
}

/* ── MOBILE FIXES ── */
@media(max-width:600px){
  /* Hero */
  .s1-inner{padding:72px 16px 0}
  .s1-badge{font-size:9px;letter-spacing:2px;padding:6px 14px;margin-bottom:14px}
  .s1-h1{font-size:clamp(34px,11vw,50px);letter-spacing:-3px;margin-bottom:12px}
  .s1-dates{font-size:11px;letter-spacing:2px;margin-bottom:16px}
  .cd-rings{gap:8px;margin-bottom:16px}
  .cd-ring{width:58px;height:58px}
  .cd-ring-num{font-size:17px}
  .cd-ring-lbl{font-size:8px;letter-spacing:1px}
  .s1-scroll{bottom:12px}

  /* On mobile: release fixed 100vh + snap so sections grow naturally */
  #main{scroll-snap-type:none}
  .sec-nosnap{height:auto;min-height:auto;overflow-y:visible;justify-content:flex-start;scroll-snap-align:none}
  .sec-nosnap>.hl-inner,
  .sec-nosnap>.deals-inner,
  .sec-nosnap>.cat-inner,
  .sec-nosnap>.oem-wrap,
  .sec-nosnap>.fav-inner,
  .sec-nosnap>.why-inner,
  .sec-nosnap>.u250-inner,
  .sec-nosnap>.rev-inner{margin-top:0;margin-bottom:0}
  .slide{height:auto;min-height:100vh;scroll-snap-align:none}

  /* Section inner paddings */
  .hl-inner,.deals-inner,.fav-inner,.u250-inner,.rev-inner{padding:52px 14px 32px}
  .cat-inner{padding:52px 14px 32px}
  .why-inner{padding:52px 14px 32px}
  #sec-oem{padding:52px 14px 32px !important}
  .oem-wrap{gap:18px;padding:0}

  /* Headings */
  .hl-h2,.deals-h2,.fav-h2,.u250-h2,.rev-h2,.why-h2,.oem-h2{font-size:clamp(20px,6.5vw,30px);letter-spacing:-1px;margin-bottom:14px}
  .cat-h2{font-size:clamp(18px,5.5vw,26px);margin-bottom:12px}

  /* Highlights — horizontal scroll, show image + price properly */
  .hl-grid{gap:10px}
  .hl-card{min-width:200px;max-width:240px}
  .hl-img{aspect-ratio:3/2}
  .hl-body{padding:8px 10px 10px}
  .hl-name{font-size:11px;margin-bottom:6px}
  .hl-price{font-size:17px}
  .hl-ship{font-size:9px;margin-bottom:8px}
  .hl-btn{font-size:10px;padding:6px 10px}

  /* Deal cards — single column */
  .deals-grid{grid-template-columns:1fr;gap:8px}
  .deal-img{aspect-ratio:3/1;object-position:center}
  .deal-body{padding:8px 12px 10px}
  .deal-name{font-size:12px;margin-bottom:6px}
  .deal-price{font-size:16px}
  .deal-ship{font-size:9px;margin-bottom:8px}

  /* Fav — 2 col */
  .fav-grid{grid-template-columns:1fr 1fr;gap:8px}
  .fav-body{padding:8px 10px 10px}
  .fav-name{font-size:12px;margin-bottom:6px}
  .fav-price{font-size:16px;margin-bottom:6px}
  .fav-cta{font-size:9px;padding:7px}

  /* U250 — 2 col */
  .u250-grid{grid-template-columns:1fr 1fr;gap:8px}
  .u250-body{padding:8px 10px 10px}
  .u250-name{font-size:12px;margin-bottom:6px}
  .u250-price{font-size:17px;margin-bottom:4px}
  .u250-note{font-size:9px}
  .u250-cta{font-size:9px}

  /* OEM */
  .oem-grid{grid-template-columns:1fr 1fr;gap:8px}
  .oem-name{font-size:10px;word-break:break-word;line-height:1.3}
  .oem-body{padding:8px 10px 10px}
  .oem-problem,.oem-solution{font-size:10px}

  /* Cat grid — 3 col */
  .cat-grid{grid-template-columns:repeat(3,1fr);gap:8px}
  .cat-body{padding:6px 4px 8px}
  .cat-name{font-size:10px}
  .cat-img-wrap{border-radius:8px}

  /* Reviews — 1 col */
  .rev-grid{grid-template-columns:1fr;gap:8px}
  .rev-card{padding:16px}
  .rev-text{font-size:13px;margin-bottom:14px}
  .rev-agg{flex-direction:column;text-align:center;gap:4px;margin-bottom:14px}
  .rev-agg-text{font-size:12px}

  /* Why grid — 2 col */
  .why-grid{grid-template-columns:1fr 1fr;gap:8px}
  .why-card{padding:14px 8px;gap:8px}
  .why-icon{font-size:26px}
  .why-title{font-size:11px}
  .why-sub{font-size:10px}

  /* Detonator — fix display overflow */
  .detonator{padding:0 12px}
  .det-title{font-size:clamp(20px,6vw,36px);letter-spacing:-1px}
  .det-sub{font-size:12px;margin-bottom:24px}
  .det-box{padding:20px 16px;width:100%;max-width:340px}
  .det-box-label{font-size:8px;letter-spacing:2px;margin-bottom:14px}
  .det-display{font-size:clamp(14px,4.5vw,22px);letter-spacing:1px;padding:10px;min-height:52px;overflow:hidden}
  .det-display-text{white-space:nowrap;letter-spacing:inherit;font-size:inherit}
  .det-wire-wrap{gap:8px;margin-bottom:20px}
  .det-btn{width:80px;height:80px;font-size:8px;letter-spacing:1px}
  .det-btn-shadow{width:90px;height:24px}
  .det-copy-hint{font-size:10px;margin-top:16px}

  /* Truck rail */
  #s3{min-height:100vh;display:flex;align-items:center}
  .s3-inner{padding:24px 0 24px 16px;display:flex;flex-direction:column;align-items:flex-start;justify-content:center;width:100%}
  .slide-eyebrow{margin-bottom:8px}
  .slide-h2{font-size:clamp(24px,7vw,36px);letter-spacing:-2px;margin-bottom:14px}
  .truck-tile{height:clamp(180px,48vh,280px)}
  .truck-tile-name{font-size:clamp(18px,5vw,26px)}
  .truck-tile-body{padding:14px}
  .truck-tile-eng{margin-bottom:10px}
  .rail-hint{margin-top:10px;text-align:left}

  /* Final CTA — fix emoji + sub text */
  .s4-kicker{font-size:56px;font-family:Apple Color Emoji,Segoe UI Emoji,sans-serif}
  .s4-h2{font-size:clamp(28px,8vw,44px);letter-spacing:-2px}
  .s4-sub{font-size:11px;letter-spacing:2px;margin-bottom:32px}
  .s4-actions{flex-direction:column;align-items:stretch;gap:12px;padding:0 24px}
  .btn{font-size:14px;padding:14px 20px;justify-content:center}

  /* Price wrap */
  .price-wrap{margin-bottom:2px}
  .price-orig{font-size:11px}

  /* Intro screen — tighter on mobile */
  .intro-flag{font-size:52px;margin-bottom:14px}
  .intro-title{font-size:clamp(28px,9vw,48px);letter-spacing:-2px;margin-bottom:10px}
  .intro-sub{font-size:11px;letter-spacing:2px;margin-bottom:32px}
  .intro-btn{font-size:14px;padding:12px 28px}

  /* Hero — hide scroll indicator, keep visible content */
  .s1-scroll{display:none}
}
@media(max-width:420px){
  #navbar{gap:10px;padding:0 12px}
  .nav-logo img{height:30px}
  .nav-badge{font-size:9px;padding:5px 9px}
  .cat-grid{grid-template-columns:repeat(2,1fr)}
  .oem-grid{grid-template-columns:1fr}
}
</style>
</head>
<body>

<canvas id="sky"></canvas>

<div id="intro">
  <div class="intro-flag">🎆</div>
  <h1 class="intro-title">Sinister<br>July 4th</h1>
  <p class="intro-sub">July 4 &ndash; 7 &nbsp;&middot;&nbsp; 2026</p>
  <button class="intro-btn" id="introBtn">Light the Fuse 🧨</button>
</div>

<nav id="navbar">
  <a href="https://sinisterdiesel.com" class="nav-logo" target="_blank" rel="noopener">
    <img src="https://sinisterdiesel.com/mm5/graphics/00000001/1/logo.png" alt="Sinister Diesel" onerror="this.style.display='none';this.parentNode.innerHTML='<span style=\'color:#fff;font-size:15px;font-weight:900;letter-spacing:-0.5px\'>SINISTER DIESEL</span>'">
  </a>
  <div class="nav-links">
    <a href="#sec-deals" id="navDeals">Deals</a>
    <a href="https://sinisterdiesel.com/shop-by-vehicle.html" target="_blank" rel="noopener">Trucks</a>
    <a href="#s2" id="navGetCode">Get Code</a>
    <a href="https://sinisterdiesel.com/sinister-diesel.html" target="_blank" rel="noopener">Shop All</a>
  </div>
  <div class="nav-badge">JULY4SD &mdash; 12% Off</div>
  <button class="nav-hamburger" id="hamburgerBtn" aria-label="Menu">
    <span></span><span></span><span></span>
  </button>
</nav>

<div id="mobileMenu">
  <a href="#sec-deals" id="mobDeals">Deals</a>
  <a href="https://sinisterdiesel.com/shop-by-vehicle.html" target="_blank" rel="noopener">Trucks</a>
  <a href="#s2" id="mobGetCode">Get Code</a>
  <a href="https://sinisterdiesel.com/sinister-diesel.html" target="_blank" rel="noopener">Shop All</a>
</div>

<nav class="nav-dots" id="navDots" aria-label="Page sections"></nav>

<div id="main">

  <section class="slide" id="s1">
    <div class="s1-inner">
      <div class="s1-badge">
        <span class="s1-live"></span>
        Sale Live &mdash; Ends July 7
      </div>
      <h1 class="s1-h1">
        <span class="r">Fire Sale.</span>
        <span class="b">Diesel Deals.</span>
        12% Off.
      </h1>
      <p class="s1-dates">July 4 &ndash; 7, 2026 &nbsp;&bull;&nbsp; Code: JULY4SD</p>
      <div class="cd-rings" aria-label="Countdown timer">
        <div class="cd-ring-wrap">
          <div class="cd-ring cd-ring-d">
            <svg viewBox="0 0 100 100"><circle class="cd-ring-track" cx="50" cy="50" r="44"/><circle class="cd-ring-prog" id="rD" cx="50" cy="50" r="44" stroke-dasharray="276.46" stroke-dashoffset="276.46"/></svg>
            <div class="cd-ring-num" id="cdDays">00</div>
          </div>
          <div class="cd-ring-lbl">Days</div>
        </div>
        <div class="cd-ring-wrap">
          <div class="cd-ring cd-ring-h">
            <svg viewBox="0 0 100 100"><circle class="cd-ring-track" cx="50" cy="50" r="44"/><circle class="cd-ring-prog" id="rH" cx="50" cy="50" r="44" stroke-dasharray="276.46" stroke-dashoffset="276.46"/></svg>
            <div class="cd-ring-num" id="cdHours">00</div>
          </div>
          <div class="cd-ring-lbl">Hours</div>
        </div>
        <div class="cd-ring-wrap">
          <div class="cd-ring cd-ring-m">
            <svg viewBox="0 0 100 100"><circle class="cd-ring-track" cx="50" cy="50" r="44"/><circle class="cd-ring-prog" id="rM" cx="50" cy="50" r="44" stroke-dasharray="276.46" stroke-dashoffset="276.46"/></svg>
            <div class="cd-ring-num" id="cdMins">00</div>
          </div>
          <div class="cd-ring-lbl">Mins</div>
        </div>
        <div class="cd-ring-wrap">
          <div class="cd-ring cd-ring-s">
            <svg viewBox="0 0 100 100"><circle class="cd-ring-track" cx="50" cy="50" r="44"/><circle class="cd-ring-prog" id="rS" cx="50" cy="50" r="44" stroke-dasharray="276.46" stroke-dashoffset="276.46"/></svg>
            <div class="cd-ring-num" id="cdSecs">00</div>
          </div>
          <div class="cd-ring-lbl">Secs</div>
        </div>
      </div>
      <div class="s1-scroll" aria-hidden="true">
        <div class="s1-scroll-line"></div>
        Scroll
      </div>
    </div>
  </section>

  <section class="sec-nosnap" id="sec-highlights">
    <div class="hl-inner">
      <div class="hl-eyebrow">🔥 July 4th Highlights</div>
      <h2 class="hl-h2">Featured <em>Deals</em></h2>
      <div class="hl-grid">
        <div class="hl-card">
          <img class="hl-img" src="https://sinisterdiesel.com/mm5/graphics/00000001/6/_DSC2377_2_720x480.jpg" alt="Cold Air Intake Cummins 6.7L 2013-2018" loading="lazy">
          <div class="hl-body">
            <div class="hl-name">Sinister Diesel Cold Air Intake for 2013-2018 Dodge/Ram Cummins 6.7L</div>
            <div class="price-wrap"><span class="price-orig">$499.99</span><div class="hl-price">$439.99</div></div>
            <div class="hl-ship">Free Shipping</div>
            <a class="hl-btn" href="https://sinisterdiesel.com/sinister-diesel-cold-air-intake-for-2013-2018-dodgeram-cummins-67l.html" target="_blank" rel="noopener">View Product &rarr;</a>
          </div>
        </div>
        <div class="hl-card">
          <img class="hl-img" src="https://sinisterdiesel.com/mm5/graphics/00000001/product_images/RAW144811573_718x480.jpeg" alt="Cold Air Intake Powerstroke 6.7L 2020-2023" loading="lazy">
          <div class="hl-body">
            <div class="hl-name">Sinister Diesel Cold Air Intake for 2020-2023 Ford Powerstroke 6.7L</div>
            <div class="price-wrap"><span class="price-orig">$589.99</span><div class="hl-price">$519.19</div></div>
            <div class="hl-ship">Free Shipping</div>
            <a class="hl-btn" href="https://sinisterdiesel.com/sinister-diesel-cold-air-intake-for-2020-2021-ford-powerstroke-67l.html" target="_blank" rel="noopener">View Product &rarr;</a>
          </div>
        </div>
        <div class="hl-card">
          <img class="hl-img" src="https://sinisterdiesel.com/mm5/graphics/00000001/8/SD-6.7PEX11-1_720x480.jpg" alt="5 inch DPF-Back Exhaust Powerstroke 6.7L 2017-2023" loading="lazy">
          <div class="hl-body">
            <div class="hl-name">Sinister Diesel 5" DPF-Back Exhaust for 2017-2023 Ford 6.7L</div>
            <div class="price-wrap"><span class="price-orig">$569.99</span><div class="hl-price">$501.59</div></div>
            <div class="hl-ship">&nbsp;</div>
            <a class="hl-btn" href="https://sinisterdiesel.com/sinister-diesel-5-exhaust-filter-back-for-2017-2020-ford-f250350450-67l.html" target="_blank" rel="noopener">View Product &rarr;</a>
          </div>
        </div>
        <div class="hl-card">
          <img class="hl-img" src="https://sinisterdiesel.com/mm5/graphics/00000001/8/SD-FF-6.7P-11_1_720x480.jpg" alt="Fuel Filter Conversion Kit Powerstroke 6.7L" loading="lazy">
          <div class="hl-body">
            <div class="hl-name">Sinister Diesel Fuel Filter Conversion Kit for 2011-2026 Ford Powerstroke 6.7L</div>
            <div class="price-wrap"><span class="price-orig">$298.99</span><div class="hl-price">$263.11</div></div>
            <div class="hl-ship">Free Shipping</div>
            <a class="hl-btn" href="https://sinisterdiesel.com/mm5/merchant.mvc?Screen=PROD&amp;Product_Code=SD-FF-6_7P-11" target="_blank" rel="noopener">View Product &rarr;</a>
          </div>
        </div>
        <div class="hl-card">
          <img class="hl-img" src="https://sinisterdiesel.com/mm5/graphics/00000001/7/_DSC3787_2_720x480.jpg" alt="Hot Side Charge Pipe Powerstroke 6.7L" loading="lazy">
          <div class="hl-body">
            <div class="hl-name">Sinister Diesel Hot Side Charge Pipe for 2011-2026 Ford Powerstroke 6.7L</div>
            <div class="price-wrap"><span class="price-orig">$429.99</span><div class="hl-price">$378.39</div></div>
            <div class="hl-ship">Free Shipping</div>
            <a class="hl-btn" href="https://sinisterdiesel.com/sinister-diesel-hot-side-charge-pipe-for-2011-ford-powerstroke-67l.html" target="_blank" rel="noopener">View Product &rarr;</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="slide" id="s3">
    <div class="s3-inner">
      <div class="slide-eyebrow">Pick Your Rig</div>
      <h2 class="slide-h2">Shop by<br><em>Your Truck</em></h2>
      <div class="truck-rail" id="truckRail">
        <a href="https://sinisterdiesel.com/shop-by-vehicle/ford-powerstroke.html" class="truck-tile" target="_blank" rel="noopener">
          <img class="truck-tile-img" src="https://sinisterdiesel.com/mm5/graphics/00000001/8/Generated%20image%201.png" alt="Ford Powerstroke" loading="lazy">
          <div class="truck-tile-overlay"></div>
          <div class="truck-tile-body">
            <div class="truck-tile-maker">Ford</div>
            <div class="truck-tile-name">Powerstroke</div>
            <div class="truck-tile-eng">6.0L &middot; 6.4L &middot; 6.7L &middot; 7.3L</div>
            <span class="truck-tile-cta">Shop Deals <span class="truck-tile-arrow">&rarr;</span></span>
          </div>
        </a>
        <a href="https://sinisterdiesel.com/shop-by-vehicle/dodge-ram-cummins.html" class="truck-tile" target="_blank" rel="noopener">
          <img class="truck-tile-img" src="https://sinisterdiesel.com/mm5/graphics/00000001/8/Generated%20image%202.png" alt="Dodge Ram Cummins" loading="lazy">
          <div class="truck-tile-overlay"></div>
          <div class="truck-tile-body">
            <div class="truck-tile-maker">Dodge / Ram</div>
            <div class="truck-tile-name">Cummins</div>
            <div class="truck-tile-eng">5.9L &middot; 6.7L</div>
            <span class="truck-tile-cta">Shop Deals <span class="truck-tile-arrow">&rarr;</span></span>
          </div>
        </a>
        <a href="https://sinisterdiesel.com/shop-by-vehicle/gm-duramax.html" class="truck-tile" target="_blank" rel="noopener">
          <img class="truck-tile-img" src="https://sinisterdiesel.com/mm5/graphics/00000001/8/Generated%20image%203.png" alt="GM Duramax" loading="lazy">
          <div class="truck-tile-overlay"></div>
          <div class="truck-tile-body">
            <div class="truck-tile-maker">Chevy / GMC</div>
            <div class="truck-tile-name">Duramax</div>
            <div class="truck-tile-eng">LB7 &middot; LLY &middot; LBZ &middot; LMM &middot; LML &middot; L5P</div>
            <span class="truck-tile-cta">Shop Deals <span class="truck-tile-arrow">&rarr;</span></span>
          </div>
        </a>
      </div>
      <div class="rail-hint">&larr; Swipe to browse &rarr;</div>
    </div>
  </section>

  <section class="sec-nosnap" id="sec-deals">
    <div class="deals-inner">
      <div class="deals-eyebrow">Best Deals of the Event</div>
      <h2 class="deals-h2">Save <em>12%</em></h2>
      <div class="deals-grid">
        <a href="https://sinisterdiesel.com/sinister-diesel-complete-blue-package-for-2017-2019-ford-powerstroke-67l.html" class="deal-card" target="_blank" rel="noopener">
          <div class="deal-badge">Save 12%</div>
          <img class="deal-img" src="https://sinisterdiesel.com/mm5/graphics/00000001/8/6.7%20BLUE%20PACKAGE_720x480.jpg" alt="Complete Blue Package 2017-2019 Powerstroke 6.7L" loading="lazy">
          <div class="deal-body">
            <div class="deal-name">Complete Blue Package for 2017-2019 Ford Powerstroke 6.7L</div>
            <div class="price-wrap"><span class="price-orig">$3,999.99</span><div class="deal-price">$3,519.99</div></div>
            <div class="deal-ship">Free Shipping</div>
            <span class="deal-cta">View Product</span>
          </div>
        </a>
        <a href="https://sinisterdiesel.com/mm5/merchant.mvc?Screen=PROD&amp;Product_Code=sd-cbk-6_0" class="deal-card" target="_blank" rel="noopener">
          <div class="deal-badge">Save 12%</div>
          <img class="deal-img" src="https://sinisterdiesel.com/mm5/graphics/00000001/8/6.0%20BLUE%20PACKAGE_720x480.png" alt="Complete Blue Kit 2003-2007 Powerstroke 6.0L" loading="lazy">
          <div class="deal-body">
            <div class="deal-name">Complete Blue Kit for Ford Powerstroke 2003-2007 6.0L</div>
            <div class="price-wrap"><span class="price-orig">$3,216.99</span><div class="deal-price">$2,831.75</div></div>
            <div class="deal-ship">Free Shipping</div>
            <span class="deal-cta">View Product</span>
          </div>
        </a>
        <a href="https://sinisterdiesel.com/sinister-diesel-complete-blue-kit-for-duramax-66-lml.html" class="deal-card" target="_blank" rel="noopener">
          <div class="deal-badge">Save 12%</div>
