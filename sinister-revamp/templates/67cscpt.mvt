<script>
document.addEventListener('DOMContentLoaded', function () {
	if (window.innerWidth <= 640) {
		var grid = document.querySelector('.sd-why-grid');
		if (grid) {
			var cards = grid.querySelectorAll('.sd-why-card');
			if (cards.length >= 2) {
				var middleIndex = Math.floor(cards.length / 2);
				var middle = cards[middleIndex];
				var offset = middle.offsetLeft - (grid.clientWidth - middle.clientWidth) / 2;
				grid.scrollLeft = Math.max(offset, 0);
			}
			grid.classList.add('sd-why-grid--ready');
		}
	}
});
</script>

