	miva_csv_encode(l.settings:line:additional_04, asciichar(9))			$ g.delimiter $
	miva_csv_encode(l.settings:line:additional_05, asciichar(9))
" />
<mvt:assign name="g.line" value="glosub(g.line, asciichar(13), ' ')" />
<mvt:assign name="g.line" value="glosub(g.line, asciichar(10), ' ')" />
&mvt:global:line;&mvt:eol:crlf;