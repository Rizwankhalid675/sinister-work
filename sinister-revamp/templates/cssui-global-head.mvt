<style>


.t-global-search{
padding-bottom: 0 !important;
}

input.u-bg-primary, button.u-bg-primary{
color:white !important;
}
.t-site-header__masthead .t-primary-link.c-button{
padding:0;
}
.slick-next{
right: 5px;
}
.slick-prev{
left: 20px;
}
.t-featured-categories{
align-items: center;
	margin: auto;
max-width: 1024px;
}
.x-hero .slick-slide img{
width: 100%;
}
.slick-slider .slick-track, .slick-slider .slick-list{
max-height:740px;
height:auto;
}
.u-printable__content .o-layout, .u-printable__content{
padding:16px;
}
.x-product-imagery__thumbnail-list.slick-initialized + .x-product-imagery__showcase {
margin-bottom:10px !important;
}
.slick-slide img {
height:auto;
object-fit: contain;
	margin: auto;

}
.t-featured-categories{
padding-top:2.5rem;
}
.t-featured-categories__heading{
margin-bottom:0.5rem;
}
.x-collapsing-breadcrumbs__group, .x-collapsing-breadcrumbs__list{
padding-top:2rem;
}
.first_two > div {
margin-bottom:10px;
}
footer .c-collapsible-menu__label{
color:white;
}
.x-product-description article{
padding: 0 30px;
}
.u-bg-white [class^="u-icon-"]::before, .u-bg-white [class*=" u-icon-"]::before, .u-bg-white [data-icon]::before {
	color: black;
}
.u-bg-white [class^="u-icon-"]:hover::before, .u-bg-white [class*=" u-icon-"]:hover::before, .u-bg-white [data-icon]:hover::before{
color: white;
}
.x-product-imagery__showcase, .x-product-layout-images__thumbnail-image{
cursor: pointer;
}
.x-product-layout-images__thumbnail-image{
	height:100px;
min-height:100px;
display:flex!important;
justify-content:center;
}
.x-omega-navigation{
top:auto;
}

.x-quantify>*{
margin: 0px 3px !important;
	padding: 5px;
	border: solid 1px #c0c0c0 !important;
}
.x-messages--error, .x-messages--success{
font-size:13px !important;
}

.x-product-list__image.t-lazy-load-image{
animation-name: none;
}
.x-product-list__figure-caption {
padding-top: 0;
}
.x-product-list__picture{

}
.t-site-header__logo img {
	max-width: 185px;
}

.contact-info svg{
margin-right:12px;
}

footer .address{
padding: 0;
}

.left-footer{
margin-left: auto;
	justify-content: flex-start;
padding-bottom: 10px;
}
.signup_form svg{
	min-width: 60px;
}
footer.t-site-footer .top_footer .contact-info{
padding-bottom: 0;
margin-bottom:0;
}
footer.t-site-footer .top_footer {
	padding: 10px 0 20px 0;
}

#js-PROD .slick-track > div > div, #js-PROD .slick-track, #js-PROD .slick-slide img{
height:100%
}

#js-PROD .slick-vertical .slick-slide, #js-PROD #thumbnails .slick-track > div > div{
height:100px;
min-heihgt:100px;
}
#js-PROD .slick-vertical .slick-slide{
display:contents;
}

@media only screen and (min-width: 60em) {
	.secure-checkout{
	position: absolute;
	right: 0;
	margin-right: 63px;}
	.t-global-footer-social-links {
	text-align: start;
}
}
.newsletter_form.signup_form{
padding-left: 38px;
}

.x-product-list__image{
height:100%;
object-fit: contain;
}

.t-featured-categories .x-product-list__image{
height: auto;
}

.u-icon-heart-empty:hover::before{
color:lightgray !important;
}

.recommended a{
box-shadow: none !important;
}

.x-product-imagery__thumbnail-list .slick-next::before, .x-product-imagery__thumbnail-list .slick-prev::before{
color:black;
font-family: 'ReadyTheme Icons';
}


@media only screen and (max-width: 60em) {
	.megamenu-shadow {
		box-shadow: none;
	}
	.x-omega-navigation__list {
		background: white;
	}
	.newsletter_form.signup_form{
		justify-content: center;
	padding:12px 0;

	}
	.top_footer>.o-wrapper{
		padding: 0 8px;
	}
	.x-omega-navigation.is-open {
		top: 0 !important;
	}
	.t-filters-trigger>*{
	color:black !important;
	}
	.x-display-list-filtering__sort-by{
	align-self: center;
	border: solid rgba(205, 205, 205, 0.7);
		border-width: 1px 1px 1px 1px;
		padding: 1rem;
	}
}

@media (max-width: 61.9em){
.x-omega-navigation__parents {
	display: none;
}
.megamenu-shadow {
		box-shadow: none;
	}
	.x-omega-navigation__list {
		background: white;
	}
}

@media (max-width: 768px){
footer.t-site-footer .top_footer .newsletter_form {
align-items:center !important;
}
}

@media (max-width: 640px){
.fitment .mm_combination_facet_fields select {
min-width: 100% !important;
margin-bottom:6px;
}
.mm_combination_facet_action_container{
padding:0 !important;
}
}


button[aria-live="polite"] {
background-color: red;
}
.t-related-product-list .slick-slider .slick-track, .t-related-product-list .slick-slider .slick-list{
height:100%!important;
max-height:100%!important;
}
<mvt:comment>MJB, this displays the "close" X for the zinrelo rewards popup</mvt:comment>
#zrl_ld_close_button div{
	display:inline-block;
}

<mvt:comment>
	SD2 Motion System v1 — global 3D/premium motion layer. Additive, pure CSS + vanilla JS
	(no framework/build step; Miva .mvt cannot host React/Framer Motion directly). Provides:
	scroll-reveal (fade+rise), pointer-based 3D card tilt w/ specular highlight, magnetic
	buttons, parallax hero layers, premium spring/expo easing tokens. Respects
	prefers-reduced-motion. Engine: sd2-motion.js (loaded in foot).
</mvt:comment>
:root{
	--sd2-ease-premium: cubic-bezier(0.16, 1, 0.3, 1);
	--sd2-ease-spring: cubic-bezier(0.34, 1.56, 0.64, 1);
	--sd2-ease-soft: cubic-bezier(0.22, 1, 0.36, 1);
	--sd2-dur-fast: 220ms;
	--sd2-dur-med: 480ms;
	--sd2-dur-slow: 900ms;
	--sd2-tilt-max: 14deg;
	--sd2-perspective: 1400px;
}

.sd2-reveal{
	opacity: 0;
	transform: translate3d(0, 48px, 0) scale(0.98);
	transition: opacity var(--sd2-dur-slow) var(--sd2-ease-premium),
				transform var(--sd2-dur-slow) var(--sd2-ease-premium);
	will-change: opacity, transform;
}
.sd2-reveal.is-visible{
	opacity: 1;
	transform: translate3d(0, 0, 0) scale(1);
}
.sd2-reveal--left{ transform: translate3d(-56px, 24px, 0) rotateY(-8deg); }
.sd2-reveal--left.is-visible{ transform: translate3d(0,0,0) rotateY(0deg); }
.sd2-reveal--right{ transform: translate3d(56px, 24px, 0) rotateY(8deg); }
.sd2-reveal--right.is-visible{ transform: translate3d(0,0,0) rotateY(0deg); }
.sd2-reveal--zoom{ transform: scale(0.85); }
.sd2-reveal--zoom.is-visible{ transform: scale(1); }

.sd2-stagger > *{
	opacity: 0;
	transform: translate3d(0, 36px, 0);
	transition: opacity var(--sd2-dur-med) var(--sd2-ease-premium),
				transform var(--sd2-dur-med) var(--sd2-ease-premium);
}
.sd2-stagger.is-visible > *{ opacity: 1; transform: translate3d(0,0,0); }
.sd2-stagger.is-visible > *:nth-child(1){ transition-delay: 0ms; }
.sd2-stagger.is-visible > *:nth-child(2){ transition-delay: 70ms; }
.sd2-stagger.is-visible > *:nth-child(3){ transition-delay: 140ms; }
.sd2-stagger.is-visible > *:nth-child(4){ transition-delay: 210ms; }
.sd2-stagger.is-visible > *:nth-child(5){ transition-delay: 280ms; }
.sd2-stagger.is-visible > *:nth-child(6){ transition-delay: 350ms; }
.sd2-stagger.is-visible > *:nth-child(n+7){ transition-delay: 400ms; }

.sd2-tilt{
	perspective: var(--sd2-perspective);
}
.sd2-tilt-card{
	position: relative;
	transform-style: preserve-3d;
	transition: transform var(--sd2-dur-fast) var(--sd2-ease-soft),
				box-shadow var(--sd2-dur-fast) var(--sd2-ease-soft);
	will-change: transform;
}
.sd2-tilt-card::after{
	content: "";
	position: absolute;
	inset: 0;
	border-radius: inherit;
	background: radial-gradient(circle at var(--sd2-glow-x, 50%) var(--sd2-glow-y, 50%), rgba(255,255,255,0.35), transparent 60%);
	opacity: 0;
	transition: opacity var(--sd2-dur-fast) var(--sd2-ease-soft);
	pointer-events: none;
	mix-blend-mode: overlay;
	z-index: 2;
}
.sd2-tilt-card:hover{
	box-shadow: 0 32px 64px -24px rgba(0,0,0,0.35), 0 12px 24px -12px rgba(0,0,0,0.2);
}
.sd2-tilt-card:hover::after{ opacity: 1; }
.sd2-tilt-card > *{ transform: translateZ(0); }
.sd2-tilt-card__depth{ transform: translateZ(32px); }

.sd2-magnetic{
	display: inline-block;
	transition: transform var(--sd2-dur-fast) var(--sd2-ease-spring);
	will-change: transform;
}

.sd2-parallax{ position: relative; overflow: hidden; }
.sd2-parallax__layer{
	will-change: transform;
	transition: transform 60ms linear;
}

.sd2-float{ animation: sd2FloatY 6s ease-in-out infinite; }
.sd2-float--slow{ animation-duration: 9s; }
.sd2-float--delay{ animation-delay: -3s; }
@keyframes sd2FloatY{
	0%, 100%{ transform: translateY(0) rotate(0deg); }
	50%{ transform: translateY(-14px) rotate(0.6deg); }
}

.sd2-shine{ position: relative; overflow: hidden; }
.sd2-shine::before{
	content: "";
	position: absolute;
	top: 0; left: -150%;
	width: 60%; height: 100%;
	background: linear-gradient(115deg, transparent 0%, rgba(255,255,255,0.55) 50%, transparent 100%);
	transform: skewX(-20deg);
	transition: left 900ms var(--sd2-ease-premium);
	pointer-events: none;
	z-index: 3;
}
.sd2-shine:hover::before{ left: 150%; }

.sd2-scale-in{ transition: transform var(--sd2-dur-fast) var(--sd2-ease-spring); }
.sd2-scale-in:hover{ transform: scale(1.035); }
.sd2-scale-in:active{ transform: scale(0.98); }

@media (prefers-reduced-motion: reduce){
	.sd2-reveal, .sd2-reveal--left, .sd2-reveal--right, .sd2-reveal--zoom,
	.sd2-stagger > *, .sd2-tilt-card, .sd2-magnetic, .sd2-parallax__layer,
	.sd2-float, .sd2-shine::before, .sd2-scale-in{
		transition: none !important;
		animation: none !important;
		transform: none !important;
		opacity: 1 !important;
	}
}
</style>

