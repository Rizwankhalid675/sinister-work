<link rel="icon" type="image/png" href="https://sinisterdiesel.com/mm5/graphics/00000001/8/apple-icon-1_2.png">
<link rel="shortcut icon" href="https://sinisterdiesel.com/mm5/graphics/00000001/8/apple-icon-1_2.png">
<link rel="apple-touch-icon" href="https://sinisterdiesel.com/graphics/00000001/8/apple-icon-1_2.png">
<mvt:item name="customfields" param="Read_Basket( 'state_via_ip', l.settings:state_via_ip )" />
<mvt:if expr="(NOT l.settings:state_via_ip) OR g.Test_Ip_Reset">
	<mvt:if expr="g.Test_Use_Ip">
		<mvt:assign name="l.settings:remote_addr" value="g.Test_Use_Ip" />
	<mvt:else>
		<mvt:assign name="l.settings:remote_addr" value="s.remote_addr" />
	</mvt:if>

	<mvt:assign name="l.settings:api_url" value="'https://pro.ip-api.com/json/' $ l.settings:remote_addr $ '?key=zEwoB0HWbQodmzp'"/>
	<mvt:call ACTION="l.settings:api_url" METHOD="'GET'">
		<mvt:assign name="l.settings:api_response" value="l.settings:api_response $ s.callvalue"/>
	</mvt:call>
	<mvt:assign name="l.decoded" value="Miva_Json_Decode(l.settings:api_response, l.settings:response_array)"/>

	<mvt:item name="customfields" param="Write_Basket( 'state_via_ip', l.settings:response_array:region )" /> 
	<mvt:assign name="l.settings:state_via_ip" value="l.settings:response_array:region" />
</mvt:if>
<mvt:item name="customfields" param="Read_Basket( 'state_via_ip', l.settings:state_via_ip )" />

<mvt:if expr="'CTGY' CIN l.settings:page:code">
	<link rel="canonical" href="&mvte:category:link;" itemprop="url">
<mvt:elseif expr="'PROD' CIN l.settings:page:code OR l.settings:page:code EQ 'PATR'">
	<link rel="canonical" href="&mvt:product:link;" itemprop="url">
<mvt:else>
	<link rel="canonical" href="&mvte:urls:_self:auto;" itemprop="url">
</mvt:if>
<mvt:item name="prodctgy_meta" param="combined" />
<script type="text/javascript" src="&mvt:global:clientside_url;Module_Code=mvga&amp;Filename=mvga.js"></script>

