<!DOCTYPE html>
<html>
<mvt:item name="html_profile" />

<head>
	<meta charset="utf-8">
	<meta name="viewport" content="width=device-width, initial-scale=1">
	<base href="&mvte:global:basehref;">

	<mvt:if expr="NOT ISNULL l.settings:category:page_title">
		<title>&mvt:category:page_title;</title>
	<mvt:elseif expr="NOT ISNULL l.settings:category:name">
		<title>&mvt:category:name; | &mvt:store:name;</title>
	<mvt:elseif expr="NOT ISNULL l.settings:page:title">
		<title>&mvt:page:title;</title>
	<mvt:else>
		<title>&mvt:page:name; | &mvt:store:name;</title>
	</mvt:if>

	<mvt:if expr="g.useDevResources EQ 1">
		<mvt:item name="head" param="css_list_dev" />
	<mvt:else>
		<mvt:item name="head" param="css_list" />
	</mvt:if>

	<mvt:item name="head" param="head_tag" />
</head>

<body>
	<mvt:item name="hdft" param="global_header" />
	<mvt:item name="hdft" param="header" />

	<mvt:comment>
		Parent categories in Miva do not inherit products assigned to their children.
		When a category has no direct products, build a deduplicated rollup from its
		active descendants so customers land on shoppable product results instead of
		a second category-selection screen.
	</mvt:comment>
	<mvt:do name="l.settings:sd2_children_loaded" file="g.Module_Library_DB" value="CategoryList_Load_Parent(l.settings:category:id, l.settings:sd2_subcategories)" />
	<mvt:if expr="l.settings:category_listing:total_prod_count EQ 0 AND miva_array_elements(l.settings:sd2_subcategories) GT 0">
		<mvt:assign name="l.settings:sd2_rollup_categories" value="''" />
		<mvt:assign name="l.settings:sd2_rollup_products" value="''" />

		<mvt:foreach iterator="sd2_child" array="sd2_subcategories">
			<mvt:if expr="l.settings:sd2_child:active">
				<mvt:assign name="l.null" value="miva_array_insert_var(l.settings:sd2_rollup_categories, l.settings:sd2_child, -1)" />
				<mvt:assign name="l.settings:sd2_grandchildren" value="''" />
				<mvt:do name="l.settings:sd2_grandchildren_loaded" file="g.Module_Library_DB" value="CategoryList_Load_Parent(l.settings:sd2_child:id, l.settings:sd2_grandchildren)" />
				<mvt:foreach iterator="sd2_grandchild" array="sd2_grandchildren">
					<mvt:if expr="l.settings:sd2_grandchild:active">
						<mvt:assign name="l.null" value="miva_array_insert_var(l.settings:sd2_rollup_categories, l.settings:sd2_grandchild, -1)" />
						<mvt:assign name="l.settings:sd2_great_grandchildren" value="''" />
						<mvt:do name="l.settings:sd2_great_grandchildren_loaded" file="g.Module_Library_DB" value="CategoryList_Load_Parent(l.settings:sd2_grandchild:id, l.settings:sd2_great_grandchildren)" />
						<mvt:foreach iterator="sd2_great_grandchild" array="sd2_great_grandchildren">
							<mvt:if expr="l.settings:sd2_great_grandchild:active">
								<mvt:assign name="l.null" value="miva_array_insert_var(l.settings:sd2_rollup_categories, l.settings:sd2_great_grandchild, -1)" />
								<mvt:assign name="l.settings:sd2_fourth_level_children" value="''" />
								<mvt:do name="l.settings:sd2_fourth_level_children_loaded" file="g.Module_Library_DB" value="CategoryList_Load_Parent(l.settings:sd2_great_grandchild:id, l.settings:sd2_fourth_level_children)" />
								<mvt:foreach iterator="sd2_fourth_level_child" array="sd2_fourth_level_children">
									<mvt:if expr="l.settings:sd2_fourth_level_child:active">
										<mvt:assign name="l.null" value="miva_array_insert_var(l.settings:sd2_rollup_categories, l.settings:sd2_fourth_level_child, -1)" />
									</mvt:if>
								</mvt:foreach>
							</mvt:if>
						</mvt:foreach>
					</mvt:if>
				</mvt:foreach>
			</mvt:if>
		</mvt:foreach>

		<mvt:foreach iterator="sd2_rollup_category" array="sd2_rollup_categories">
			<mvt:assign name="l.settings:sd2_category_products" value="''" />
			<mvt:do name="l.settings:sd2_category_product_count" file="g.Module_Library_DB" value="Runtime_ProductList_Load_Offset_Category(l.settings:sd2_rollup_category:id, 0, 1000, l.settings:sd2_category_next_offset, l.settings:sd2_category_products)" />
			<mvt:foreach iterator="sd2_rollup_product" array="sd2_category_products">
				<mvt:assign name="l.settings:sd2_rollup_is_duplicate" value="0" />
				<mvt:foreach iterator="sd2_existing_product" array="sd2_rollup_products">
					<mvt:if expr="l.settings:sd2_existing_product:id EQ l.settings:sd2_rollup_product:id">
						<mvt:assign name="l.settings:sd2_rollup_is_duplicate" value="1" />
					</mvt:if>
				</mvt:foreach>
				<mvt:if expr="NOT l.settings:sd2_rollup_is_duplicate">
					<mvt:assign name="l.null" value="miva_array_insert_var(l.settings:sd2_rollup_products, l.settings:sd2_rollup_product, -1)" />
				</mvt:if>
			</mvt:foreach>
		</mvt:foreach>

		<mvt:assign name="l.settings:sd2_rollup_product_count" value="miva_array_elements(l.settings:sd2_rollup_products)" />
		<mvt:if expr="l.settings:sd2_rollup_product_count GT 0">
			<mvt:do name="l.settings:sd2_rollup_prices_ready" file="g.Module_Feature_TUI_UT" value="CommonComponentFields_Initialize_Product_Discounts_Runtime(l.settings:sd2_rollup_products, l.settings:sd2_rollup_product_count)" />
			<mvt:foreach iterator="sd2_rollup_product" array="sd2_rollup_products">
				<mvt:do name="l.settings:sd2_rollup_product:link" file="g.Module_Feature_URI_UT" value="Store_Product_URL(l.settings:sd2_rollup_product, NULL)" />
			</mvt:foreach>
			<mvt:assign name="l.settings:category_listing:products" value="l.settings:sd2_rollup_products" />
			<mvt:assign name="l.settings:category_listing:total_prod_count" value="l.settings:sd2_rollup_product_count" />
			<mvt:assign name="l.settings:category_listing:products_on_page_count" value="l.settings:sd2_rollup_product_count" />
			<mvt:assign name="l.settings:category_listing:page_links:last_page" value="1" />
			<mvt:assign name="l.settings:sd2_descendant_rollup" value="1" />
		</mvt:if>
	</mvt:if>

	<main class="sd2-v2-search-page" data-v2-listing-page>
		<div class="sd2-wrap">

			<header class="sd2-v2-search-page__head">
				<nav class="sd2-v2-breadcrumbs" aria-label="Breadcrumb">
					<a href="&mvte:urls:SFNT:auto;">Home</a>
					<span aria-hidden="true">/</span>
					<span>&mvte:category:name;</span>
				</nav>

				<div class="sd2-v2-search-page__title-row">
					<div>
						<p class="sd2-eyebrow">Product Listing</p>
						<h1 class="sd2-heading-lg">&mvte:category:name;</h1>
					</div>
					<p class="sd2-v2-search-page__count">&mvte:category_listing:total_prod_count; products</p>
				</div>
				<div class="sd2-v3-hero-data" aria-label="Category overview">
					<div><span>Catalog</span><strong>&mvte:category_listing:total_prod_count; live products</strong></div>
					<div><span>Fitment</span><strong>Garage ready</strong></div>
					<div><span>Support</span><strong>US-based team</strong></div>
				</div>
			</header>

			<mvt:if expr="miva_array_elements(l.settings:sd2_subcategories) GT 0 AND l.settings:category_listing:total_prod_count EQ 0">
				<section class="sd2-v3-subcategory-map" data-sd2-story aria-labelledby="sd2-v3-subcategory-title">
					<div class="sd2-v3-subcategory-map__head">
						<div><p class="sd2-kicker">Refine Your Build</p><h2 id="sd2-v3-subcategory-title">Shop &mvte:category:name;</h2></div>
						<p>Choose a system to browse live parts assigned in Miva.</p>
					</div>
					<div class="sd2-v3-subcategory-map__grid sd2-stagger">
						<mvt:foreach iterator="sd2_subcategory" array="sd2_subcategories">
							<mvt:if expr="l.settings:sd2_subcategory:active">
								<mvt:assign name="l.settings:sd2_subcategory_products" value="''" />
								<mvt:assign name="l.settings:sd2_subcategory_children" value="''" />
								<mvt:assign name="l.settings:sd2_subcategory_has_viable_child" value="0" />
								<mvt:do file="g.Module_Library_DB" name="l.settings:sd2_subcategory_product_count" value="Runtime_ProductList_Load_Offset_Category(l.settings:sd2_subcategory:id, 0, 1, l.settings:sd2_subcategory_next_offset, l.settings:sd2_subcategory_products)" />
								<mvt:do file="g.Module_Library_DB" name="l.settings:sd2_subcategory_child_count" value="Runtime_CategoryList_Load_Parent(l.settings:sd2_subcategory:id, l.settings:sd2_subcategory_children)" />
								<mvt:foreach iterator="sd2_grandchild" array="sd2_subcategory_children">
									<mvt:if expr="l.settings:sd2_grandchild:active AND NOT l.settings:sd2_subcategory_has_viable_child">
										<mvt:assign name="l.settings:sd2_grandchild_products" value="''" />
										<mvt:assign name="l.settings:sd2_grandchild_children" value="''" />
										<mvt:assign name="l.settings:sd2_grandchild_has_active_child" value="0" />
										<mvt:do file="g.Module_Library_DB" name="l.settings:sd2_grandchild_product_count" value="Runtime_ProductList_Load_Offset_Category(l.settings:sd2_grandchild:id, 0, 1, l.settings:sd2_grandchild_next_offset, l.settings:sd2_grandchild_products)" />
										<mvt:if expr="l.settings:sd2_grandchild_product_count GT 0">
											<mvt:assign name="l.settings:sd2_subcategory_has_viable_child" value="1" />
										<mvt:else>
											<mvt:do file="g.Module_Library_DB" name="l.settings:sd2_grandchild_child_count" value="Runtime_CategoryList_Load_Parent(l.settings:sd2_grandchild:id, l.settings:sd2_grandchild_children)" />
											<mvt:foreach iterator="sd2_great_grandchild" array="sd2_grandchild_children">
												<mvt:if expr="l.settings:sd2_great_grandchild:active AND NOT l.settings:sd2_subcategory_has_viable_child">
													<mvt:assign name="l.settings:sd2_great_grandchild_products" value="''" />
													<mvt:assign name="l.settings:sd2_great_grandchild_children" value="''" />
													<mvt:assign name="l.settings:sd2_great_grandchild_has_active_child" value="0" />
													<mvt:do file="g.Module_Library_DB" name="l.settings:sd2_great_grandchild_product_count" value="Runtime_ProductList_Load_Offset_Category(l.settings:sd2_great_grandchild:id, 0, 1, l.settings:sd2_great_grandchild_next_offset, l.settings:sd2_great_grandchild_products)" />
													<mvt:if expr="l.settings:sd2_great_grandchild_product_count GT 0">
														<mvt:assign name="l.settings:sd2_subcategory_has_viable_child" value="1" />
													<mvt:else>
														<mvt:do file="g.Module_Library_DB" name="l.settings:sd2_great_grandchild_child_count" value="Runtime_CategoryList_Load_Parent(l.settings:sd2_great_grandchild:id, l.settings:sd2_great_grandchild_children)" />
														<mvt:foreach iterator="sd2_fourth_level_child" array="sd2_great_grandchild_children">
															<mvt:if expr="l.settings:sd2_fourth_level_child:active"><mvt:assign name="l.settings:sd2_subcategory_has_viable_child" value="1" /></mvt:if>
														</mvt:foreach>
													</mvt:if>
												</mvt:if>
											</mvt:foreach>
										</mvt:if>
									</mvt:if>
								</mvt:foreach>
								<mvt:if expr="l.settings:sd2_subcategory_product_count GT 0 OR l.settings:sd2_subcategory_has_viable_child">
									<mvt:assign name="l.settings:sd2_subcategory_uri" value="''" />
									<mvt:assign name="l.settings:sd2_subcategory_link" value="''" />
									<mvt:assign name="l.settings:sd2_subcategory_uri:store_id" value="g.Store:id" />
									<mvt:assign name="l.settings:sd2_subcategory_uri:cat_id" value="l.settings:sd2_subcategory:id" />
									<mvt:do file="g.Module_Feature_URI_DB" name="l.settings:sd2_subcategory_has_uri" value="URI_Load_Item_Canonical(l.settings:sd2_subcategory_uri, l.settings:sd2_subcategory_link)" />
									<mvt:if expr="l.settings:sd2_subcategory_has_uri AND NOT ISNULL l.settings:sd2_subcategory_link:uri">
										<mvt:assign name="l.settings:sd2_subcategory:url" value="l.settings:sd2_subcategory_link:uri" />
									<mvt:else>
										<mvt:do file="g.Module_Feature_URI_UT" name="l.settings:sd2_subcategory:url" value="Store_Category_URL(l.settings:sd2_subcategory, NULL)" />
									</mvt:if>
									<a href="&mvte:sd2_subcategory:url;" class="sd2-v3-subcategory-map__card">
										<span>Category</span><strong>&mvte:sd2_subcategory:name;</strong><i aria-hidden="true">&#8599;</i>
									</a>
								</mvt:if>
							</mvt:if>
						</mvt:foreach>
					</div>
				</section>
			</mvt:if>

			<section class="sd2-v3-commerce-stage" data-sd2-story aria-label="Browse &mvte:category:name;">
			<div class="sd2-v2-result-tools">
				<div class="sd2-v2-chips" data-v2-filter-chips>
					<span class="sd2-v2-chip">&mvte:category:name;</span>
				</div>
				<mvt:if expr="l.settings:facets:facet_count GT 0 AND NOT l.settings:sd2_descendant_rollup">
					<button class="sd2-v2-filter-trigger" type="button" data-v2-filter-open aria-expanded="false">
						<span>Filter Parts</span><strong>&mvte:facets:facet_count;</strong>
					</button>
				</mvt:if>
			</div>

			<mvt:if expr="l.settings:facets:facet_count GT 0 AND NOT l.settings:sd2_descendant_rollup">
				<mvt:assign name="l.settings:sd2_ctgy_layout_class" value="'sd2-v2-search-page__layout sd2-v2-search-page__layout--has-filters'" />
			<mvt:else>
				<mvt:assign name="l.settings:sd2_ctgy_layout_class" value="'sd2-v2-search-page__layout sd2-v2-search-page__layout--no-filters'" />
			</mvt:if>
			<section class="&mvte:sd2_ctgy_layout_class;" aria-label="Category products">
				<mvt:if expr="l.settings:facets:facet_count GT 0 AND NOT l.settings:sd2_descendant_rollup">
					<div class="sd2-v2-filter-sheet-scrim" data-v2-filter-close hidden></div>
					<aside class="sd2-v2-filter-rail sd2-v2-filter-sheet" data-v2-filter-sheet aria-hidden="true" aria-label="Product filters">
						<div class="sd2-v2-filter-sheet__head"><div><span>Catalog Control</span><strong>Filter Parts</strong></div><button type="button" data-v2-filter-close aria-label="Close filters">&times;</button></div>
						<div class="sd2-v2-filter-sheet__body"><mvt:item name="facets" /></div>
						<div class="sd2-v2-filter-sheet__foot"><button class="sd2-btn sd2-btn--primary sd2-btn--full" type="button" data-v2-filter-close>View Products</button></div>
					</aside>
				</mvt:if>

				<mvt:item name="category_listing" />
			</section>
			</section>
		</div>
	</main>

	<mvt:item name="hdft" param="footer" />
	<mvt:item name="hdft" param="global_footer" />
</body>
</html>
