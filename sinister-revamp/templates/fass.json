                    "img": {
                        "image": "graphics/00000001/7/fuel-polishing-how-it-works.png"
                    },
                    "size": {
                        "value": "auto"
                    }
                },
                "layout": {
                    "content_width": {
                        "value": 50
                    },
                    "image_position": {
