        "mmx_texteditor": {
            "component_code": "mmx-text-editor",
            "item_code": "mmx_texteditor",
            "settings": {
                "advanced": {
                    "spacing": {
                        "bottom": {
                            "value": 0
                        },
                        "top": {
                            "value": 0
                        }
                    }
                },
                "content": {
                    "value": "<div style=\"font-family: Arial, sans-serif; font-size: 16px; color: #333; line-height: 1.6; margin: 20px 0;\">\r\n    <h2 style=\"font-size: 20px; color: #444; border-bottom: 2px solid #007BFF; padding-bottom: 5px;\">Benefits of a FASS Titanium Fuel System</h2>\r\n    <ul style=\"list-style-type: disc; padding-left: 20px; margin-top: 10px;\">\r\n        <li><strong>Improved Fuel Filtration:</strong> Removes water, air, and contaminants from diesel fuel, enhancing combustion and reducing engine wear.</li>\r\n        <li><strong>Enhanced Injector Performance:</strong> Protects injectors from clogging and failure by supplying clean, air-free fuel.</li>\r\n        <li><strong>Increased Engine Efficiency:</strong> Optimizes fuel atomization for better fuel economy and lower emissions.</li>\r\n        <li><strong>Protection Against Fuel Starvation:</strong> Ensures a steady fuel supply even under heavy towing or hauling conditions.</li>\r\n        <li><strong>Boosted Power and Performance:</strong> Enables the engine to deliver more power and torque with consistent fuel flow.</li>\r\n        <li><strong>Reduced Maintenance Costs:</strong> Extends the lifespan of engine components by protecting them from damage.</li>\r\n    </ul>\r\n\r\n    <h2 style=\"font-size: 20px; color: #444; border-bottom: 2px solid #007BFF; padding-bottom: 5px; margin-top: 20px;\">Why It\u2019s a Must-Have for Diesel Trucks</h2>\r\n    <p style=\"margin-top: 10px;\">\r\n        Diesel trucks often face demanding conditions, making fuel quality critical. The FASS Titanium Fuel System optimizes performance, reliability, and longevity, \r\n        ensuring your truck performs at its peak. It's a smart investment for any owner looking to protect their vehicle while maximizing power, efficiency, \r\n        and durability. <br><br><center>Select your engine below and start shopping!</center>\r\n    </p>\r\n</div>"
                }
            }
        },
