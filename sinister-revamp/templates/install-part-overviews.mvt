<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>Part Overviews — Sinister Diesel</title>
<meta name="description" content="Learn what our parts do, how they improve your truck, and which upgrades are right for your build.">
<meta name="theme-color" content="#0a1628">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Barlow+Condensed:wght@600;700;900&family=Barlow:wght@400;500;600;700&display=swap" rel="stylesheet">
<style>
:root{
  --navy:#0a1628;
  --navy-deep:#050b16;
  --blue:#3b82f6;
  --blue-bright:#60a5fa;
  --paper:#f7f9fc;
  --ink:#171d29;
  --muted:#5b6472;
  --line:#e2e8f5;
  --dur:220ms;
  --ease:cubic-bezier(.22,.9,.3,1);
}
@media(prefers-reduced-motion:reduce){
  *,*::before,*::after{animation-duration:.001ms!important;animation-iteration-count:1!important;transition-duration:.001ms!important;scroll-behavior:auto!important}
}
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
html{scroll-behavior:smooth}
html,body{width:100%;font-family:'Barlow',-apple-system,BlinkMacSystemFont,'Segoe UI',sans-serif;background:var(--paper);color:var(--ink)}
h1,h2,h3{font-family:'Barlow Condensed','Barlow',sans-serif}
::selection{background:var(--blue);color:var(--navy-deep)}
a{color:inherit}

#navbar{
  position:fixed;top:0;left:0;right:0;z-index:200;
  height:64px;display:flex;align-items:center;
  padding:0 clamp(16px,3vw,40px);gap:24px;
  background:rgba(5,11,22,.92);
  backdrop-filter:blur(16px);-webkit-backdrop-filter:blur(16px);
  border-bottom:2px solid var(--blue);
}
.nav-logo{flex-shrink:0}
.nav-logo img{height:36px;object-fit:contain;display:block}
.nav-links{display:flex;align-items:center;gap:clamp(16px,2.5vw,32px);flex:1;justify-content:center}
.nav-links a{position:relative;color:rgba(255,255,255,.65);text-decoration:none;font-size:13px;font-weight:600;letter-spacing:.5px;transition:color var(--dur) var(--ease);white-space:nowrap}
.nav-links a::after{content:'';position:absolute;left:0;right:100%;bottom:-6px;height:2px;background:var(--blue);transition:right var(--dur) var(--ease)}
.nav-links a:hover{color:#fff}
.nav-links a:hover::after{right:0}
.nav-badge{
  flex-shrink:0;margin-left:auto;position:relative;overflow:hidden;text-decoration:none;
  background:#fff;color:var(--navy-deep);font-size:11px;font-weight:800;letter-spacing:1px;
  padding:7px 16px;clip-path:polygon(8px 0,100% 0,calc(100% - 8px) 100%,0 100%);white-space:nowrap;
}
.nav-hamburger{display:none;flex-direction:column;gap:5px;cursor:pointer;background:none;border:none;padding:6px}
.nav-hamburger span{display:block;width:22px;height:2px;background:#fff;border-radius:2px;transition:transform var(--dur) var(--ease),opacity var(--dur) var(--ease)}
@media(max-width:700px){.nav-links{display:none}.nav-hamburger{display:flex}.nav-badge{font-size:10px;padding:6px 12px}}
#mobileMenu{
  position:fixed;top:64px;left:0;right:0;z-index:199;
  background:rgba(5,11,22,.98);border-bottom:2px solid var(--blue);
  padding:20px 24px;display:flex;flex-direction:column;gap:16px;
  transform:translateY(-110%);transition:transform var(--dur) var(--ease);pointer-events:none;
}
#mobileMenu.open{transform:translateY(0);pointer-events:auto}
#mobileMenu a{color:rgba(255,255,255,.8);text-decoration:none;font-size:15px;font-weight:600;padding:4px 0}

#page-head{background:#eef2f9;padding:calc(64px + clamp(32px,6vh,48px)) clamp(20px,5vw,40px) clamp(28px,4vh,40px);text-align:center}
.page-h1{font-size:clamp(26px,4vw,44px);font-weight:900;letter-spacing:-.5px;text-transform:uppercase;color:var(--navy);margin-bottom:10px}
.page-sub{font-size:14px;color:var(--muted);max-width:640px;margin:0 auto}

.cat-block{max-width:1180px;margin:0 auto;padding:clamp(40px,6vh,56px) clamp(20px,5vw,40px);border-bottom:1px solid var(--line)}
.cat-block:last-of-type{border-bottom:none}
.cat-name{font-size:clamp(20px,3vw,28px);font-weight:800;letter-spacing:-.3px;text-transform:uppercase;color:var(--blue);margin-bottom:4px}
.cat-desc{font-size:13px;color:var(--muted);margin-bottom:20px}

.vid-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:14px;margin-bottom:24px}
@media(max-width:900px){.vid-grid{grid-template-columns:1fr 1fr}}
.vid-tile{
  aspect-ratio:16/10;background:#fff;border:1px solid var(--line);
  display:flex;align-items:center;justify-content:center;text-decoration:none;overflow:hidden;
  transition:transform var(--dur) var(--ease),border-color var(--dur) var(--ease);
}
.vid-tile:hover{transform:translateY(-3px);border-color:var(--blue)}
.vid-tile-label{font-size:11px;font-weight:700;letter-spacing:1px;text-transform:uppercase;color:#a9b6c8}

.cta-row{display:grid;grid-template-columns:1fr 1fr;gap:14px}
@media(max-width:560px){.cta-row{grid-template-columns:1fr}}
.cta{
  display:block;text-align:center;text-decoration:none;padding:16px;
  background:linear-gradient(135deg,#1d4ed8,var(--blue));color:#fff;
  transition:transform var(--dur) var(--ease),box-shadow var(--dur) var(--ease);
}
.cta:hover{transform:translateY(-2px);box-shadow:0 10px 24px rgba(59,130,246,.3)}
.cta-title{font-size:14px;font-weight:800;letter-spacing:.2px;margin-bottom:2px}
.cta-sub{font-size:12px;color:rgba(255,255,255,.8)}
</style>
</head>
<body>

<nav id="navbar">
  <a href="https://sinisterdiesel.com" class="nav-logo" target="_blank" rel="noopener">
    <img src="https://sinisterdiesel.com/mm5/graphics/00000001/1/logo.png" alt="Sinister Diesel" onerror="this.style.display='none';this.parentNode.innerHTML='<span style=\'color:#fff;font-size:15px;font-weight:900;letter-spacing:-0.5px\'>SINISTER DIESEL</span>'">
  </a>
  <div class="nav-links">
    <a href="https://sinisterdiesel.com/shop-by-vehicle.html" target="_blank" rel="noopener">Shop by Vehicle</a>
    <a href="https://sinisterdiesel.com/sinister-diesel.html" target="_blank" rel="noopener">Shop All</a>
  </div>
  <a class="nav-badge" href="https://sinisterdiesel.com/install-hub.html">Install Guides</a>
  <button class="nav-hamburger" id="hamburgerBtn" aria-label="Menu">
    <span></span><span></span><span></span>
  </button>
</nav>

<div id="mobileMenu">
  <a href="https://sinisterdiesel.com/install-hub.html">Install Guides Home</a>
  <a href="https://sinisterdiesel.com/install-tutorials-overview.html">All Tutorials</a>
  <a href="https://sinisterdiesel.com/shop-by-vehicle.html" target="_blank" rel="noopener">Shop by Vehicle</a>
</div>

<header id="page-head">
  <h1 class="page-h1">Part Overviews</h1>
  <p class="page-sub">Learn what our parts do, how they improve your truck, and which upgrades are right for your build.</p>
</header>

<div id="charge-pipes" class="cat-block">
  <div class="cat-name">Charge Pipes</div>
  <p class="cat-desc">Cold-side and hot-side charge pipe upgrades — reduced restriction, no boost leaks, built to last.</p>
  <div class="vid-grid">
    <div class="vid-tile"><div class="vid-tile-label">Video</div></div>
    <div class="vid-tile"><div class="vid-tile-label">Video</div></div>
    <div class="vid-tile"><div class="vid-tile-label">Video</div></div>
    <div class="vid-tile"><div class="vid-tile-label">Video</div></div>
    <div class="vid-tile"><div class="vid-tile-label">Video</div></div>
    <div class="vid-tile"><div class="vid-tile-label">Video</div></div>
    <div class="vid-tile"><div class="vid-tile-label">Video</div></div>
    <div class="vid-tile"><div class="vid-tile-label">Video</div></div>
  </div>
  <div class="cta-row">
    <a class="cta" href="https://sinisterdiesel.com/intercoolers-pipes.html" target="_blank" rel="noopener"><div class="cta-title">Ready to Upgrade?</div><div class="cta-sub">Shop now &rarr;</div></a>
    <a class="cta" href="https://sinisterdiesel.com/install-tutorials-overview.html"><div class="cta-title">Ready to Install?</div><div class="cta-sub">Learn how &rarr;</div></a>
  </div>
</div>

<div id="filtration" class="cat-block">
  <div class="cat-name">Filtration Kits</div>
  <p class="cat-desc">Coolant and fuel filtration systems that catch casting debris before it reaches your engine.</p>
  <div class="vid-grid">
    <div class="vid-tile"><div class="vid-tile-label">Video</div></div>
    <div class="vid-tile"><div class="vid-tile-label">Video</div></div>
    <div class="vid-tile"><div class="vid-tile-label">Video</div></div>
    <div class="vid-tile"><div class="vid-tile-label">Video</div></div>
    <div class="vid-tile"><div class="vid-tile-label">Video</div></div>
    <div class="vid-tile"><div class="vid-tile-label">Video</div></div>
    <div class="vid-tile"><div class="vid-tile-label">Video</div></div>
    <div class="vid-tile"><div class="vid-tile-label">Video</div></div>
  </div>
  <div class="cta-row">
    <a class="cta" href="https://sinisterdiesel.com/view-all-filtration-kits.html" target="_blank" rel="noopener"><div class="cta-title">Ready to Upgrade?</div><div class="cta-sub">Shop now &rarr;</div></a>
    <a class="cta" href="https://sinisterdiesel.com/install-tutorials-overview.html"><div class="cta-title">Ready to Install?</div><div class="cta-sub">Learn how &rarr;</div></a>
  </div>
</div>

<div id="cold-air-intakes" class="cat-block">
  <div class="cat-name">Cold Air Intakes</div>
  <p class="cat-desc">Increased airflow, better filtration, and a cleaner engine bay install.</p>
  <div class="vid-grid">
    <div class="vid-tile"><div class="vid-tile-label">Video</div></div>
    <div class="vid-tile"><div class="vid-tile-label">Video</div></div>
    <div class="vid-tile"><div class="vid-tile-label">Video</div></div>
    <div class="vid-tile"><div class="vid-tile-label">Video</div></div>
    <div class="vid-tile"><div class="vid-tile-label">Video</div></div>
    <div class="vid-tile"><div class="vid-tile-label">Video</div></div>
    <div class="vid-tile"><div class="vid-tile-label">Video</div></div>
    <div class="vid-tile"><div class="vid-tile-label">Video</div></div>
  </div>
  <div class="cta-row">
    <a class="cta" href="https://sinisterdiesel.com/diesel-air-intakes-parts-for-powerstroke-cummins-superduty-engines.html" target="_blank" rel="noopener"><div class="cta-title">Ready to Upgrade?</div><div class="cta-sub">Shop now &rarr;</div></a>
    <a class="cta" href="https://sinisterdiesel.com/install-tutorials-overview.html"><div class="cta-title">Ready to Install?</div><div class="cta-sub">Learn how &rarr;</div></a>
  </div>
</div>

<div class="cat-block">
  <div class="cat-name">The Rest of the Misc Videos</div>
  <p class="cat-desc">Everything else — exhaust, engine parts, exterior, and more.</p>
  <div class="vid-grid">
    <div class="vid-tile"><div class="vid-tile-label">Video</div></div>
    <div class="vid-tile"><div class="vid-tile-label">Video</div></div>
    <div class="vid-tile"><div class="vid-tile-label">Video</div></div>
    <div class="vid-tile"><div class="vid-tile-label">Video</div></div>
  </div>
</div>

<script>
(function(){
'use strict';
var hamburgerBtn=document.getElementById('hamburgerBtn');
var mobileMenu=document.getElementById('mobileMenu');
hamburgerBtn.addEventListener('click',function(){
  mobileMenu.classList.toggle('open');
});
}());
</script>
</body>
</html>
