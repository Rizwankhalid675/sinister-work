<div class="sd2-v2-hdr-root sd2-v3-shell" data-sd2-global-shell>

	<div class="sd2-v2-hdr-trust">
		<div class="sd2-v2-hdr-trust__inner">
			<span class="sd2-v2-hdr-trust__plate">MADE &amp; TESTED IN THE USA &middot; SINCE 2009</span>
			<span class="sd2-v2-hdr-trust__links">
				<a href="/help-center.html">Help Center</a>
				<a href="&mvte:urls:ORDH:auto;">Track Order</a>
			</span>
		</div>
	</div>

	<mvt:item name="readytheme" param="banner( 'header_message' )" />

	<header class="sd2-v2-hdr sd2-v3-floating-nav" data-hook="site-header" data-v2-sticky-header>
		<div class="sd2-v2-hdr__row">

			<button class="sd2-v2-hdr__mobile-toggle" type="button" data-v2-drawer-open aria-label="Open menu" aria-expanded="false">
				<svg class="sd2-icon sd2-icon--lg" viewBox="0 0 24 24" aria-hidden="true"><path d="M4 7h16M4 12h16M4 17h16"/></svg>
			</button>

			<a class="sd2-v2-hdr__logo" href="&mvte:urls:SFNT:auto;" title="&mvt:global:store:name;" rel="nofollow">
				<mvt:if expr="l.settings:readytheme:logo_type EQ 'text'">
					<span class="sd2-v2-hdr__logo-text">&mvt:readytheme:logo_name;<small class="sd2-v2-hdr__logo-tag">&mvt:readytheme:logo_tagline;</small></span>
				<mvt:elseif expr="l.settings:readytheme:logo_type EQ 'image' AND NOT ISNULL l.settings:readytheme:logo_image">
					<img src="&mvte:readytheme:logo_image;" alt="&mvt:readytheme:logo_alt;">
				<mvt:else>
					<span class="sd2-v2-hdr__logo-text">Sinister Diesel<small class="sd2-v2-hdr__logo-tag">Diesel Performance</small></span>
				</mvt:if>
			</a>

			<button class="sd2-v2-hdr__garage" type="button" data-v2-garage-toggle aria-haspopup="true" aria-expanded="false">
				<svg class="sd2-icon sd2-v2-hdr__garage-icon" viewBox="0 0 24 24" aria-hidden="true"><path d="M3 12l1.5-5A2 2 0 0 1 6.4 5.5h11.2A2 2 0 0 1 19.5 7L21 12"/><path d="M3 12h18v5a1 1 0 0 1-1 1h-1a1 1 0 0 1-1-1v-1H6v1a1 1 0 0 1-1 1H4a1 1 0 0 1-1-1v-5Z"/><circle cx="7" cy="16" r="1"/><circle cx="17" cy="16" r="1"/></svg>
				<span class="sd2-v2-hdr__garage-text">
					<span class="sd2-v2-hdr__garage-label">My Truck</span>
					<span class="sd2-v2-hdr__garage-value is-empty" data-v2-garage-label>Add Your Truck</span>
				</span>
			</button>

			<div class="sd2-v2-hdr__search">
				<button class="sd2-v2-hdr__search-btn" type="button" data-v2-search-open aria-haspopup="true" aria-expanded="false">
					<svg class="sd2-icon" viewBox="0 0 24 24" aria-hidden="true"><circle cx="11" cy="11" r="7"/><path d="m20 20-3.6-3.6"/></svg>
					Search parts, part numbers, or your truck
				</button>
			</div>

			<div class="sd2-v2-hdr__util">
				<a class="sd2-v2-hdr__util-item sd2-v2-hdr__account-link" href="&mvte:urls:ACLN:auto;" aria-label="Account">
					<svg class="sd2-icon sd2-icon--lg" viewBox="0 0 24 24" aria-hidden="true">
						<circle cx="12" cy="8" r="4"/>
						<path d="M4 20a8 8 0 0 1 16 0"/>
					</svg>

				</a>
				<button class="sd2-v2-hdr__util-item t-site-header__basket-link" data-hook="open-mini-basket" data-v2-cart-open type="button" aria-label="Cart">
					<svg class="sd2-icon sd2-icon--lg" viewBox="0 0 24 24" aria-hidden="true"><path d="M4 6h16l-1.5 11a2 2 0 0 1-2 1.7H7.5a2 2 0 0 1-2-1.7L4 6Z"/><path d="M9 6V5a3 3 0 0 1 6 0v1"/></svg>
					<span class="sd2-v2-hdr__cart-badge t-site-header__basket-link-quantity t-prevent-events" data-hook="mini-basket-count">&mvte:global_minibasket:basket_count;</span>
				</button>
			</div>
		</div>

		<nav class="sd2-v2-hdr-nav" aria-label="Primary">
			<div class="sd2-v2-hdr-nav__row" data-v2-menu-root>
				<div class="sd2-v2-hdr-nav__item">
					<a class="sd2-v2-hdr-nav__link" href="&mvte:sd2_mega_powerstroke:url;" data-v2-menu-trigger="1" aria-haspopup="true" aria-expanded="false">
						Powerstroke
						<svg class="sd2-icon sd2-icon--sm" viewBox="0 0 24 24" aria-hidden="true"><path d="m6 9 6 6 6-6"/></svg>
					</a>
				</div>
				<div class="sd2-v2-hdr-nav__item">
					<a class="sd2-v2-hdr-nav__link" href="&mvte:sd2_mega_duramax:url;" data-v2-menu-trigger="2" aria-haspopup="true" aria-expanded="false">
						Duramax
						<svg class="sd2-icon sd2-icon--sm" viewBox="0 0 24 24" aria-hidden="true"><path d="m6 9 6 6 6-6"/></svg>
					</a>
				</div>
				<div class="sd2-v2-hdr-nav__item">
					<a class="sd2-v2-hdr-nav__link" href="&mvte:sd2_mega_cummins:url;" data-v2-menu-trigger="3" aria-haspopup="true" aria-expanded="false">
						Cummins
						<svg class="sd2-icon sd2-icon--sm" viewBox="0 0 24 24" aria-hidden="true"><path d="m6 9 6 6 6-6"/></svg>
					</a>
				</div>
				<div class="sd2-v2-hdr-nav__item">
					<a class="sd2-v2-hdr-nav__link" href="&mvte:sd2_mega_apparel:url;" data-v2-menu-trigger="4" aria-haspopup="true" aria-expanded="false">
						Apparel
						<svg class="sd2-icon sd2-icon--sm" viewBox="0 0 24 24" aria-hidden="true"><path d="m6 9 6 6 6-6"/></svg>
					</a>
				</div>
				<span class="sd2-v2-hdr-nav__spacer"></span>
				<a class="sd2-v2-hdr-nav__pill" href="/help-center.html">
					<svg class="sd2-icon sd2-icon--sm" viewBox="0 0 24 24" aria-hidden="true"><circle cx="12" cy="12" r="9"/><path d="M9.1 9a3 3 0 0 1 5.8 1c0 2-3 2.5-3 3"/><path d="M12 17h.01"/></svg>
					Help Center
				</a>
				<div data-v2-mega-mount></div>
			</div>
		</nav>
	</header>

