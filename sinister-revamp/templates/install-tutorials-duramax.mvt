
<mvt:item name="html_profile" />
<head><meta charset="utf-8"><meta name="viewport" content="width=device-width, initial-scale=1"><base href="&mvte:global:basehref;"><title>Duramax Installation Guides | Sinister Diesel</title><meta name="description" content="Duramax installation guidance for LB7, LLY, LBZ, LMM, LML and L5P GM diesel trucks. Identify your engine, verify fitment and prepare for the job."><mvt:if expr="g.useDevResources EQ 1"><mvt:item name="head" param="css_list_dev" /><mvt:else><mvt:item name="head" param="css_list" /></mvt:if><mvt:item name="head" param="head_tag" /><link rel="stylesheet" href="/mm5/css/00000001/b37/sd2-global.css?T=20260715v45"></head>
<body class="single-column sd2-install-library-page"><mvt:comment>
	Header Experience V2. Mega-menu category links are resolved from verified
	category records so each submenu entry points to its own canonical URL.
</mvt:comment>

