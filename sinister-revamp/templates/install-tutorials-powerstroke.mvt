<script>
(function(){
'use strict';
var hamburgerBtn=document.getElementById('hamburgerBtn');
var mobileMenu=document.getElementById('mobileMenu');
hamburgerBtn.addEventListener('click',function(){
  mobileMenu.classList.toggle('open');
});

function loadVideo(wrap){
  var ytId=wrap.getAttribute('data-yt');
  if(!ytId||wrap.classList.contains('playing'))return;
  var iframe=document.createElement('iframe');
  iframe.src='https://www.youtube.com/embed/'+ytId+'?si=K2W-F4STkTzrGvqg&autoplay=1';
  iframe.title='YouTube video player';
  iframe.setAttribute('frameborder','0');
  iframe.setAttribute('allow','accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share');
  iframe.setAttribute('referrerpolicy','strict-origin-when-cross-origin');
  iframe.setAttribute('allowfullscreen','');
  wrap.appendChild(iframe);
  wrap.classList.add('playing');
}
document.querySelectorAll('.vid-tile[data-yt]').forEach(function(wrap){
  wrap.addEventListener('click',function(){loadVideo(wrap);});
  wrap.addEventListener('keydown',function(e){
    if(e.key==='Enter'||e.key===' '){e.preventDefault();loadVideo(wrap);}
  });
});
}());
</script>
</body>
</html>
