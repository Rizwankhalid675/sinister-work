      <div class="vid-tile"><div class="vid-tile-label">Video</div></div>
    </div>
    <div class="why-h3">Why Upgrade?</div>
    <p class="why-sub">See how Sinister Diesel parts solve common problems and improve performance.</p>
    <div class="prod-grid">
      <div class="prod-tile"><div class="prod-tile-label">Video</div></div>
      <div class="prod-tile"><div class="prod-tile-label">Video</div></div>
