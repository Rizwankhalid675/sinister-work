<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>Powerstroke Tutorials — Sinister Diesel</title>
<meta name="description" content="Step-by-step videos to help you install your Sinister Diesel parts with confidence. Powerstroke 6.7L, 6.4L, 6.0L, 7.3L.">
<meta name="theme-color" content="#0a1628">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Barlow+Condensed:wght@600;700;900&family=Barlow:wght@400;500;600;700&display=swap" rel="stylesheet">
<style>
:root{
  --navy:#0a1628;
  --navy-deep:#050b16;
  --blue:#3b82f6;
  --blue-bright:#60a5fa;
  --paper:#f7f9fc;
  --ink:#171d29;
  --muted:#5b6472;
  --line:#e2e8f5;
  --dur:220ms;
  --ease:cubic-bezier(.22,.9,.3,1);
}
@media(prefers-reduced-motion:reduce){
  *,*::before,*::after{animation-duration:.001ms!important;animation-iteration-count:1!important;transition-duration:.001ms!important;scroll-behavior:auto!important}
}
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
html{scroll-behavior:smooth}
html,body{width:100%;font-family:'Barlow',-apple-system,BlinkMacSystemFont,'Segoe UI',sans-serif;background:var(--paper);color:var(--ink)}
h1,h2,h3{font-family:'Barlow Condensed','Barlow',sans-serif}
::selection{background:var(--blue);color:var(--navy-deep)}
a{color:inherit}

/* ── NAV ── */
#navbar{
  position:fixed;top:0;left:0;right:0;z-index:200;
  height:64px;display:flex;align-items:center;
  padding:0 clamp(16px,3vw,40px);gap:24px;
  background:rgba(5,11,22,.92);
  backdrop-filter:blur(16px);-webkit-backdrop-filter:blur(16px);
  border-bottom:2px solid var(--blue);
}
.nav-logo{flex-shrink:0}
.nav-logo img{height:36px;object-fit:contain;display:block}
.nav-links{display:flex;align-items:center;gap:clamp(16px,2.5vw,32px);flex:1;justify-content:center}
.nav-links a{position:relative;color:rgba(255,255,255,.65);text-decoration:none;font-size:13px;font-weight:600;letter-spacing:.5px;transition:color var(--dur) var(--ease);white-space:nowrap}
.nav-links a::after{content:'';position:absolute;left:0;right:100%;bottom:-6px;height:2px;background:var(--blue);transition:right var(--dur) var(--ease)}
.nav-links a:hover{color:#fff}
.nav-links a:hover::after{right:0}
.nav-badge{
  flex-shrink:0;margin-left:auto;position:relative;overflow:hidden;text-decoration:none;
  background:#fff;color:var(--navy-deep);font-size:11px;font-weight:800;letter-spacing:1px;
  padding:7px 16px;clip-path:polygon(8px 0,100% 0,calc(100% - 8px) 100%,0 100%);white-space:nowrap;
}
.nav-hamburger{display:none;flex-direction:column;gap:5px;cursor:pointer;background:none;border:none;padding:6px}
.nav-hamburger span{display:block;width:22px;height:2px;background:#fff;border-radius:2px;transition:transform var(--dur) var(--ease),opacity var(--dur) var(--ease)}
@media(max-width:700px){.nav-links{display:none}.nav-hamburger{display:flex}.nav-badge{font-size:10px;padding:6px 12px}}
#mobileMenu{
  position:fixed;top:64px;left:0;right:0;z-index:199;
  background:rgba(5,11,22,.98);border-bottom:2px solid var(--blue);
  padding:20px 24px;display:flex;flex-direction:column;gap:16px;
  transform:translateY(-110%);transition:transform var(--dur) var(--ease);pointer-events:none;
}
#mobileMenu.open{transform:translateY(0);pointer-events:auto}
#mobileMenu a{color:rgba(255,255,255,.8);text-decoration:none;font-size:15px;font-weight:600;padding:4px 0}

/* ── PAGE HEADER + QUICK NAV ── */
#page-head{background:#eef2f9;padding:calc(64px + clamp(28px,5vh,40px)) clamp(20px,5vw,40px) 0;text-align:center}
.page-h1{font-size:clamp(26px,4vw,44px);font-weight:900;letter-spacing:-.5px;text-transform:uppercase;color:var(--navy);margin-bottom:10px}
.page-sub{font-size:14px;color:var(--muted);max-width:640px;margin:0 auto 24px}
.quick-nav{display:flex;justify-content:center;gap:0;flex-wrap:wrap;border-top:1px solid var(--line)}
.quick-nav a{
  padding:14px 20px;font-size:13px;font-weight:800;letter-spacing:.5px;text-transform:uppercase;
  color:var(--blue);text-decoration:none;border-right:1px solid var(--line);transition:background var(--dur) var(--ease);
}
.quick-nav a:last-child{border-right:none}
.quick-nav a:hover{background:#fff}

/* ── ENGINE BLOCK ── */
.eng-block{padding:0}
.eng-header{
  background:var(--navy-deep);color:#fff;
  padding:clamp(28px,4vh,40px) clamp(20px,5vw,40px);
  display:flex;justify-content:space-between;align-items:flex-start;gap:24px;flex-wrap:wrap;
  scroll-margin-top:180px;
}
.eng-header-copy{max-width:640px}
.eng-name{font-size:clamp(22px,3.2vw,32px);font-weight:900;letter-spacing:-.5px;text-transform:uppercase;margin-bottom:8px}
.eng-fit{font-size:12px;color:rgba(255,255,255,.5);line-height:1.6}
.eng-media{
  flex-shrink:0;width:min(220px,100%);aspect-ratio:16/10;
  background:repeating-linear-gradient(-45deg,rgba(255,255,255,.05) 0 14px,transparent 14px 28px),radial-gradient(ellipse at 30% 20%,#16305a 0%,var(--navy-deep) 70%);
  display:flex;align-items:center;justify-content:center;color:rgba(255,255,255,.3);font-size:10px;font-weight:700;letter-spacing:1.5px;text-transform:uppercase;text-align:center;padding:12px;
}

.eng-body{max-width:1180px;margin:0 auto;padding:clamp(32px,5vh,48px) clamp(20px,5vw,40px)}
.eng-section-label{font-size:11px;font-weight:800;letter-spacing:2px;text-transform:uppercase;color:var(--blue);margin-bottom:14px}

.vid-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:14px;margin-bottom:clamp(32px,5vh,48px)}
@media(max-width:900px){.vid-grid{grid-template-columns:1fr 1fr}}
.vid-tile{
  aspect-ratio:16/10;background:#fff;border:1px solid var(--line);
  display:flex;align-items:center;justify-content:center;text-decoration:none;overflow:hidden;position:relative;
  transition:transform var(--dur) var(--ease),border-color var(--dur) var(--ease);
}
.vid-tile:hover{transform:translateY(-3px);border-color:var(--blue)}
.vid-tile-label{font-size:11px;font-weight:700;letter-spacing:1px;text-transform:uppercase;color:#a9b6c8}

/* real video tile */
.vid-tile.real{background:#000;border:none}
.vid-thumb{position:absolute;inset:0;background:linear-gradient(160deg,rgba(5,11,22,.35) 0%,rgba(5,11,22,.8) 100%),radial-gradient(ellipse at 30% 30%,#1c3a63 0%,var(--navy-deep) 65%);display:flex;align-items:center;justify-content:center}
.play-dot{width:40px;height:40px;border-radius:50%;background:rgba(255,255,255,.14);border:1.5px solid rgba(255,255,255,.45);display:flex;align-items:center;justify-content:center;transition:transform var(--dur) var(--ease),background var(--dur) var(--ease)}
.play-dot svg{width:14px;height:14px;fill:#fff;margin-left:2px}
.vid-tile.real:hover .play-dot{transform:scale(1.1);background:var(--blue)}
.vid-tile-cap{position:absolute;left:8px;bottom:6px;color:#fff;font-size:10px;font-weight:700;letter-spacing:.4px;text-transform:uppercase}
.vid-tile.real iframe{position:absolute;inset:0;width:100%;height:100%;border:0}
.vid-tile.real.playing .vid-thumb{display:none}

.why-h3{font-size:20px;font-weight:800;text-transform:uppercase;letter-spacing:.2px;color:var(--navy);margin-bottom:4px}
.why-sub{font-size:13px;color:var(--muted);margin-bottom:18px}
.prod-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:14px}
@media(max-width:900px){.prod-grid{grid-template-columns:1fr 1fr}}
.prod-tile{aspect-ratio:1;background:#f0f3f9;border:1px dashed #c7d3e6;display:flex;align-items:center;justify-content:center}
.prod-tile-label{font-size:10px;font-weight:700;letter-spacing:1px;text-transform:uppercase;color:#9aa8bc}
</style>
</head>
<body>

<nav id="navbar">
  <a href="https://sinisterdiesel.com" class="nav-logo" target="_blank" rel="noopener">
    <img src="https://sinisterdiesel.com/mm5/graphics/00000001/1/logo.png" alt="Sinister Diesel" onerror="this.style.display='none';this.parentNode.innerHTML='<span style=\'color:#fff;font-size:15px;font-weight:900;letter-spacing:-0.5px\'>SINISTER DIESEL</span>'">
  </a>
  <div class="nav-links">
    <a href="https://sinisterdiesel.com/shop-by-vehicle.html" target="_blank" rel="noopener">Shop by Vehicle</a>
    <a href="https://sinisterdiesel.com/sinister-diesel.html" target="_blank" rel="noopener">Shop All</a>
  </div>
  <a class="nav-badge" href="https://sinisterdiesel.com/install-hub.html">Install Guides</a>
  <button class="nav-hamburger" id="hamburgerBtn" aria-label="Menu">
    <span></span><span></span><span></span>
  </button>
</nav>

<div id="mobileMenu">
  <a href="https://sinisterdiesel.com/install-hub.html">Install Guides Home</a>
  <a href="https://sinisterdiesel.com/install-tutorials-overview.html">All Tutorials</a>
