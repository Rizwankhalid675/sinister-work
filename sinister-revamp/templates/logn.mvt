<!DOCTYPE html>
<html>
<mvt:item name="html_profile" />
<head>
	<meta charset="utf-8">
	<meta http-equiv="X-UA-Compatible" content="IE=edge">
	<meta name="viewport" content="width=device-width, initial-scale=1">
	<base href="&mvt:global:basehref;">
	<mvt:if expr="NOT ISNULL l.settings:page:title">
		<title>&mvt:page:title;</title>
	<mvt:else>
		<title>&mvt:store:name;: &mvt:page:name;</title>
	</mvt:if>
	<mvt:if expr="g.useDevResources EQ 1"><mvt:item name="head" param="css_list_dev" /><mvt:else><mvt:item name="head" param="css_list" /></mvt:if>
	<mvt:item name="head" param="head_tag" />
</head>
<body id="js-&mvte:page:code;" class="o-site-wrapper t-page-&mvt:global:pageClass;">
	<mvt:item name="hdft" param="global_header" />
	<mvt:item name="hdft" param="header" />

	<main class="sd2-v2-auth" data-v2-auth>
		<mvt:item name="readytheme" param="contentsection( 'messages' )" />
		<div class="sd2-v2-auth__grid">
			<aside class="sd2-v3-auth-story" aria-label="Sinister Diesel account benefits" data-sd2-story>
				<p class="sd2-eyebrow">Your Build, Remembered</p>
				<h1>One account.<br>Your whole garage.</h1>
				<p>Keep your truck context, account details, and order access connected across the Sinister Diesel storefront.</p>
				<div class="sd2-v3-auth-story__data">
					<div><span>01</span><strong>Garage context</strong></div>
					<div><span>02</span><strong>Order access</strong></div>
					<div><span>03</span><strong>Faster checkout</strong></div>
				</div>
			</aside>
			<section class="sd2-v2-auth__panel">
				<header class="sd2-v2-account-hero">
					<p class="sd2-kicker">Account</p>
					<h1>Welcome Back</h1>
				</header>
				<mvt:if expr="g.Customer_Temporary_Password">
					<mvt:assign name="l.settings:url" value="l.settings:urls:CPWD:secure" />
				<mvt:elseif expr="g.Order">
					<mvt:assign name="l.settings:url" value="l.settings:urls:OINF:secure" />
				<mvt:else>
					<mvt:assign name="l.settings:url" value="l.settings:urls:ACLN:secure" />
				</mvt:if>
				<form method="post" action="&mvte:url;">
					<fieldset>
						<legend>&mvt:page:name;</legend>
						<input type="hidden" name="Action" value="LOGN" />
						<label class="sd2-label &mvt:global:invalid_credentials;" for="l-Customer_LoginEmail">Email Address</label>
						<input id="l-Customer_LoginEmail" class="sd2-field" type="email" name="Customer_LoginEmail" value="&mvte:global:Customer_LoginEmail;" autocomplete="email" required>
						<label class="sd2-label &mvt:global:invalid_credentials;" for="l-Customer_Password">Password:</label>
						<mvt:if expr="g.Customer_Temporary_Password">
							<input type="hidden" name="Customer_Temporary_Password" value="&mvte:global:Customer_Temporary_Password;" autocomplete="off">
							<input type="hidden" name="Customer_Password" value="&mvte:global:Customer_Temporary_Password;" autocomplete="off">
							<input id="l-Customer_Password" class="sd2-field" type="text" value="&mvte:global:Customer_Temporary_Password;" autocomplete="off" disabled readonly>
						<mvt:else>
							<input id="l-Customer_Password" class="sd2-field" type="password" name="Customer_Password" autocomplete="current-password" required>
						</mvt:if>
						<mvt:item name="buttons" param="Login" />
					</fieldset>
				</form>
				<p class="sd2-body-sm"><a data-mini-modal data-mini-modal-type="inline" data-mini-modal-content="data-forgot-password" href="&mvte:urls:FPWD:secure;" title="Forgot Password">Forgot your password?</a></p>
			</section>
			<section class="sd2-v2-auth__panel">
				<header class="sd2-v2-account-hero">
					<p class="sd2-kicker">New Customer</p>
					<h1>Create Account</h1>
				</header>
				<form method="post" action="&mvte:urls:CACT:secure;">
					<fieldset>
						<legend>Customer Log In</legend>
						<mvt:if expr="g.Order">
							<input type="hidden" name="current_location" value="&mvte:urls:OINF:secure_sep;">
							<input type="hidden" name="Order" value="&mvte:global:Order;">
						<mvt:elseif expr="g.Redeem">
							<input type="hidden" name="current_location" value="&mvte:urls:RGFT:secure_sep;">
							<input type="hidden" name="Redeem" value="&mvte:global:Redeem;">
						<mvt:elseif expr="g.WishList">
							<input type="hidden" name="current_location" value="&mvte:urls:WISH:secure_sep;">
							<input type="hidden" name="WishList" value="&mvte:global:WishList;">
						<mvt:else>
							<input type="hidden" name="current_location" value="&mvte:urls:ACLN:secure_sep;">
						</mvt:if>
						<label class="sd2-label" for="l-register_fname">First Name</label>
						<input id="l-register_fname" class="sd2-field" type="text" name="register_fname" value="" autocomplete="name given-name" required>
						<label class="sd2-label" for="l-register_lname">Last Name</label>
						<input id="l-register_lname" class="sd2-field" type="text" name="register_lname" autocomplete="name family-name" required>
						<label class="sd2-label" for="l-register_email">Email Address</label>
						<input id="l-register_email" class="sd2-field" type="email" name="register_email" value="&mvte:global:register_email;" autocomplete="email" required>
						<label class="sd2-label" for="l-register_password">Password</label>
						<input id="l-register_password" class="sd2-field" type="password" name="register_password" autocomplete="new-password" required>
						<button class="sd2-btn sd2-btn--outline sd2-btn--full" type="submit">Create My Account</button>
					</fieldset>
				</form>
			</section>
		</div>
	</main>

	<mvt:item name="hdft" param="footer" />
	<mvt:item name="readytheme" param="contentsection( 'forgot-password' )" />
	<mvt:item name="hdft" param="global_footer" />
</body>
</html>
