<style>
	.affirm-as-low-as {
		font-size: 1.0em;
		font-weight: 300;
	}
	
	.apple-pay-button {
		height: 55px;
		margin: 5px 0 0 0;
		width: 100%;
	}
	
	.x-product-list__item {
		margin-bottom: 0;
		padding: 0 !important;
	}
	
	.x-product-list__picture {
		height: auto !important;
	}
	
	.x-product-list__picture {
		display: block;
		height: auto !important;
		padding: 5px 1rem !important;
	}
	
	.x-product-list__figure-caption {
		height: auto !important;
		padding: 0 10px !important;
	}
	
	address, blockquote, dl, fieldset, figure, form, h1, h2, h3, h4, h5, h6, menu, ol, p, pre, summary, table, ul {
		margin-bottom: 0 !important;
		margin-top: 0 !important;
	}
	
	.t-related-products {
		margin-bottom: 0 !important;
		padding: 0 1.5rem !important;
	}
	
	.x-product-list__figure-caption input[type="submit"] {
		margin-top: 0 !important;
	}
	
	.ss__price label {
		background-color: red;
		color: #fff;
	}
	
	.ss__price label, .ss__msrp label {
		display: inline-block;
		font-size: 1.6em;
		font-weight: 600;
		font-weight: 600;
		height: 25px;
		line-height: 1em;
		padding: 0px;
		text-transform: uppercase;
		width: 0px;
	}
	
	.x-product-list__price {
		color: #1833b8;
		display: inline-block;
		font-size: 1.6em;
		font-weight: 600;
		padding-left: 0em;
		padding-right: 0.5em;
	}
	
	.ss__sale__price {
		color: Red;
	}
	
	.ss__msrp__price {
		color: gray;
		text-decoration: line-through;
	}
	
	.ss__msrp label {
		background-color: gray;
		color: #fff;
	}
	
	#product_just_stars {
		align-items: center;
		cursor: pointer;
		display: flex;
		flex-direction: row;
		justify-content: left;
	}

	#product_just_stars:has(.off+.off),#product_just_stars:has(.off+.half)  { display:none; }
	
	.ind_cnt {
		font-size: 1rem;
	}
	
	.page_link, page_link visited {
		color: #33c;
	}
	
	.page_link {
		text-decoration: none;
	}
	
	#veh-fit-list {
		background: #fff;
		border: 1px solid #ccc;
		flex-wrap: revert;
		height: 200px;
		margin: 0 0 15px;
		overflow-y: scroll;
		padding: 5px;
	}
</style>
	
<mvt:if expr="(l.settings:state_via_ip EQ 'CA') AND (l.settings:product:customfield_values:customfields:no_sale_california)">
	<mvt:item name="california_restricted" />
</mvt:if>

<div class="t-expanded-block u-bg-white" data-hook="product-content">
	<div class="o-wrapper t-wrapper">
		<section class="o-layout o-layout--wide x-product-layout">
			
			<mvt:item name="readytheme" param="contentsection( 'product_promo_banner' )" />
			
			<div class="o-layout__item u-width-12 u-hidden--l">
				<br>
				<p class="x-product-layout-purchase__name">
					<span class="x-product-layout-purchase__sku">
						<mvt:if expr="NOT ISNULL l.settings:product:sku">
							SKU: &mvt:product:sku;
						<mvt:else>
							SKU: &mvt:product:code;
						</mvt:if>
					</span>
					<span>&mvt:product:name;</span>
				</p>
				<br>
			</div>

			<div data-hook="product-thumbnails" hidden></div>

			<div class="o-layout__item u-width-12 u-width-6--l u-width-7--w sidebar">
				<mvt:if expr="NOT ISNULL l.settings:product:customfield_values:customfields:product_label AND l.settings:product:customfield_values:customfields:product_label NE 'none'">
					<span class="x-product-label u-bg-black u-color-white u-font-tiny u-text-uppercase">&mvt:product:customfield_values:customfields:product_label;</span>
				</mvt:if>
				<div class="sidebar__inner">
					<div class="x-product-layout-images" data-PhotoGallery role="group" style="--prod-img-x: &mvte:product_display_imagemachine:image_width;px; --prod-img-y: &mvte:product_display_imagemachine:image_height;px; --prod-thumb-x: &mvte:product_display_imagemachine:thumb_width;px; --prod-thumb-y: &mvte:product_display_imagemachine:thumb_height;px;">
						<section aria-label="The carousel with thumbnails. Selecting a thumbnail will change the &mvt:product:name; carousel." class="splide x-filmstrip-wrapper" data-filmstrip-wrapper>
							<div class="splide__track x-filmstrip" data-filmstrip>
								<ul class="splide__list x-filmstrip__list" id="thumbnails"></ul>
							</div>
						</section>
						<div class="x-product-layout-images__main-image" id="main_image">
							<div id="filmstrip-video-iframe-container" class="u-hidden"></div>
							<section class="splide" data-photograph>
								<div class="splide__track ">
									<ul class="splide__list " id="product-image-list"></ul>
								</div>
							</section>
						</div>
						<mvt:item name="product_display_imagemachine" param="body_deferred:product:id"/>
					</div>
					<!-- end .x-product-layout-images -->
				</div>
			</div>
			<!-- end .x-product-layout-images -->

			<form id="apdr" class="o-layout__item x-product-layout-purchase u-width-12 u-width-6--l u-width-5--w" data-hook="purchase" action="&mvte:urls:BASK:auto;" method="post" name="add">
				<input type="hidden" name="Old_Screen" value="&mvte:global:Screen;" />
				<input type="hidden" name="Old_Search" value="&mvte:global:Search;" />
				<input type="hidden" name="Action" value="ADPR" />
				<input type="hidden" name="Product_Code" value="&mvte:product:code;" />
				<input type="hidden" name="Product_Name" value="&mvtj:product:name;" />
				<input type="hidden" name="Product_Price" value="&mvte:product:price;" />
				<input type="hidden" name="Category_Code" value="&mvte:global:category_code;" />
				<input type="hidden" name="Offset" value="&mvte:global:Offset;" />
				<input type="hidden" name="AllOffset" value="&mvte:global:AllOffset;" />
				<input type="hidden" name="CatListingOffset" value="&mvte:global:CatListingOffset;" />
				<input type="hidden" name="RelatedOffset" value="&mvte:global:RelatedOffset;" />
				<input type="hidden" name="SearchOffset" value="&mvte:global:SearchOffset;" />
				<mvt:comment>
					<!--
						This `fieldset` element has been commented out due to a potential bug in the attribute machine
						JavaScript which can cause the form functions to not load properly in Internet Explorer and Edge.
					-->
				<fieldset>
				</mvt:comment><mvt:item name="extend" param="productfields" />
					<legend>Purchase &mvt:product:name;</legend>
					<ul class="c-form-list">
						<li class="c-form-list__item c-form-list__item--full u-hidden u-block--l">
							<h1 class="x-product-layout-purchase__name" id="js-product-name">
								<span class="x-product-layout-purchase__sku">
									<mvt:if expr="NOT ISNULL l.settings:product:sku">
										SKU: &mvt:product:sku;
									<mvt:else>
										SKU: &mvt:product:code;
									</mvt:if>
								</span>
								<span itemprop="name">&mvt:product:name;</span>
							</h1>

						</li>

						
						<li class="c-form-list__item c-form-list__item--full">
							<!-- <div class="ss__msrp"><label>Price</label><span class="x-product-list__price ss__msrp__price">$&mvt:product:customfield_values:customfields:msrp;</span></div> -->
							<div class="ss__price"><label> Sale</label><span class="x-product-layout-purchase__pricing-current x-product-list__price ss__sale__price"><span id="price-value" itemprop="price" content="&mvt:product:price;">&mvt:product:formatted_price;</span></span></div>
							<mvt:comment>
								<p class="x-product-layout-purchase__pricing">
									<span class="x-product-layout-purchase__pricing-current">
										<span id="price-value" itemprop="price" content="&mvt:product:price;">&mvt:product:formatted_price;</span>
									</span>
									<span class="x-product-layout-purchase__pricing-original">
										<span id="price-value-additional" data-prompt="regular:"><mvt:if expr="l.settings:product:base_price GT l.settings:product:price">&mvt:product:formatted_base_price;</mvt:if></span>
									</span>
								</p>
	
								<div id="product-discounts" class="x-product-layout-purchase__product-discounts u-font-small">
									<mvt:foreach iterator="discount" array="product:discounts">
										<p class="x-product-layout-purchase__product-discounts">
											&mvt:discount:descrip;: <strong>&mvt:discount:formatted_discount;</strong>
										</p>
									</mvt:foreach>
								</div>
							</mvt:comment>

							<mvt:comment>
								<!-- If you would like to display the product weight, uncomment this section. -->
								<mvt:if expr="l.settings:product:weight NE 0">
									<p class="x-product-layout-purchase__product-weight u-font-small">
										Shipping Weight: <strong>&mvt:product:weight;</strong> &mvt:store:wtunits;
									</p>
								</mvt:if>
							</mvt:comment>
	
							<mvt:if expr="l.settings:product:inv_active OR l.settings:attributemachine:product:inv_active">
								<link itemprop="availability" href="http://schema.org/&mvt:product:inv_short;">
							</mvt:if>
							<div id="inventory-message" class="x-product-layout-purchase__inventory-message"><mvt:if expr="l.settings:product:inv_active OR l.settings:attributemachine:product:inv_active">&mvt:product:inv_long;</mvt:if></div>
	
							<mvt:comment>
								<!-- If you would like to display the product quantity in basket, uncomment this section. -->
								<p class="x-product-layout-purchase__product-quantity u-font-tiny">
									Quantity in Basket:&nbsp;
									<mvt:if expr="l.settings:product:quantity EQ 0">
										<em>None</em>
									<mvt:else>
										<strong>&mvt:product:quantity;</strong>
									</mvt:if>
								</p>
							</mvt:comment>
						</li>

						<mvt:item name="discount_volume" param="product:id" />

						<li class="o-layout c-form-list__item x-product-layout-purchase__options">
							<mvt:item name="product_attributes" param="product:id" />
						</li>
						
						<li class="o-layout c-form-list__item x-product-layout-extend">
							<div class="o-layout__item"><mvt:item name="extend" param="product" /></div>
						</li>
						
						<li class="c-form-list__item c-form-list__item--full x-product-layout-purchase__cta">
							<div class="x-product-layout-purchase__message" data-hook="purchase-message"></div>
							<mvt:if expr="l.settings:product:inv_level NE 'out'">
								<div class="o-layout">
									<mvt:if expr="l.settings:subscription:enabled AND l.settings:subscription:mandatory">
										<div class="o-layout__item c-control-group x-product-layout-purchase__options-quantity">
											<div class="c-control-group__field t-product-layout-purchase__quantity">
												<label class="c-form-label u-text-bold u-font-small u-color-gray-40 is-required" for="l-quantity">qty</label>
												<input id="l-quantity" class="c-form-input u-text-center u-color-gray-40" type="tel" name="Quantity" value="1">
											</div>
											<span class="t-product-layout-purchase__add-to-cart" onclick="document.forms.add.action = '&mvtj:urls:BASK:auto;'; document.forms.add.elements.Action.value = 'ADPR';">
												<mvt:item name="buttons" param="AddToBasket"/>
											</span>
										</div>
									<mvt:else>
										<div class="o-layout__item c-control-group x-product-layout-purchase__options-quantity">
											<mvt:if expr="(l.settings:state_via_ip NE 'CA') OR (ISNULL l.settings:product:customfield_values:customfields:no_sale_california)">
												<div class="c-control-group__field t-product-layout-purchase__quantity">
													<label class="c-form-label u-text-bold u-font-small u-color-gray-50 is-required" for="l-quantity">qty</label>
													<input id="l-quantity" class="c-form-input u-text-center u-color-gray-50" type="tel" name="Quantity" value="1">
												</div>

												<span class="t-product-layout-purchase__add-to-cart" onclick="document.forms.add.action = '&mvtj:urls:BASK:auto;'; document.forms.add.elements.Action.value = 'ADPR';">
													<mvt:item name="buttons" param="AddToBasket"/>
												</span>
											</mvt:if>
											<span class="t-product-layout-purchase__add-to-wish" data-mmnodisable="true">
												<span onclick="document.forms.add.action = '&mvtj:urls:WISH:secure;'; document.forms.add.elements.Action.value = 'ATWL';">
													<mvt:item name="buttons" param="AddToWishList"/>
												</span>
											</span>
										</div>

										<div style="padding-top:20px; padding-left:16px;">
											<mvt:item name="mvaffirm_aslowas" param="product:product" />
											<div style="margin-top:10px;">
												<mvt:item name="readytheme" param="contentsection( 'paypalcp_configuration' )" />
												<mvt:item name="paypalcp_buttons" param="product" />
												<mvt:item name="applepay" param="product" />
											</div>
										</div>
									</mvt:if>
								</div>
							</mvt:if>

							<div class="o-layout o-layout--justify-center" style="margin-top:10px;">
								<center><a href="https://www.p65warnings.ca.gov/" rel="nofollow"><span class="has-lazy-image has-lazy-image--loaded"><img src="graphics/00000001/8/warning-yellow-triangle.jpg" alt="Warning Icon Triangle"><font size="2"><strong>PROP 65 WARNING</strong></span></a></center></font>
							</div>

							<li class="c-form-list__item c-form-list__item--full">
							<mvt:comment>MJB ShopperApproved Reviews</mvt:comment>
							<mvt:comment>MJB 2024/6/7 Commented out the Review stars </mvt:comment>
							
							<div id="product_just_stars" class="reg aside" role="region" tabindex="-1" aria-label="Product rating summary"></div>
							
							</li>	

						</ul>
					<mvt:comment>
					</fieldset>
					</mvt:comment>
				</form>
			</section>
		</div>
		<div class="x-photo-gallery-template" data-hook="photo-gallery-template"></div>
	</div>
	
	<mvt:comment>
		<mvt:if expr="l.settings:related_product_count NE 0">
			<mvt:item name="related_products" />
		</mvt:if>
	</mvt:comment>
	<section class="t-expanded-block u-bg-white x-product-description">
	<div class="o-layout">
		<div class="o-layout__item o-layout__item u-width-12 u-width-9--l u-width-8--m">
			<ul class="t-product-description__navigation">
				<li><a class="active" href="#product-description">Description</a></li>
				<li><a href="#product-specifications">Details</a></li>
				<mvt:if expr="NOT ISNULL l.settings:product:customfield_values:customfields:shipping_required">
					<li><a href="#product-shipping">Shipping</a></li>
				</mvt:if>
				<li><a href="#product-reviews">Reviews / Q&A</a></li>
				<mvt:if expr="NOT ISNULL l.settings:product:customfield_values:customfields:installation">
					<li><a href="#installation">&mvt:customfield_names:customfields:installation;</a></li>
				</mvt:if>
				<mvt:if expr="g.at_least_one_video NE 0">
					<li><a href="#tab_videos">Videos</a></li>
				</mvt:if>
			</ul>
	
			<article class="t-product-description__article" id="product-description">
				<header>
					<p class="c-heading-delta"><br></p>
				</header>
				&mvt:product:descrip;
			</article>
	
			<mvt:if expr="NOT ISNULL l.settings:product:customfield_values:customfields:shipping_required">
	
				<mvt:do file="g.Module_Feature_SHP_DB" name="l.success" value="ProductShippingRules_Load_Product(l.settings:product:id, l.settings:productshippingrules)" />
	
				<article class="t-product-description__article hide" id="product-shipping">
					<header>
						<p class="c-heading-delta">Shipping Information</p>
					</header>
					<ul>
					<li class="row">
						<label class="">Requires Shipping: </label><span class="">Item Requires Shipping</span>
					</li>
					<li class="row">
						<label class="">Weight: </label><span class="">&mvt:product:weight; lbs.</span>
					</li>
					<li class="row">
						<label class="">Package Dimensions: </label><span class="">W&mvt:productshippingrules:width;" x H&mvt:productshippingrules:height;" x L&mvt:productshippingrules:length;"</span>
					</li>
	
					<mvt:if expr="(l.settings:product:customfield_values:customfields:free_ground EQ 1)">
						<li class="row">
							<label class="">Shipping: </label><span class="">Free Shipping!</span>
						</li>
					</mvt:if>
					<mvt:if expr="(l.settings:product:customfield_values:customfields:free_ground EQ 3)">
						<li class="row">
							<label class="">Shipping: </label><span class="">Free Shipping to Continental US!</span>
						</li>
					</mvt:if>
					<mvt:if expr="(l.settings:product:customfield_values:customfields:free_ground EQ 2)">
						<li class="row">
							<label class="">Shipping: </label><span class="">Calculated based off shipping address</span>
						</li>
					</mvt:if>
					<mvt:if expr="(l.settings:product:customfield_values:customfields:free_ground EQ 0) AND (l.settings:product:price GT 100)">
						<li class="row">
							<label class="">Shipping: </label><span class="">Free Shipping!</span>
						</li>
					</mvt:if>
					</ul>
				</article>
			</mvt:if>
	
			<article class="t-product-description__article hide" id="product-specifications">
				<header>
					<p class="c-heading-delta">Specs</p>
				</header>
				<ul>
				<li class="row spec-part-num">
					<label class="">Item #</label><span class="">&mvt:product:code;</span>
				</li>
				</ul>
	<mvt:comment>https://sinisterdiesel.mivatest.com/shop#/filter:ss_fitment:2021$253EFord$253EF-350$253E6.7L
	</mvt:comment>
				<header>
					<p class="c-heading-delta">Vehicle Applications</p>
				</header>
				<div class="o-layout o-layout--column" id="veh-fit-list">
				<mvt:foreach iterator="fitment" array="product:customfield_values:combofacets:fitment">
	<mvt:comment>
	 :customfield_values:combofacets:fitment[1]=2004&gt;Ford&gt;Excursion&gt;6.0L     :customfield_values:combofacets:fitment[2]=2004&gt;Ford&gt;F-250&gt;6.0L     :customfield_values:combofacets:fitment[3]=2004&gt;Ford&gt;F-350&gt;6.0L     :customfield_values:combofacets:fitment[4]=2003&gt;Ford&gt;Excursion&gt;6.0L     :customfield_values:combofacets:fitment[5]=2003&gt;Ford&gt;F-250&gt;6.0L     :customfield_values:combofacets:fitment[6]=2003&gt;Ford&gt;F-350&gt;6.0L
	</mvt:comment>
					<mvt:assign name="l.settings:this_url" value="'https://sinisterdiesel.com/shop#/filter:ss_fitment:' $ gettoken(l.settings:fitment,'>',1) $ '/' $ gettoken(l.settings:fitment,'>',2) $ '/' $ gettoken(l.settings:fitment,'>',3)  $ '/' $ gettoken(l.settings:fitment,'>', 4)" />
					<div class="o-layout__item">
					<h2 class="" href="&mvt:this_url;"><mvt:eval expr="gettoken(l.settings:fitment,'>',1) $ ' ' $ gettoken(l.settings:fitment,'>',2) $ ' ' $ gettoken(l.settings:fitment,'>',3)  $ ' ' $ gettoken(l.settings:fitment,'>', 4)" /></a>
					</div>
				</mvt:foreach>
				</div>
	
				<header>
					<p class="c-heading-delta">Details</p>
				</header>
				<ul>
					<li><span class="u-text-bold">SKU:</span>&mvt:product:sku;</li>
					<li><span class="u-text-bold">Item #:</span>&mvt:product:code;</li>
					<mvt:if expr="l.settings:product:customfield_values:customfields:upc">
						<li><span class="u-text-bold">UPC #:</span>&mvt:product:customfield_values:customfields:upc;</li>
					</mvt:if>
				</ul>
	
	<mvt:comment>
	This builds and displays the category "breadcrumbs" for this product.  Nests 5 deep so if at some point they go over that we will need to rework this
	</mvt:comment>
	
				<mvt:do name="l.result" file="g.Module_Library_DB" value="CategoryList_Load_Offset_Product_Assigned(l.settings:product:id,0,'','',0,l.null, g.assigned_categories )" />
				<mvt:if expr="NOT ISNULL g.assigned_categories">
					<header>
						<p class="c-heading-delta">Categories</p>
					</header>
					<ul>
					<mvt:foreach iterator="category" array="global:assigned_categories">
						<mvt:assign name="l.settings:category_array" value="''" />
						<mvt:assign name="l.settings:category_array[5]" value="l.settings:category" />
						<mvt:if expr="l.settings:category:parent_id">
							<mvt:do name="l.result" file="g.Module_Library_DB" value="Category_Load_ID( l.settings:category:parent_id, l.settings:parent_category )" />
							<mvt:assign name="l.settings:category_array[4]" value="l.settings:parent_category" />
							<mvt:if expr="l.settings:parent_category:parent_id">
								<mvt:do name="l.result" file="g.Module_Library_DB" value="Category_Load_ID( l.settings:parent_category:parent_id, l.settings:parent_category )" />
								<mvt:assign name="l.settings:category_array[3]" value="l.settings:parent_category" />
								<mvt:if expr="l.settings:parent_category:parent_id">
									<mvt:do name="l.result" file="g.Module_Library_DB" value="Category_Load_ID( l.settings:parent_category:parent_id, l.settings:parent_category )" />
									<mvt:assign name="l.settings:category_array[2]" value="l.settings:parent_category" />
									<mvt:if expr="l.settings:parent_category:parent_id">
										<mvt:do name="l.result" file="g.Module_Library_DB" value="Category_Load_ID( l.settings:parent_category:parent_id, l.settings:parent_category )" />
										<mvt:assign name="l.settings:category_array[1]" value="l.settings:parent_category" />
									</mvt:if>
								</mvt:if>
							</mvt:if>
						</mvt:if>
						<li>
						<mvt:assign name="l.dummy" value="miva_array_collapse(l.settings:category_array)"/>
						<mvt:foreach iterator="this_category" array="category_array">
							<mvt:do file="g.Module_Feature_URI_DB" name="l.success" value="URI_Load_Category_Canonical(l.settings:this_category:id, l.settings:uri_info)" />
							<mvt:if expr="POS2 GT 1">
								-
							</mvt:if>
							<a class="page_link" href="&mvt:uri_info:uri;">&mvt:this_category:name;</a>
						</mvt:foreach>
						</li>
					</mvt:foreach>
					</ul>
				</mvt:if>
			</article>
	
		<article class="t-product-description__article hide" id="product-reviews">
		  <header>
