<mvt:comment>Move these styles to the theme css files when ready</mvt:comment>
<style>
	.x-product-videos--grid {
		justify-content: center;
	}

	.x-product-videos--embedded-video,
	.t-page-prod iframe.x-product-videos--embedded-video {
		margin: 0;
		width: 100%;
	}

	.x-product-videos--video {
		margin-bottom: 1rem;
		padding-bottom: 1.5rem;
		position: relative;
	}

	.x-product-videos--videotn {
		background-position: center center;
		background-repeat: no-repeat;
		background-size: cover;
		margin: 0;
		padding: 0 0 56.25% 0;
		position: relative;
	}

	.x-product-videos--videotn:before {
		background: url('data:image/png;base64,') center center no-repeat;
		content: " ";
		height: 100%;
		left: 0;
		opacity: 0.75;
		position: absolute;
		top: 0;
		width: 100%;
	}

	.x-hover--allowed .x-product-videos--videotn:hover::before {
		opacity: 1;
	}

	.x-product-videos--video-title {
		clear: both;
		display: block;
		font-size: 0.875rem;
		font-weight: 500;
		margin: 0;
		padding: 0.667em;
		text-align: center;
	}
</style>


<mvt:comment>Video Tab Contents</mvt:comment>
<div class="x-product-videos">
	<div class="x-product-videos--grid o-layout">
		<mvt:foreach iterator="video" array="product:videos_arr">
			<div id="x-product-videos--video&mvt:video:count;-area" class="x-product-videos--video o-layout__item u-width-12 u-width-6--s">
				<div class="x-product-videos--video-inner" id="x-product-videos--video&mvt:video:count;">
					<a
						class="x-product-videos--videotn u-block"
						style="background-image:url('&mvte:video:youtube_tn;');"
						data-embedlink="&mvte:video:youtube_embed_link;"
						data-videoguid="&mvta:video:guid;"
						data-containerid="x-product-videos--video&mvt:video:count;"
						onclick="return GD_writeYouTubeVideo(this);"
						aria-label="Opens in a new tab/window"
						href="&mvte:video:youtube_view_link;"
						target="_blank"
					>
					</a>
					<mvt:if expr="l.settings:video:caption NE ''">
							<div class="x-product-videos--video-title">&mvt:video:caption;</div>
					</mvt:if>
				</div>
			</div>
		</mvt:foreach>
	</div>
</div>


<mvt:comment>You can move these scripts to the theme JS file if you want. Just put them, so they're able to be accessed globally.</mvt:comment>
<script>
	function GD_writeYouTubeVideo(obj) {
		const currVideoContainer = obj.getAttribute('data-containerid');
		const currVideoGUID = obj.getAttribute('data-videoguid');
		const currVideoEmbedLink = obj.getAttribute('data-embedlink');

		document.getElementById(currVideoContainer).innerHTML = `<iframe class="x-product-videos--embedded-video" src="${currVideoEmbedLink}" width="100%" height="180" allow="autoplay; accelerometer; encrypted-media; gyroscope; picture-in-picture" allowfullscreen="" ></iframe>`;
		GD_fluidVideoEmbed();
		return false;
	}

	function GD_fluidVideoEmbed() {
		if (document.querySelectorAll('.x-product-videos--embedded-video').length) {
			const preferred_video_ratio = 1.78; /*  1.78 = 16:9 */

			for (let k = 0; k < document.querySelectorAll('.x-product-videos--embedded-video').length; k++) {
				const curr_iframe_width_px = document.querySelectorAll('.x-product-videos--embedded-video')[k].clientWidth;

				document.querySelectorAll('.x-product-videos--embedded-video')[k].style.height = `${parseInt(curr_iframe_width_px / preferred_video_ratio)}px`;
			}
		}
	}

	window.addEventListener('resize', () => {
		GD_fluidVideoEmbed();
	}, false);

	window.addEventListener('load', () => {
		GD_fluidVideoEmbed();
	}, false);
</script>
