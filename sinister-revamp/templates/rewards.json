        "mmx_texteditor": {
            "component_code": "mmx-text-editor",
            "item_code": "mmx_texteditor",
            "settings": {
                "content": {
                    "value": "<div style=\"text-align: center; font-size: 20px;\"><span style=\"font-weight: bold; font-size: 20px; text-decoration-line: underline;\">Coupon Code Rules</span></div><div style=\"text-align: center; font-size: 20px;\"><span style=\"font-weight: bold; font-size: 20px;\"><br></span></div><div style=\"text-align: left;\"><ul style=\"\"><li style=\"font-size: 15px;\"><span style=\"font-size: 15px;\">Coupon codes cannot be stacked with other coupon codes, this includes any sale coupon codes</span><br></li><li style=\"font-size: 15px;\"><span style=\"font-size: 15px;\">Coupon Codes are ONLY Valid on Sinister Diesel Products.&nbsp;</span></li><li style=\"font-size: 15px;\"><span style=\"font-size: 15px;\">You MUST be logged in to redeem coupons and see rewards points.</span></li><li style=\"font-size: 15px;\"><span style=\"font-size: 15px;\">You MUST be logged in to be awarded points for an order that is placed online</span></li><li style=\"font-size: 15px;\"><span style=\"font-size: 15px;\">If you place an order over the phone, you must have an account online with the same email given for the order over the phone. If for some reason your points do not show up for over-the-phone orders, please contact customer service and we can have the points added.</span></li><li style=\"\"><span style=\"font-size: 15px;\">ALL coupons redeemed through our Rewards System are one-time use. Once used, they are permenantly removed from our system.</span></li></ul></div>"
                }
            }
