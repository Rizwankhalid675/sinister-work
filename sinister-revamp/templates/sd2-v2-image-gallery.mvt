<mvt:comment>Commerce partial: Image Gallery. Inactive reusable component composed by Product Media Container.</mvt:comment>
<section class="sd2-v2-media" data-v2-gallery aria-label="Product image gallery">
	<div class="sd2-v2-media__viewer" data-v2-zoom-viewer>
		<img src="&mvte:product:imagetypes:main;" alt="&mvte:product:name;" data-v2-gallery-main>
	</div>
	<div class="sd2-v2-media__thumbs" data-v2-thumbnail-rail></div>
</section>
