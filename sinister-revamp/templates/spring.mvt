        <button class="nav next" type="button" aria-label="Next products">›</button>
      </div>

      <div class="dots" role="tablist" aria-label="Carousel pagination"></div>
    </section>

    <!-- ===== Shop by Category ===== -->
    <section id="bf-shop-cat" class="shop-cat" aria-label="Shop by Category">
      <h2>Shop by Category</h2>
      <div class="cat-grid" role="list">
        <a class="cat-card" role="listitem" href="https://sinisterdiesel.com/diesel-air-intakes-parts-for-powerstroke-cummins-superduty-engines.html">
          <img src="/mm5/graphics/00000001/7/1_1200x800.jpg" alt="">
          <span class="label">Air Intake</span>
        </a>
        <a class="cat-card" role="listitem" href="https://sinisterdiesel.com/exhaust.html">
          <img src="/mm5/graphics/00000001/product_images/RAW144811535.jpeg" alt="">
          <span class="label">Exhaust Kits</span>
        </a>
        <a class="cat-card" role="listitem" href="https://sinisterdiesel.com/intercoolers-pipes.html">
          <img src="/mm5/graphics/00000001/7/_DSC3789_1200x800.jpg" alt="">
          <span class="label">Charge Pipes</span>
        </a>
        <a class="cat-card" role="listitem" href="https://sinisterdiesel.com/view-all-filtration-kits.html">
          <img src="/mm5/graphics/00000001/8/67FuelFilter_1200x800.png" alt="">
          <span class="label">Filtration</span>
        </a>
        <a class="cat-card" role="listitem" href="https://sinisterdiesel.com/merchandise-apparel-5534.html">
          <img src="/mm5/graphics/00000001/product_images/RAW144810153.jpeg" alt="">
          <span class="label">Apparel</span>
        </a>
        <a class="cat-card" role="listitem" href="https://sinisterdiesel.com/scratch-dent.html">
          <img src="/mm5/graphics/00000001/7/CATEGORIES_Open%20Box-Clearance.png" alt="">
          <span class="label">Clearance</span>
        </a>
      </div>
    </section>

    <!-- ===== FAQ ===== -->
    <section id="faq" class="faq" aria-label="Sale FAQs">
      <style>
        #faq .shell{
          background:linear-gradient(180deg,#0f1a2b,#0c1526);
          border:1px solid #1b2740;
          box-shadow:0 30px 70px rgba(0,0,0,.5);
          border-radius:16px;
          padding:clamp(14px,2.4vw,28px);
          max-width:1100px;
          margin:0 auto;
        }
        #faq .split{
          display:grid;
          grid-template-columns:1.05fr 1.35fr;
          grid-template-rows:auto auto;
          grid-template-areas:
            "left list"
            "brand list";
          gap:20px;
          align-items:start;
        }
        #faq .left{grid-area:left;}
        #faq .list{grid-area:list;}
        #faq .brand{
          grid-area:brand;
          align-self:start;
          justify-self:center;
          text-align:center;
        }
        #faq .left h2{
          margin:4px 0 8px;
          font-size:clamp(28px,3.6vw,40px);
          line-height:1.05;
          font-weight:900;
          color:#e4e9f9;
          letter-spacing:.3px;
        }
        #faq .left .blurb{ color:#9fb0c9; max-width:36ch; }
        #faq .brand img{
          display:block;
          width:100%;
          max-width:300px;
          height:auto;
          margin-inline:auto;
        }
        #faq .list{
          background:#0f172a;
          border:1px solid #1c2740;
          border-radius:14px;
          overflow:hidden;
          box-shadow:0 10px 30px rgba(0,0,0,.35);
        }
        #faq .faq-item{ background:transparent; border-bottom:1px solid #1f2a44; }
        #faq .faq-item:last-child{border-bottom:0;}
        #faq .faq-item>summary{
          list-style:none;
          cursor:pointer;
          padding:16px 18px;
          display:grid;
          grid-template-columns:1fr auto;
          align-items:center;
          gap:12px;
          color:#d6def0;
          font-weight:800;
          letter-spacing:.15px;
          font-size:15px;
        }
        #faq .faq-item>summary::after{
          content:"⌄";
          color:#8ea2c7;
          font-weight:900;
          font-size:16px;
          line-height:1;
          transform:rotate(0deg);
          transition:transform .18s ease,color .18s ease;
        }
        #faq .faq-item[open]>summary{
          color:#fff;
          background:linear-gradient(0deg,rgba(255,255,255,.02),rgba(255,255,255,0));
        }
        #faq .faq-item[open]>summary::after{ transform:rotate(180deg); color:#1e3aff; }
        #faq .faq-item .answer{
          padding:0 18px 16px 18px;
          color:#b8c6e0;
          font-size:14px;
          line-height:1.6;
          border-left:3px solid #1e3aff;
          margin-left:12px;
        }
        #faq > h2{display:none;}
        @media (max-width:979px){
          #faq .split{
            grid-template-columns:1fr;
            grid-template-rows:auto auto auto;
            grid-template-areas:
              "left"
              "list"
              "brand";
          }
          #faq .brand img{max-width:clamp(180px,44vw,300px);}
        }
      </style>

      <h2>Frequently Asked Questions</h2>
      <div class="shell">
        <div class="split">
          <aside class="left">
            <h2>Frequently Asked<br>Questions</h2>
            <p class="blurb">
              Quick answers about our , shipping timelines, and returns.
            </p>
          </aside>

          <div class="list" role="list">
            <details class="faq-item" role="listitem">
              <summary><span>When does the Big Spring Sale end?</span></summary>
              <div class="answer"><p>Our main Big Spring Sale promotion runs through the posted end date on this page. Any changes or extensions will be updated here.</p></div>
            </details>
            <details class="faq-item" role="listitem">
              <summary><span>Are discounts automatic or do I need a code?</span></summary>
              <div class="answer"><p>Big Spring Sale requires you to use "SpringSale26"</p></div>
            </details>
            <details class="faq-item" role="listitem">
              <summary><span>Can I stack coupons with Big Spring Sale pricing?</span></summary>
              <div class="answer"><p>Coupon stacking is not permitted during sitewide Big Spring Sale promotions unless specifically noted. One promo per order.</p></div>
            </details>
            <details class="faq-item" role="listitem">
              <summary><span>Are Clearance or Doorbuster items returnable?</span></summary>
              <div class="answer"><p>Doorbusters and Closeout/Clearance items are final sale unless defective. Standard items follow our normal return policy.</p></div>
            </details>
            <details class="faq-item" role="listitem">
              <summary><span>How long will shipping take during the Big Spring Sale?</span></summary>
              <div class="answer"><p>Due to carrier volume, shipping times may be longer than usual. In-stock items typically ship within 1–3 business days.</p></div>
            </details>
          </div>

          <div class="brand" aria-label="Sinister Diesel">
           <mvt:item name="readytheme" param="image( 'stklogo1' )" />
          </div>
        </div>
      </div>
    </section>
  </main>

  <section class="o-layout">
    <div class="o-layout__item">
      <mvt:item name="hdft" param="footer" />
    </div>
  </section>
  <mvt:item name="hdft" param="global_footer" />

  <!-- SIMPLE CAROUSEL JS -->
  <script>
    (function(){
      try{
        var track = document.getElementById('bf-track');
        var prev  = document.querySelector('#bf-carousel .nav.prev');
        var next  = document.querySelector('#bf-carousel .nav.next');
        var dotsC = document.querySelector('#bf-carousel .dots');
        if(!track || !prev || !next || !dotsC) return;

        var cards = Array.from(track.children);
        dotsC.innerHTML = '';
        cards.forEach(function(_, i){
          var b=document.createElement('button');
          b.className='dot';
          b.type='button';
          b.role='tab';
          b.setAttribute('aria-label','Go to slide '+(i+1));
          b.addEventListener('click', function(){
            track.scrollTo({left: cards[i].offsetLeft, behavior:'smooth'});
          });
          dotsC.appendChild(b);
        });

        function updateButtons(){
          var maxLeft = track.scrollWidth - track.clientWidth - 1;
          prev.disabled = track.scrollLeft <= 1;
          next.disabled = track.scrollLeft >= maxLeft;

          var center = track.scrollLeft + track.clientWidth/2;
          var best=0, bestD=Infinity;
          cards.forEach(function(c, i){
            var cc = c.offsetLeft + c.offsetWidth/2;
            var d = Math.abs(center - cc);
            if(d < bestD){ bestD = d; best = i; }
          });
          Array.from(dotsC.children).forEach(function(d, idx){
            d.setAttribute('aria-selected', idx===best ? 'true' : 'false');
          });
        }

        function stepAmount(){
          return Math.max(200, Math.round(track.clientWidth * 0.9));
        }

        prev.addEventListener('click', function(e){
          e.preventDefault();
          track.scrollBy({left:-stepAmount(),behavior:'smooth'});
        });
        next.addEventListener('click', function(e){
          e.preventDefault();
          track.scrollBy({left: stepAmount(),behavior:'smooth'});
        });

        track.addEventListener('scroll', function(){
          requestAnimationFrame(updateButtons);
        }, {passive:true});
        window.addEventListener('resize', function(){
          requestAnimationFrame(updateButtons);
        });

        // Price + badge formatting
        var nf=new Intl.NumberFormat('en-US',{style:'currency',currency:'USD'});
        cards.forEach(function(card){
          var reg=parseFloat(card.getAttribute('data-price')||'0'),
              sale=parseFloat(card.getAttribute('data-sale')||'0');
          var saleEl=card.querySelector('.price .sale'),
              wasEl =card.querySelector('.price .was'),
              badge =card.querySelector('.disc-badge');

          if(reg && sale && sale<reg){
            if(saleEl) saleEl.textContent=nf.format(sale);
            if(wasEl)  wasEl.textContent=nf.format(reg);
            if(badge){
              var pct=Math.round((reg-sale)/reg*100);
              badge.textContent=pct+'% OFF';
              badge.hidden=false;
            }
          } else {
            var priceToShow=sale||reg;
            if(saleEl) saleEl.textContent=priceToShow?nf.format(priceToShow):'';
            if(wasEl && (!sale || sale>=reg)) wasEl.remove();
            if(badge) badge.hidden=true;
          }
        });

        updateButtons();
      }catch(e){
        console.error('Carousel init error', e);
      }
    })();
  </script>
</body>
</html>