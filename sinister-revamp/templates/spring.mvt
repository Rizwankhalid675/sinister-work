<!-- ===============================
     SINISTER DIESEL NEW YEARS 2025 LANDING PAGE
     (Hero bleed + Carousel + Categories + FAQ + Fireworks overlay)
     =============================== -->

<mvt:item name="html_profile" />
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <base href="&mvte:global:basehref;">

  <mvt:if expr="NOT ISNULL l.settings:page:title">
    <title>&mvt:page:title;</title>
  <mvt:else>
    <title>&mvt:page:name; | &mvt:store:name;</title>
  </mvt:if>

  <mvt:if expr="g.useDevResources EQ 1">
    <mvt:item name="head" param="css_list_dev" />
  <mvt:else>
    <mvt:item name="head" param="css_list" />
  </mvt:if>
  <mvt:item name="head" param="head_tag" />

  <style>
    /* Kill the auto page title strip on the NEW YEARS landing page only */
    .newyears-2025 .o-layout__item.t-expanded-block__item,
    .newyears-2025 h1.c-heading-delta.u-text-bold.u-color-primary,
    .newyears-2025 .c-keyline {
      display: none !important;
    }

    :root{
      --bg:#000;
      --text-on-dark:#f5f5f5;
      --accent:#1e3aff;
      --accent-soft:#93a2ff;
      --sale:#d90429;
      --line:#e5e7eb;
    }

    html,body{
      height:100%;
      margin:0;
      background:var(--bg);
      color:var(--text-on-dark);
      font-family:system-ui,-apple-system,"Segoe UI",Roboto,Inter,Arial,sans-serif;
      line-height:1.45;
      overflow-x:hidden;
    }

    .container{
      max-width:1200px;
      margin:0 auto;
      padding:0 clamp(16px,3vw,32px) clamp(16px,3vw,32px);
    }

    /* ===== HERO ===== */
    .hero{
      position:relative;
      padding:0;
      margin-top:0;
      color:#fff;
    }

    /* full-bleed hero artwork */
    .hero-art{
      position:relative;
      left:50%;
      right:50%;
      width:100vw;
      margin-left:-50vw;
      margin-right:-50vw;
    }
    .hero-art img{
      display:block;
      width:100%;
      height:auto;
    }

    .hero-inner{
      position:relative;
      z-index:1;
      text-align:center;
      max-width:680px;
      margin:0 auto;
    }

    .hero .actions{
      display:flex;
      gap:12px;
      justify-content:center;
      flex-wrap:wrap;
      margin-top: clamp(18px, 3.2vw, 36px);
    }

    .btn{
      appearance:none;
      cursor:pointer;
      border:0;
      border-radius:999px;
      padding:16px 24px;
      font-weight:200;
      text-decoration:none;
      display:inline-flex;
      align-items:center;
      justify-content:center;
    }

    .btn-primary{
      background:var(--accent);
      box-shadow:0 10px 28px rgba(30,58,255,.45);
      color:#fff;
      font-size:clamp(20px, 13vw, 28px);
      font-weight:600;
      letter-spacing:0.03em;
      padding:clamp(18px, 3vw, 24px)
              clamp(36px, 6vw, 56px);
      min-width:min(480px, 96vw);
    }
    @media (max-width: 640px){
      .hero .actions{ margin-top:16px; }
      .hero .btn-primary{
        font-size:16px;
        padding:12px 20px;
        width:80vw;
        max-width:320px;
        min-width:auto;
        margin-inline:auto;
      }
    }

    /* hero image wrappers */
    .hero-img-wrap{ display:block; }
    .hero-img-wrap img{ display:block; width:100%; height:auto; }
    .hero-img-mobile{ display:none; }
    @media (max-width:768px){
      .hero-img-desktop{ display:none; }
      .hero-img-mobile{ display:block; }
    }

    /* ===== SECTION HEADINGS ===== */
    #bf-carousel h2,
    #bf-shop-cat h2,
    #faq h2{
      font-size:clamp(32px,3.5vw,36px);
      text-align:center;
      margin:0 0 14px;
      text-transform:uppercase;
      font-weight:900;
      letter-spacing:.5px;
    }
    #bf-carousel h2{color:#fff;}
    #bf-shop-cat h2{color:#e8edff;text-shadow:0 2px 10px rgba(0,0,250,.35);}
    #faq h2{color:#e8edff;text-shadow:0 2px 10px rgba(30,58,255,.35);}

    /* ===== FEATURED CAROUSEL ===== */
    #bf-carousel{
      margin-top: 0;
      padding-top: 32px;
    }

    #bf-carousel .bf-carousel{
      position:relative;
      display:grid;
      grid-template-columns:auto 1fr auto;
      align-items:center;
      gap:10px;
    }

    #bf-carousel .nav{
      appearance:none;
      border:0;
      background:#0f172a;
      color:#fff;
      width:40px;
      height:40px;
      border-radius:999px;
      font-size:24px;
      display:grid;
      place-items:center;
      cursor:pointer;
      box-shadow:0 10px 24px rgba(0,0,0,.3);
    }
    @media (max-width:720px){ #bf-carousel .nav{display:none;} }

    #bf-track{
      display:grid;
      grid-auto-flow:column;
      grid-auto-columns:30%;
      gap:18px;
      overflow-x:auto;
      scroll-snap-type:x mandatory;
      padding:6px;
      scrollbar-width:none;
      align-items:stretch;
    }
    #bf-track::-webkit-scrollbar{display:none;}
    @media (max-width:1024px){#bf-track{grid-auto-columns:48%;}}
    @media (max-width:640px){#bf-track{grid-auto-columns:82%;gap:8px;padding:4px 8px 10px;}}

    #bf-carousel .card{
      background:#fff;
      color:#0f172a;
      border-radius:16px;
      overflow:hidden;
      box-shadow:0 10px 24px rgba(0,0,0,.10);
      scroll-snap-align:center;
      border:1px solid #e5e7eb;
      position:relative;
      height:100%;
      display:flex;
      flex-direction:column;
    }
    #bf-carousel .card.featured{outline:2px solid var(--accent);}

#bf-carousel .media{
  height:220px;
  background:#fff;
  position:relative;
  display:flex;
  align-items:center;
  justify-content:center;
  padding:12px;
}

#bf-carousel .media img{
  width:100%;
  height:100%;
  object-fit:contain;
  display:block;
}

    #bf-carousel .disc-badge{
      position:absolute;
      right:10px;
      top:10px;
      width:56px;
      height:56px;
      border-radius:999px;
      background:var(--sale);
      color:#fff;
      font-weight:900;
      font-size:12px;
      display:flex;
      align-items:center;
      justify-content:center;
      text-align:center;
      line-height:1.05;
      box-shadow:0 10px 18px rgba(217,4,41,.45);
      padding:4px;
    }

    #bf-carousel .body{
      padding:12px 14px 14px;
      display:flex;
      flex-direction:column;
      gap:8px;
      flex:1;
    }

    #bf-carousel .name{
      font-size:15px;
      margin:0;
      line-height:1.25;
      min-height:2.6em;
      max-height:2.6em;
      overflow:hidden;
    }
    #bf-carousel .name a{
      display:-webkit-box;
      -webkit-box-orient:vertical;
      -webkit-line-clamp:2;
      overflow:hidden;
      text-overflow:ellipsis;
      color:inherit;
      text-decoration:none;
    }
    #bf-carousel .sku{ font-size:12px; color:#6b7280; }
    #bf-carousel .price{ display:flex; align-items:center; gap:10px; margin-top:8px; }
    #bf-carousel .price .sale{ font-size:19px; font-weight:900; color:#d90429; }
    #bf-carousel .price .was{ font-size:14px; color:#6b7280; text-decoration:line-through; }

    #bf-carousel .btn.view{
      margin-top:auto;
      height:42px;
      border-radius:12px;
      display:inline-flex;
      align-items:center;
      justify-content:center;
      background:var(--accent);
      color:#fff;
      font-weight:800;
      font-size:14px;
      text-decoration:none;
    }

    #bf-carousel .dots{ display:flex; justify-content:center; gap:8px; margin-top:12px; }
    #bf-carousel .dot{
      width:10px; height:10px; border-radius:999px; border:0;
      background:#4b5563; cursor:pointer;
    }
    #bf-carousel .dot[aria-selected="true"]{ background:var(--accent); width:18px; }

    @media (min-width:1100px){
      #bf-carousel{
        position:relative;
        left:50%;
        transform:translateX(-50%);
        width:min(1600px,96vw);
        padding-inline:clamp(8px,2vw,20px);
      }
      #bf-track{grid-auto-columns:24%;gap:16px;}
    }
    @media (min-width:1400px){ #bf-track{grid-auto-columns:19%;gap:16px;} }

    /* ===== CATEGORIES ===== */
    .shop-cat{
      margin-top:clamp(32px,4vw,48px);
      margin-bottom:clamp(56px,7vw,110px);
    }
    .cat-grid{
      display:grid;
      grid-template-columns:repeat(2,minmax(0,1fr));
      gap:20px;
    }
    @media (min-width:1000px){
      .cat-grid{grid-template-columns:repeat(3,minmax(0,1fr));}
    }
    .cat-card{
  display:block;
  position:relative;
  background:#fff;
  border:2px solid var(--accent);
  border-radius:14px;
  overflow:hidden;
  transition:transform .22s ease,box-shadow .22s ease,border-color .22s ease;
}

.cat-card img{
  width:100%;
  height:260px;
  object-fit:contain;
  object-position:top;
  display:block;
  background:#fff;
}

@media (max-width:999px){
  .cat-card{
    aspect-ratio:1 / 1;
  }

  .cat-card img{
    height:100%;
    padding:14px;
    object-fit:contain;
    object-position:top;
    background:#fff;
  }

  .cat-card .label{
    position:absolute;
    left:12px;
    right:12px;
    bottom:12px;
  }
}
.cat-card .label{
  position:absolute;
  left:12px;
  right:12px;
  bottom:12px;
  background:var(--accent);
  color:#fff;
  padding:10px 12px;
  border-radius:12px;
  font-weight:900;
  text-transform:uppercase;
  font-size:14px;
  letter-spacing:.5px;
  z-index:2;
}
.cat-card .label{
  white-space:nowrap;
  overflow:hidden;
  text-overflow:ellipsis;
  text-align:center;
}
  </style>
</head>

<body class="single-column newyears-2025">
  <mvt:item name="hdft" param="global_header" />
  <mvt:item name="hdft" param="header" />

  <main id="newyears-landing" class="container">
    <!-- HERO -->
    <section class="hero">
      <div class="hero-art">
        <span class="hero-img-wrap hero-img-desktop">
          <mvt:item name="readytheme" param="image( 'spring' )" />
        </span>
        <span class="hero-img-wrap hero-img-mobile">
         <mvt:item name="readytheme" param="image( 'springmob' )" />
        </span>
      </div>

      <div class="hero-inner">
        <div class="actions">
          <a class="btn btn-primary"
             href="https://sinisterdiesel.com/sinister-diesel.html"
