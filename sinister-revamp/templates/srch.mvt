<!DOCTYPE html>
<html>
<mvt:item name="html_profile" />
<head>
	<meta charset="utf-8">
	<meta name="viewport" content="width=device-width, initial-scale=1">
	<base href="&mvte:global:basehref;">
	<mvt:if expr="NOT ISNULL l.settings:page:title">
		<title>&mvt:page:title;</title>
	<mvt:else>
		<title>&mvt:page:name; | &mvt:store:name;</title>
	</mvt:if>
	<mvt:if expr="g.useDevResources EQ 1"><mvt:item name="head" param="css_list_dev" /><mvt:else><mvt:item name="head" param="css_list" /></mvt:if>
	<mvt:item name="head" param="head_tag" />
	<mvt:comment>
		Sinister Diesel native SRCH template using the approved revamp design
		patterns on the live search shell. Native Miva search_results owns the
		result data and pagination; this shell owns the page chrome only.
	</mvt:comment>
</head>
<body>
	<mvt:item name="hdft" param="global_header" />
	<mvt:item name="hdft" param="header" />

<main class="sd2-v2-search-page" data-v2-search-page>
	<div class="sd2-wrap">
		<header class="sd2-v2-search-page__head" data-v2-search-results-header>
			<nav class="sd2-v2-breadcrumbs" aria-label="Breadcrumb">
				<a href="&mvte:urls:SFNT:auto;">Home</a>
				<span aria-hidden="true">/</span>
				<span>Search</span>
			</nav>
			<div class="sd2-v2-search-page__title-row">
				<div>
					<p class="sd2-eyebrow">Search Results</p>
					<mvt:if expr="NOT ISNULL g.Search">
						<h1 class="sd2-heading-lg">Results for &quot;&mvte:global:Search;&quot;</h1>
					<mvt:else>
						<h1 class="sd2-heading-lg">Search Sinister Diesel</h1>
					</mvt:if>
				</div>
				<p class="sd2-v2-search-page__count">
					<mvt:if expr="NOT ISNULL g.Search">
						&mvte:search_product_count; results
					<mvt:else>
						Discovery mode
					</mvt:if>
				</p>
			</div>
			<div class="sd2-v3-hero-data" aria-label="Search status">
				<div><span>Query</span><strong><mvt:if expr="NOT ISNULL g.Search">&mvte:global:Search;<mvt:else>Open search</mvt:if></strong></div>
				<div><span>Results</span><strong><mvt:if expr="NOT ISNULL g.Search">&mvte:search_product_count;<mvt:else>—</mvt:if></strong></div>
				<div><span>Coverage</span><strong>All platforms</strong></div>
			</div>
			<form class="sd2-v2-search-page__form" method="get" action="&mvte:urls:SRCH:auto;">
				<label class="sd2-label" for="sd2-v2-search-page-input">Search</label>
				<div class="sd2-v2-search-page__field-row">
					<input class="sd2-field" id="sd2-v2-search-page-input" type="search" name="Search" value="&mvte:global:Search;" data-v2-search-page-input autocomplete="off">
					<button class="sd2-btn sd2-btn--primary" type="submit">Search</button>
				</div>
			</form>
			<mvt:if expr="NOT ISNULL g.Search AND l.settings:search_product_count EQ 0">
				<p class="sd2-v2-search-page__correction">Try a shorter part number, truck platform, engine generation, or product family.</p>
			</mvt:if>
		</header>

		<section class="sd2-v2-search-suggestions sd2-v3-search-discovery" aria-label="Search suggestions" data-v2-search-suggestions data-sd2-story>
			<div class="sd2-v2-search-suggestions__block">
				<h2 class="sd2-v2-search-suggestions__title">Popular Searches</h2>
				<div class="sd2-v2-search-suggestions__chips">
					<a href="&mvte:urls:SRCH:auto;?Search=powerstroke%20turbo">Powerstroke turbo</a>
					<a href="&mvte:urls:SRCH:auto;?Search=duramax%20intercooler">Duramax intercooler</a>
					<a href="&mvte:urls:SRCH:auto;?Search=cummins%20injectors">Cummins injectors</a>
					<a href="&mvte:urls:SRCH:auto;?Search=egr%20cooler">EGR cooler</a>
				</div>
			</div>
			<div class="sd2-v2-search-suggestions__block" data-v2-search-page-recent hidden>
				<h2 class="sd2-v2-search-suggestions__title">Recent Searches</h2>
				<div class="sd2-v2-search-suggestions__chips" data-v2-search-page-recent-list></div>
			</div>
			<div class="sd2-v2-search-suggestions__block">
				<h2 class="sd2-v2-search-suggestions__title">Suggested Categories</h2>
				<div class="sd2-v2-search-suggestions__links">
					<a href="/ford-powerstroke-powerstroke-diesel-truck-parts-online.html">Powerstroke Parts</a>
					<a href="/shop-gm-duramax-diesel-parts-sinister-diesel.html">Duramax Parts</a>
					<a href="/dodge-cummins-diesel-performance-parts-sinister-diesel.html">Cummins Parts</a>
				</div>
			</div>
		</section>

		<mvt:if expr="NOT ISNULL g.Search AND l.settings:facets:facet_count GT 0">
			<mvt:assign name="l.settings:sd2_srch_layout_class" value="'sd2-v2-search-page__layout sd2-v2-search-page__layout--has-filters'" />
		<mvt:else>
			<mvt:assign name="l.settings:sd2_srch_layout_class" value="'sd2-v2-search-page__layout sd2-v2-search-page__layout--no-filters'" />
		</mvt:if>
		<section class="&mvte:sd2_srch_layout_class;" aria-label="Search products">
			<mvt:if expr="NOT ISNULL g.Search AND l.settings:facets:facet_count GT 0">
				<div class="sd2-v2-filter-sheet-scrim" data-v2-filter-close hidden></div>
				<aside class="sd2-v2-filter-rail sd2-v2-filter-sheet" data-v2-filter-sheet aria-hidden="true" aria-label="Search filters">
					<div class="sd2-v2-filter-sheet__head"><div><span>Catalog Control</span><strong>Filter Parts</strong></div><button type="button" data-v2-filter-close aria-label="Close filters">&times;</button></div>
					<div class="sd2-v2-filter-sheet__body"><mvt:item name="facets" /></div>
					<div class="sd2-v2-filter-sheet__foot"><button class="sd2-btn sd2-btn--primary sd2-btn--full" type="button" data-v2-filter-close>View Products</button></div>
				</aside>
			</mvt:if>

			<div class="sd2-v2-search-page__results">
				<div class="sd2-v2-result-tools">
					<div class="sd2-v2-filter-chips" data-v2-filter-chips>
						<mvt:if expr="NOT ISNULL g.Search">
							<span>Search: &mvte:global:Search;</span>
						<mvt:else>
							<span>Discovery</span>
						</mvt:if>
					</div>
					<mvt:if expr="NOT ISNULL g.Search AND l.settings:facets:facet_count GT 0">
						<button class="sd2-v2-filter-trigger" type="button" data-v2-filter-open aria-expanded="false"><span>Filter Parts</span><strong>&mvte:facets:facet_count;</strong></button>
					</mvt:if>
					<mvt:comment>
						TODO: Legacy SRCH (srch.mvt / srch-search_results.mvt) has no real Sort_By
						submission form — only a page-jump <select> inside search_results:page_links.
						Do not fabricate Sort_By values with no backing legacy logic. This control
						is presentation-only until a real sort mechanism is confirmed for SRCH.
					</mvt:comment>
				</div>

				<mvt:if expr="ISNULL g.Search">
					<div class="sd2-v2-search-discovery" data-v2-search-discovery>
						<p class="sd2-body">Start with a part number, engine, symptom, or product family. Discovery links above keep the page useful before a query is entered.</p>
					</div>
				<mvt:elseif expr="l.settings:search_product_count GT 0">
					<mvt:comment>
						search_results item owns product cards AND its own real pagination
						(search_results:page_links). Do not duplicate a "Load More" control here —
						legacy has no infinite-scroll mechanism, only page-link pagination rendered
						inside this item.
					</mvt:comment>
					<mvt:item name="search_results" />
				<mvt:else>
					<section class="sd2-v2-search-empty" aria-labelledby="sd2-v2-search-empty-title" data-v2-search-empty-state>
						<div>
							<p class="sd2-eyebrow">No Results</p>
							<h2 class="sd2-heading-lg" id="sd2-v2-search-empty-title">No exact match found.</h2>
							<p class="sd2-body">Clear the search, browse by platform, or start from a proven category path.</p>
							<div class="sd2-v2-search-empty__actions">
								<a class="sd2-btn sd2-btn--primary" href="&mvte:urls:SRCH:auto;">Clear Search</a>
								<button class="sd2-btn sd2-btn--outline" type="button" data-v2-garage-toggle>Add Your Truck</button>
							</div>
						</div>
						<div class="sd2-v2-search-empty__grid">
							<div><h3>Popular Categories</h3><a href="/intercoolers-pipes.html">Intercoolers &amp; Pipes</a><a href="/view-all-filtration-kits.html">Coolant &amp; Oil Filtration</a><a href="/turbos.html">Turbos</a></div>
							<div><h3>Popular Products</h3><a href="&mvte:urls:SRCH:auto;?Search=charge%20pipe">Charge Pipe Kits</a><a href="&mvte:urls:SRCH:auto;?Search=fuel%20filter">Fuel Filter Kits</a><a href="&mvte:urls:SRCH:auto;?Search=oil%20bypass">Oil Bypass Kits</a></div>
							<div><h3>Need Help?</h3><a href="/help-center.html">Help Center</a><a href="/shipping-policies.html">Shipping Policies</a><a href="/return-and-warranty-policies.html">Returns &amp; Warranty</a></div>
						</div>
					</section>
				</mvt:if>
			</div>
		</section>
	</div>
</main>
	<mvt:item name="hdft" param="footer" />
	<mvt:item name="hdft" param="global_footer" />
</body>
</html>
