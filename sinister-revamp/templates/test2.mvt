            <svg class="mem-instagram__icon" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 2.2c2.7 0 3 .01 4 .06 1.1.05 1.8.2 2.4.4.6.24 1.1.55 1.6 1.1.5.5.86 1 .98 1.6.2.6.35 1.3.4 2.4.05 1 .06 1.3.06 4s-.01 3-.06 4c-.05 1.1-.2 1.8-.4 2.4-.24.6-.55 1.1-1.1 1.6-.5.5-1 .86-1.6.98-.6.2-1.3.35-2.4.4-1 .05-1.3.06-4 .06s-3-.01-4-.06c-1.1-.05-1.8-.2-2.4-.4-.6-.24-1.1-.55-1.6-1.1-.5-.5-.86-1-.98-1.6-.2-.6-.35-1.3-.4-2.4-.05-1-.06-1.3-.06-4s.01-3 .06-4c.05-1.1.2-1.8.4-2.4.24-.6.55-1.1 1.1-1.6.5-.5 1-.86 1.6-.98.6-.2 1.3-.35 2.4-.4 1-.05 1.3-.06 4-.06zm0 1.8c-2.6 0-2.9.01-3.9.06-1 .04-1.5.2-1.9.33-.5.18-.8.4-1.2.75-.35.35-.57.7-.75 1.2-.13.4-.29.9-.33 1.9-.05 1-.06 1.3-.06 3.9s.01 2.9.06 3.9c.04 1 .2 1.5.33 1.9.18.5.4.8.75 1.2.35.35.7.57 1.2.75.4.13.9.29 1.9.33 1 .05 1.3.06 3.9.06s2.9-.01 3.9-.06c1-.04 1.5-.2 1.9-.33.5-.18.8-.4 1.2-.75.35-.35.57-.7.75-1.2.13-.4.29-.9.33-1.9.05-1 .06-1.3.06-3.9s-.01-2.9-.06-3.9c-.04-1-.2-1.5-.33-1.9-.18-.5-.4-.8-.75-1.2-.35-.35-.7-.57-1.2-.75-.4-.13-.9-.29-1.9-.33-1-.05-1.3-.06-3.9-.06zm0 3.4a5.6 5.6 0 110 11.2 5.6 5.6 0 010-11.2zm0 1.8a3.8 3.8 0 100 7.6 3.8 3.8 0 000-7.6zm5.9-2.2a1.3 1.3 0 110 2.6 1.3 1.3 0 010-2.6z"/></svg>
            <p class="mem-instagram__label">Follow our builds on Instagram</p>
