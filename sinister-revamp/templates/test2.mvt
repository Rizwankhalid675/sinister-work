<!-- ===============================
     SINISTER DIESEL — MEMORIAL DAY SALE LANDING PAGE
     Upload as a Miva Page Template. Assign ReadyTheme images:
       mem-hero-desktop, mem-hero-mobile, mem-promo-parts,
       mem-ymm-bg, mem-cta-bg, mem-truck-1, mem-truck-2, mem-truck-3
     =============================== -->

<mvt:item name="html_profile" />
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <base href="&mvte:global:basehref;">

  <mvt:if expr="NOT ISNULL l.settings:page:title">
    <title>&mvt:page:title;</title>
  <mvt:else>
    <title>&mvt:page:name; | &mvt:store:name;</title>
  </mvt:if>

  <mvt:if expr="g.useDevResources EQ 1">
    <mvt:item name="head" param="css_list_dev" />
  <mvt:else>
    <mvt:item name="head" param="css_list" />
  </mvt:if>
  <mvt:item name="head" param="head_tag" />

  <style>
    .memorial-day-landing .o-layout__item.t-expanded-block__item,
    .memorial-day-landing h1.c-heading-delta.u-text-bold.u-color-primary,
    .memorial-day-landing .c-keyline {
      display: none !important;
    }

    :root {
      --navy: #0c2340;
      --navy-dark: #071628;
      --navy-mid: #1a3a5c;
      --red: #c8102e;
      --red-dark: #9b0c24;
      --white: #ffffff;
      --off-white: #f4f6f9;
      --text-muted: #6b7280;
      --text-on-dark: #e8edf5;
      --star-gold: #c9a227;
      --max: 1200px;
    }

    html, body {
      margin: 0;
      background: var(--off-white);
      color: var(--navy);
      font-family: system-ui, -apple-system, "Segoe UI", Roboto, Inter, Arial, sans-serif;
      line-height: 1.5;
      overflow-x: hidden;
    }

    .memorial-day-landing main {
      overflow-x: hidden;
    }

    .mem-container {
      max-width: var(--max);
      margin: 0 auto;
      padding: 0 clamp(16px, 3vw, 32px);
    }

    .mem-stars {
      color: var(--star-gold);
      letter-spacing: 0.35em;
      font-size: 14px;
    }

    .mem-section-title {
      text-align: center;
      font-size: clamp(26px, 3.2vw, 34px);
      font-weight: 900;
      text-transform: uppercase;
      letter-spacing: 0.06em;
      color: var(--navy);
      margin: 0 0 clamp(20px, 3vw, 36px);
    }

  /* ===== HERO ===== */
    .mem-hero {
      position: relative;
      color: var(--white);
    }

    .mem-hero__bleed {
      position: relative;
      left: 50%;
      width: 100vw;
      margin-left: -50vw;
      margin-right: -50vw;
    }

    .mem-hero__bleed img {
      display: block;
      width: 100%;
      height: auto;
      min-height: 320px;
      object-fit: cover;
    }

    .mem-hero__img--mobile { display: none; }

    @media (max-width: 768px) {
      .mem-hero__img--desktop { display: none; }
      .mem-hero__img--mobile { display: block; }
    }

    .mem-hero__overlay {
      position: absolute;
      inset: 0;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      text-align: center;
      padding: clamp(24px, 5vw, 48px) clamp(16px, 4vw, 32px) clamp(56px, 8vw, 72px);
      background: linear-gradient(180deg, rgba(7, 22, 40, 0.35) 0%, rgba(7, 22, 40, 0.55) 100%);
    }

    .mem-hero__eyebrow {
      font-size: clamp(28px, 5vw, 52px);
      font-weight: 900;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      margin: 0;
      line-height: 1.05;
      text-shadow: 0 4px 24px rgba(0, 0, 0, 0.45);
    }

    .mem-hero__sale {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: clamp(10px, 2vw, 20px);
      margin: 4px 0 12px;
    }

    .mem-hero__sale-word {
      font-size: clamp(48px, 10vw, 96px);
      font-weight: 900;
      color: var(--red);
      line-height: 1;
      text-shadow: 0 4px 20px rgba(0, 0, 0, 0.5);
      letter-spacing: 0.04em;
    }

    .mem-hero__tagline {
      font-size: clamp(14px, 2.2vw, 20px);
      font-weight: 800;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      margin: 0 0 8px;
    }

    .mem-hero__sub {
      font-size: clamp(13px, 1.8vw, 17px);
      margin: 0 0 20px;
      opacity: 0.95;
      max-width: 42ch;
    }

    .mem-hero__offer {
      font-size: clamp(16px, 2.4vw, 22px);
      margin: 0 0 24px;
      font-weight: 600;
    }

    .mem-hero__offer strong {
      font-size: 1.35em;
      font-weight: 900;
    }

    .mem-btn {
      appearance: none;
      cursor: pointer;
      border: 0;
      border-radius: 4px;
      font-weight: 800;
      text-decoration: none;
      text-transform: uppercase;
      letter-spacing: 0.08em;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      transition: transform 0.2s ease, box-shadow 0.2s ease, background 0.2s ease;
    }

    .mem-btn:hover {
      transform: translateY(-2px);
    }

    .mem-btn--red {
      background: var(--red);
      color: var(--white);
      padding: 16px 40px;
      font-size: clamp(14px, 2vw, 17px);
      box-shadow: 0 8px 28px rgba(200, 16, 46, 0.45);
      min-width: min(280px, 90vw);
    }

    .mem-btn--red:hover {
      background: var(--red-dark);
    }

    .mem-btn--outline {
      background: transparent;
      color: var(--white);
      border: 2px solid var(--white);
      padding: 14px 32px;
      font-size: 15px;
    }

    .mem-btn--outline:hover {
      background: rgba(255, 255, 255, 0.12);
    }

    .mem-btn--navy {
      background: var(--navy);
      color: var(--white);
      padding: 14px 28px;
      font-size: 14px;
    }

    .mem-btn--navy-sm {
      background: var(--navy);
      color: var(--white);
      padding: 8px 16px;
      font-size: 12px;
      border-radius: 4px;
    }

    .mem-hero__deadline {
      position: absolute;
      bottom: 0;
      left: 0;
      right: 0;
      background: rgba(0, 0, 0, 0.75);
      text-align: center;
      padding: 10px 16px;
      font-size: clamp(11px, 1.6vw, 13px);
      font-weight: 700;
      letter-spacing: 0.06em;
      text-transform: uppercase;
    }

  /* ===== VALUE PROPS ===== */
    .mem-value-bar {
      background: var(--white);
      border-bottom: 1px solid #e2e8f0;
      padding: clamp(20px, 3vw, 28px) 0;
    }

    .mem-value-bar__grid {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 20px 16px;
    }

    @media (min-width: 768px) {
      .mem-value-bar__grid {
        grid-template-columns: repeat(4, 1fr);
        gap: 24px;
      }
    }

    .mem-value-item {
      display: flex;
      flex-direction: column;
      align-items: center;
      text-align: center;
      gap: 8px;
    }

    .mem-value-item__icon {
      width: 44px;
      height: 44px;
      color: var(--navy-mid);
    }

    .mem-value-item__title {
      font-size: 13px;
      font-weight: 900;
      text-transform: uppercase;
      letter-spacing: 0.04em;
      color: var(--navy);
      margin: 0;
    }

    .mem-value-item__desc {
      font-size: 12px;
      color: var(--text-muted);
      margin: 0;
      line-height: 1.35;
    }

  /* ===== SHOP BY CATEGORY ===== */
    .mem-categories {
      padding: clamp(40px, 6vw, 64px) 0;
      background: var(--off-white);
    }

    .mem-cat-grid {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 20px;
    }

    @media (min-width: 900px) {
      .mem-cat-grid {
        grid-template-columns: repeat(3, 1fr);
      }
    }

    .mem-cat-card {
      background: var(--white);
      border-radius: 8px;
      overflow: hidden;
      box-shadow: 0 4px 20px rgba(12, 35, 64, 0.08);
      text-decoration: none;
      color: inherit;
      display: flex;
      flex-direction: column;
      transition: transform 0.22s ease, box-shadow 0.22s ease;
    }

    .mem-cat-card:hover {
      transform: translateY(-4px);
      box-shadow: 0 12px 32px rgba(12, 35, 64, 0.14);
    }

    .mem-cat-card__media {
      background: #0a0a0a;
      aspect-ratio: 4/3;
      overflow: hidden;
    }

    .mem-cat-card__media img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      display: block;
    }

    .mem-cat-card__body {
      padding: 16px;
      flex: 1;
      display: flex;
      flex-direction: column;
      gap: 8px;
    }

    .mem-cat-card__title {
      font-size: 15px;
      font-weight: 900;
      text-transform: uppercase;
      color: var(--navy);
      margin: 0;
      letter-spacing: 0.03em;
    }

    .mem-cat-card__desc {
      font-size: 13px;
      color: var(--text-muted);
      margin: 0;
      flex: 1;
      line-height: 1.4;
    }

  /* ===== SECONDARY PROMO ===== */
    .mem-promo {
      background: var(--navy-dark);
      color: var(--text-on-dark);
      padding: clamp(40px, 6vw, 72px) 0;
    }

    .mem-promo__grid {
      display: grid;
      gap: 32px;
      align-items: center;
    }

    @media (min-width: 900px) {
      .mem-promo__grid {
        grid-template-columns: 1fr 1.2fr 1fr;
        gap: 40px;
      }
    }

    .mem-promo__stars {
      color: var(--red);
      font-size: 22px;
      letter-spacing: 4px;
      margin-bottom: 8px;
    }

    .mem-promo__headline {
      font-size: clamp(22px, 3vw, 28px);
      font-weight: 900;
      text-transform: uppercase;
      margin: 0 0 4px;
      letter-spacing: 0.04em;
    }

    .mem-promo__pct {
      font-size: clamp(36px, 5vw, 48px);
      font-weight: 900;
      margin: 0;
      line-height: 1.1;
    }

    .mem-promo__pct span {
      color: var(--red);
    }

    .mem-promo__sub {
      font-size: 14px;
      text-transform: uppercase;
      letter-spacing: 0.08em;
      color: var(--red);
      font-weight: 800;
      margin: 8px 0 0;
    }

    .mem-promo__list {
      list-style: none;
      margin: 0 0 24px;
      padding: 0;
    }

    .mem-promo__list li {
      display: flex;
      align-items: flex-start;
      gap: 10px;
      margin-bottom: 12px;
      font-size: 14px;
      font-weight: 600;
    }

    .mem-promo__check {
      color: var(--red);
      font-weight: 900;
      flex-shrink: 0;
    }

    .mem-promo__visual img {
      width: 100%;
      height: auto;
      display: block;
      border-radius: 8px;
    }

  /* ===== YMM FINDER ===== */
    .mem-ymm {
      position: relative;
      padding: clamp(48px, 7vw, 80px) 0;
      color: var(--white);
    }

    .mem-ymm__bg {
      position: absolute;
      inset: 0;
      z-index: 0;
    }

    .mem-ymm__bg img {
      width: 100%;
      height: 100%;
      object-fit: cover;
    }

    .mem-ymm__bg::after {
      content: "";
      position: absolute;
      inset: 0;
      background: linear-gradient(180deg, rgba(7, 22, 40, 0.82) 0%, rgba(7, 22, 40, 0.92) 100%);
    }

    .mem-ymm__inner {
      position: relative;
      z-index: 1;
    }

    .mem-ymm .mem-section-title {
      color: var(--white);
    }

    .mem-ymm__form {
      display: grid;
      grid-template-columns: 1fr;
      gap: 12px;
      max-width: 900px;
      margin: 0 auto;
    }

    @media (min-width: 640px) {
      .mem-ymm__form {
        grid-template-columns: repeat(4, 1fr) auto;
        align-items: end;
      }
    }

    .mem-ymm__field label {
      display: block;
      font-size: 11px;
      font-weight: 800;
      text-transform: uppercase;
      letter-spacing: 0.1em;
      margin-bottom: 6px;
      opacity: 0.9;
    }

    .mem-ymm__field select {
      width: 100%;
      padding: 12px 14px;
      border: 1px solid rgba(255, 255, 255, 0.25);
      border-radius: 4px;
      background: rgba(255, 255, 255, 0.95);
      color: var(--navy);
      font-size: 14px;
      font-weight: 600;
    }

    .mem-ymm__submit {
      width: 100%;
      padding: 14px 24px;
      white-space: nowrap;
    }

    @media (min-width: 640px) {
      .mem-ymm__submit { width: auto; }
    }

  /* ===== WHY SINISTER ===== */
    .mem-why {
      padding: clamp(48px, 6vw, 72px) 0;
      background: var(--white);
    }

    .mem-why__grid {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 28px 20px;
    }

    @media (min-width: 768px) {
      .mem-why__grid {
        grid-template-columns: repeat(4, 1fr);
      }
    }

    .mem-why__item {
      text-align: center;
    }

    .mem-why__icon {
      width: 56px;
      height: 56px;
      margin: 0 auto 12px;
      color: var(--navy-mid);
    }

    .mem-why__title {
      font-size: 14px;
      font-weight: 900;
      text-transform: uppercase;
      color: var(--navy);
      margin: 0 0 8px;
      letter-spacing: 0.04em;
    }

    .mem-why__desc {
      font-size: 13px;
      color: var(--text-muted);
      margin: 0;
      line-height: 1.45;
    }

  /* ===== SOCIAL PROOF ===== */
    .mem-social {
      padding: clamp(40px, 6vw, 64px) 0;
      background: var(--off-white);
    }

    .mem-social__trucks {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 12px;
      margin-bottom: 32px;
    }

    .mem-social__trucks img {
      width: 100%;
      aspect-ratio: 1;
      object-fit: cover;
      border-radius: 8px;
      display: block;
    }

    .mem-social__lower {
      display: grid;
      gap: 24px;
    }

    @media (min-width: 900px) {
      .mem-social__lower {
        grid-template-columns: 1fr 1fr;
      }
    }

    .mem-testimonial {
      background: var(--navy-dark);
      color: var(--text-on-dark);
      border-radius: 12px;
      padding: clamp(24px, 4vw, 36px);
    }

    .mem-testimonial__stars {
      color: var(--red);
      font-size: 18px;
      letter-spacing: 2px;
      margin-bottom: 12px;
    }

    .mem-testimonial__quote {
      font-size: clamp(15px, 2vw, 18px);
      font-style: italic;
      line-height: 1.55;
      margin: 0 0 16px;
    }

    .mem-testimonial__author {
      font-weight: 800;
      color: #7eb8ff;
      margin: 0;
      font-size: 14px;
    }

    .mem-instagram {
      background: var(--navy-dark);
      color: var(--white);
      border-radius: 12px;
      padding: clamp(28px, 4vw, 40px);
      text-align: center;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      gap: 12px;
    }

    .mem-instagram__icon {
      width: 48px;
      height: 48px;
    }

    .mem-instagram__label {
      font-size: 13px;
      font-weight: 800;
      text-transform: uppercase;
      letter-spacing: 0.1em;
      margin: 0;
      opacity: 0.9;
    }

    .mem-instagram__handle {
      font-size: 20px;
      font-weight: 900;
      margin: 0;
    }

  /* ===== FINAL CTA ===== */
    .mem-final-cta {
      position: relative;
      padding: clamp(56px, 8vw, 88px) 0;
      text-align: center;
      color: var(--white);
    }

    .mem-final-cta__bg {
      position: absolute;
      inset: 0;
      z-index: 0;
    }

    .mem-final-cta__bg img {
      width: 100%;
      height: 100%;
      object-fit: cover;
    }

    .mem-final-cta__bg::after {
      content: "";
      position: absolute;
      inset: 0;
      background: rgba(7, 22, 40, 0.78);
    }

    .mem-final-cta__inner {
      position: relative;
      z-index: 1;
    }

    .mem-final-cta h2 {
      font-size: clamp(22px, 3.5vw, 32px);
      font-weight: 900;
      text-transform: uppercase;
      letter-spacing: 0.04em;
      margin: 0 0 28px;
      max-width: 20ch;
      margin-left: auto;
      margin-right: auto;
    }

    .mem-final-cta__actions {
      display: flex;
      flex-wrap: wrap;
      gap: 16px;
      justify-content: center;
    }
  </style>
</head>

<body class="single-column memorial-day-landing">
  <mvt:item name="hdft" param="global_header" />
  <mvt:item name="hdft" param="header" />

  <main id="memorial-day-landing">

    <!-- ===== HERO ===== -->
    <section class="mem-hero" aria-label="Memorial Day Sale">
      <div class="mem-hero__bleed">
        <span class="mem-hero__img--desktop">
          <mvt:item name="readytheme" param="image( 'mem-hero-desktop' )" />
        </span>
        <span class="mem-hero__img--mobile">
          <mvt:item name="readytheme" param="image( 'mem-hero-mobile' )" />
        </span>
        <div class="mem-hero__overlay">
          <p class="mem-hero__eyebrow">Memorial Day</p>
          <div class="mem-hero__sale" aria-hidden="true">
            <span class="mem-stars">★</span>
            <span class="mem-hero__sale-word">Sale</span>
            <span class="mem-stars">★</span>
          </div>
          <p class="mem-hero__tagline">Honor. Freedom. Performance.</p>
          <p class="mem-hero__sub">Save big on premium diesel performance parts.</p>
          <p class="mem-hero__offer">Up to <strong>20% OFF</strong> select performance parts</p>
          <a class="mem-btn mem-btn--red" href="https://sinisterdiesel.com/sinister-diesel.html">Shop Sale Now</a>
        </div>
        <p class="mem-hero__deadline">Sale ends 5/26/26 at 11:59pm CST</p>
      </div>
    </section>

    <!-- ===== VALUE PROPS ===== -->
    <section class="mem-value-bar" aria-label="Store benefits">
      <div class="mem-container">
        <div class="mem-value-bar__grid">
          <div class="mem-value-item">
            <svg class="mem-value-item__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" aria-hidden="true"><path d="M12 2l2.4 7.4H22l-6.2 4.5 2.4 7.4L12 17l-6.2 4.3 2.4-7.4L2 9.4h7.6L12 2z"/></svg>
            <p class="mem-value-item__title">Military Discount</p>
            <p class="mem-value-item__desc">Active duty &amp; veterans save more</p>
          </div>
          <div class="mem-value-item">
            <svg class="mem-value-item__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" aria-hidden="true"><path d="M1 12h5l2-7 4 14 2-7h7"/></svg>
            <p class="mem-value-item__title">Fast &amp; Free Shipping</p>
            <p class="mem-value-item__desc">On orders over $99</p>
          </div>
          <div class="mem-value-item">
            <svg class="mem-value-item__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" aria-hidden="true"><path d="M3 7v10a2 2 0 002 2h14a2 2 0 002-2V7M3 7l4-4h10l4 4M12 11v6"/></svg>
            <p class="mem-value-item__title">Easy 30-Day Returns</p>
            <p class="mem-value-item__desc">Hassle free</p>
          </div>
          <div class="mem-value-item">
            <svg class="mem-value-item__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" aria-hidden="true"><circle cx="12" cy="8" r="4"/><path d="M4 20c0-4 3.6-6 8-6s8 2 8 6"/></svg>
            <p class="mem-value-item__title">Diesel Experts</p>
            <p class="mem-value-item__desc">Here to help</p>
          </div>
        </div>
      </div>
    </section>

    <!-- ===== SHOP BY CATEGORY ===== -->
    <section class="mem-categories" id="mem-shop-cat" aria-label="Shop by Category">
      <div class="mem-container">
        <h2 class="mem-section-title"><span class="mem-stars">★</span> Shop By Category <span class="mem-stars">★</span></h2>
        <div class="mem-cat-grid">
          <a class="mem-cat-card" href="https://sinisterdiesel.com/egr-delete-kits.html">
            <div class="mem-cat-card__media">
              <img src="/mm5/graphics/00000001/7/CATEGORIES_EGR.png" alt="EGR Delete Kits">
            </div>
            <div class="mem-cat-card__body">
              <h3 class="mem-cat-card__title">EGR Delete Kits</h3>
              <p class="mem-cat-card__desc">Improve flow and reliability on your diesel.</p>
              <span class="mem-btn mem-btn--navy-sm">Shop Now</span>
            </div>
          </a>
          <a class="mem-cat-card" href="https://sinisterdiesel.com/diesel-air-intakes-parts-for-powerstroke-cummins-superduty-engines.html">
            <div class="mem-cat-card__media">
              <img src="/mm5/graphics/00000001/7/CATEGORIES_Air%20Intakes%20%281%29.png" alt="Cold Air Intakes">
            </div>
            <div class="mem-cat-card__body">
              <h3 class="mem-cat-card__title">Cold Air Intakes</h3>
              <p class="mem-cat-card__desc">More airflow for Powerstroke, Duramax &amp; Cummins.</p>
              <span class="mem-btn mem-btn--navy-sm">Shop Now</span>
            </div>
          </a>
          <a class="mem-cat-card" href="https://sinisterdiesel.com/intercoolers-pipes.html">
            <div class="mem-cat-card__media">
              <img src="/mm5/graphics/00000001/7/CATEGORIES_Intercooler%20Pipes.png" alt="Charge Pipes">
            </div>
            <div class="mem-cat-card__body">
              <h3 class="mem-cat-card__title">Charge Pipes</h3>
