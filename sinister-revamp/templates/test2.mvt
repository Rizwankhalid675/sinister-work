  </main>

  <section class="o-layout">
    <div class="o-layout__item">
      <mvt:item name="hdft" param="footer" />
    </div>
  </section>
  <mvt:item name="hdft" param="global_footer" />

  <script>
    (function () {
      /* Wire YMM to your existing fitment endpoint if different */
      var currentYear = new Date().getFullYear();
      var yearSelect = document.getElementById('mem-year');
      var makeSelect = document.getElementById('mem-make');
      var modelSelect = document.getElementById('mem-model');
      var engineSelect = document.getElementById('mem-engine');
      var form = document.getElementById('mem-ymm-form');

      if (!yearSelect) return;

      for (var y = currentYear; y >= 1999; y--) {
        var opt = document.createElement('option');
        opt.value = y;
        opt.textContent = y;
        yearSelect.appendChild(opt);
      }

      function resetFrom(select) {
        var chain = [yearSelect, makeSelect, modelSelect, engineSelect];
        var start = chain.indexOf(select) + 1;
        for (var i = start; i < chain.length; i++) {
          chain[i].innerHTML = '<option value="">' + chain[i].id.replace('mem-', '').replace(/^\w/, function (c) { return c.toUpperCase(); }) + '</option>';
          chain[i].disabled = i > start;
        }
      }

      yearSelect.addEventListener('change', function () {
        resetFrom(yearSelect);
        if (yearSelect.value) {
          makeSelect.disabled = false;
          ['Ford', 'Chevrolet', 'GMC', 'Ram'].forEach(function (m) {
            var o = document.createElement('option');
            o.value = m;
            o.textContent = m;
            makeSelect.appendChild(o);
          });
        }
      });

      makeSelect.addEventListener('change', function () {
        resetFrom(makeSelect);
        if (makeSelect.value) {
          modelSelect.disabled = false;
          var models = {
            Ford: ['F-250', 'F-350', 'F-450'],
            Chevrolet: ['Silverado 2500HD', 'Silverado 3500HD'],
            GMC: ['Sierra 2500HD', 'Sierra 3500HD'],
            Ram: ['2500', '3500', '4500']
          };
          (models[makeSelect.value] || []).forEach(function (m) {
            var o = document.createElement('option');
            o.value = m;
            o.textContent = m;
            modelSelect.appendChild(o);
          });
        }
      });

      modelSelect.addEventListener('change', function () {
        resetFrom(modelSelect);
        if (modelSelect.value) {
          engineSelect.disabled = false;
          ['6.7L Powerstroke', '6.7L Cummins', '6.6L Duramax', '6.0L Powerstroke', '7.3L Powerstroke'].forEach(function (e) {
            var o = document.createElement('option');
            o.value = e;
            o.textContent = e;
            engineSelect.appendChild(o);
          });
        }
      });

      if (form) {
        form.addEventListener('submit', function (e) {
          e.preventDefault();
          var q = [yearSelect.value, makeSelect.value, modelSelect.value, engineSelect.value].filter(Boolean).join(' ');
          window.location.href = 'https://sinisterdiesel.com/search.html?Search=' + encodeURIComponent(q);
        });
      }
    })();
  </script>
</body>
</html>
