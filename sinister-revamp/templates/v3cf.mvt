	<!-- FAQ Section -->
	<section class="section section-light">
		<div class="container">
			<div class="section-title" data-aos="fade-up">
				<h2>Frequently Asked Questions</h2>
				<p>Everything you need to know about our coolant filtration systems</p>
			</div>
			
			<div class="split-feature">
				<div class="split-content" data-aos="fade-right">
					<h3>Installation & Maintenance</h3>
					<div style="margin-top: 2rem;">
						<h4>How long does installation take?</h4>
						<p style="margin-bottom: 1.5rem;">Most installations take approximately 2 hours. The kit mounts using existing factory holes with no drilling required, and all necessary hardware is included.</p>
						
						<h4>What's the maintenance schedule?</h4>
						<p style="margin-bottom: 1.5rem;">Replace the first filter at 500 miles, the second and third at 3,000 miles each. After the initial three changes, replace the filter annually or with each coolant flush.</p>
					</div>
				</div>
				<div class="split-content" data-aos="fade-left">
					<h3>Performance & Benefits</h3>
					<div style="margin-top: 2rem;">
						<h4>Why do I need coolant filtration?</h4>
						<p style="margin-bottom: 1.5rem;">Factory engines often contain casting sand and metal particles that can damage cooling system components. Our system removes these contaminants to prevent premature failure.</p>
						
						<h4>Does it affect coolant flow?</h4>
						<p style="margin-bottom: 1.5rem;">No, the bypass design maintains optimal coolant flow while filtering a portion of the coolant to gradually clean the entire system.</p>
					</div>
				</div>
			</div>
		</div>
	</section>
	
