                "content": {
                    "value": "<section style=\"padding: 60px 20px; max-width: 1200px; margin: 0 auto; font-family: Verdana, sans-serif;\">\r\n  <style>\r\n    @media screen and (max-width: 768px) {\r\n      .benefits-container {\r\n        flex-direction: column !important;\r\n      }\r\n      .benefits-divider {\r\n        display: none !important;\r\n      }\r\n      .benefit-row {\r\n        flex-direction: column !important;\r\n        text-align: center !important;\r\n      }\r\n      .benefit-row img {\r\n        margin: 0 auto 15px auto !important;\r\n      }\r\n      .mobile-divider-top {\r\n        border-top: 1px solid #ddd !important;\r\n      }\r\n    }\r\n  </style>\r\n\r\n  <!-- Headings -->\r\n  <h2 style=\"font-size: 28px; font-weight: bold; margin-bottom: 10px; text-align: center;\">Key Benefits</h2>\r\n  <h3 style=\"font-size: 20px; font-weight: normal; margin-bottom: 40px; text-align: center;\">Why Upgrade to Sinister's 6.7 Fuel Filter?</h3>\r\n\r\n  <!-- Two Column Layout with Dividers -->\r\n  <div class=\"benefits-container\" style=\"display: flex; flex-wrap: wrap; justify-content: center; gap: 0; border: 1px solid #ddd; border-radius: 10px; overflow: hidden;\">\r\n\r\n    <!-- Left Column -->\r\n    <div style=\"flex: 1; min-width: 280px; padding: 20px;\">\r\n      <div class=\"benefit-row\" style=\"display: flex; align-items: center; padding: 20px 0; border-bottom: 1px solid #ddd;\">\r\n        <img src=\"https://t4.ftcdn.net/jpg/06/02/78/31/240_F_602783177_PjSQ091jUck9D9kmf5LcLtwaU3iqysHh.jpg\" alt=\"Filtration Icon\" style=\"width: 90px; height: 90px; margin-right: 15px;\">\r\n        <p style=\"font-size: 16px; margin: 0;\">Better Filtration, Less Restriction</p>\r\n      </div>\r\n      <div class=\"benefit-row\" style=\"display: flex; align-items: center; padding: 20px 0;\">\r\n        <img src=\"https://t4.ftcdn.net/jpg/10/62/25/31/240_F_1062253115_iwSF3eH4xaoaEkLgP3QDmK4bjD6LNZd8.jpg\" alt=\"DIY Install Icon\" style=\"width: 90px; height: 90px; margin-right: 15px;\">\r\n        <p style=\"font-size: 16px; margin: 0;\">Easy DIY Installation</p>\r\n      </div>\r\n    </div>\r\n\r\n    <!-- Vertical Divider -->\r\n    <div class=\"benefits-divider\" style=\"width: 1px; background-color: #ddd;\"></div>\r\n\r\n    <!-- Right Column -->\r\n    <div style=\"flex: 1; min-width: 280px; padding: 20px;\">\r\n      <div class=\"benefit-row mobile-divider-top\" style=\"display: flex; align-items: center; padding: 20px 0; border-bottom: 1px solid #ddd;\">\r\n        <img src=\"https://t4.ftcdn.net/jpg/05/57/88/25/240_F_557882527_QR2dJG9K4FtaasoYpoPTbj3FpzLADVjG.jpg\" alt=\"USA Made Icon\" style=\"width: 90px; height: 90px; margin-right: 15px;\">\r\n        <p style=\"font-size: 16px; margin: 0;\">USA-Made Quality</p>\r\n      </div>\r\n      <div class=\"benefit-row\" style=\"display: flex; align-items: center; padding: 20px 0;\">\r\n        <img src=\"https://t3.ftcdn.net/jpg/04/81/74/10/240_F_481741098_vdJ7jY8paiKzuA2Nq0As9xUkYKcksG21.jpg\" alt=\"Save Money Icon\" style=\"width: 90px; height: 90px; margin-right: 15px;\">\r\n        <p style=\"font-size: 16px; margin: 0;\">Save on Filters for Life</p>\r\n      </div>\r\n    </div>\r\n\r\n  </div>\r\n</section>"
