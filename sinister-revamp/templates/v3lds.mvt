  <!-- Swiper (optional progressive enhancement) -->
  <script defer src="https://unpkg.com/swiper@8/swiper-bundle.min.js"></script>
  <script>
    document.addEventListener('DOMContentLoaded', function () {
      // Smooth anchor scroll
      document.querySelectorAll('a[href^="#"]').forEach(a=>{
        a.addEventListener('click',e=>{
          const t=document.querySelector(a.getAttribute('href')); if(!t) return;
          e.preventDefault(); window.scrollTo({top:t.getBoundingClientRect().top+window.scrollY-10,behavior:'smooth'});
        });
      });

      // Reviews slider (if library loaded)
      if (window.Swiper) {
        new Swiper('.reviews-swiper',{
          loop:true,
          autoHeight:true,
          autoplay:{delay:3500, disableOnInteraction:false},
          effect:'fade',
          fadeEffect:{crossFade:true},
          pagination:{el:'.swiper-pagination',clickable:true}
        });
      }
    });
  </script>

<script>
(function () {
  if (window.mivaJS?.Screen !== 'V3LDS') return;

  const root = document.getElementById('sd2-truck-finder');
  if (!root) return;

  // Native Miva MMCombinationFacet "Apply" button only sets the vehicle-fitment
  // cookie (see js/runtimecombofacets.js Event_SetCookie_OnClick) — it does not
  // navigate. On category/search pages that's fine since the page already
  // reflects the cookie, but on the homepage we need to send the shopper to
  // native search results once their vehicle is applied.
  root.addEventListener('click', function (e) {
    const btn = e.target.closest('button[id^="mm_combination_facet_button_setcookie_"]');
    if (!btn || btn.disabled) return;

    setTimeout(function () {
      location.assign('&mvte:urls:SRCH:auto;');
    }, 300);
  }, true); // capture to run even if MMCombinationFacet's own handler stops propagation
})();
</script>

</body>
