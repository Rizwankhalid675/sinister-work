    <mvt:item name="hdft" param="footer" />
    <mvt:item name="hdft" param="global_footer" />
    
    <!-- JavaScript Libraries -->
    <script src="https://unpkg.com/aos@2.3.1/dist/aos.js"></script>
    <script>
        // Initialize AOS animations
        document.addEventListener('DOMContentLoaded', function() {
            AOS.init({
                duration: 600,
                once: true,
                easing: 'ease-in-out-quad',
                offset: 100
            });
            
            // Smooth scrolling for anchor links
            document.querySelectorAll('a[href^="#"]').forEach(anchor => {
                anchor.addEventListener('click', function(e) {
                    e.preventDefault();
                    const target = document.querySelector(this.getAttribute('href'));
                    if (target) {
                        target.scrollIntoView({
                            behavior: 'smooth'
                        });
                    }
                });
            });
            
            // Testimonial Carousel
            const testimonials = document.querySelectorAll('.testimonial-card');
            let currentTestimonial = 0;
            
            function rotateTestimonials() {
                // Hide current testimonial
                testimonials[currentTestimonial].classList.remove('active');
                
                // Move to next testimonial
                currentTestimonial = (currentTestimonial + 1) % testimonials.length;
                
                // Show next testimonial
                testimonials[currentTestimonial].classList.add('active');
            }
            
            // Start rotation every 4 seconds
            setInterval(rotateTestimonials, 4000);
            
            // Cart Popup Functionality
            const cartPopupOverlay = document.getElementById('cartPopupOverlay');
            const cartPopup = document.getElementById('cartPopup');
            const keepShoppingBtn = document.getElementById('keepShoppingBtn');
            const addToCartForms = document.querySelectorAll('form[id^="addToCartForm"], form[id^="ctaAddToCartForm"]');
            
            function showCartPopup() {
                cartPopupOverlay.style.display = 'block';
                cartPopup.style.display = 'block';
                document.body.style.overflow = 'hidden';
            }
            
            function hideCartPopup() {
                cartPopupOverlay.style.display = 'none';
                cartPopup.style.display = 'none';
                document.body.style.overflow = '';
            }
            
            // Close popup when clicking overlay or keep shopping button
            cartPopupOverlay.addEventListener('click', hideCartPopup);
            keepShoppingBtn.addEventListener('click', function(e) {
                e.preventDefault();
                hideCartPopup();
            });
            
            // Handle form submissions
            if (addToCartForms) {
                addToCartForms.forEach(form => {
                    form.addEventListener('submit', function(e) {
                        e.preventDefault();
                        
                        // Immediately increment the cart count
                        const cartCountElements = document.querySelectorAll('span[data-hook="mini-basket-count"]');
                        if (cartCountElements) {
                            cartCountElements.forEach(el => {
                                const currentCount = parseInt(el.textContent) || 0;
                                el.textContent = currentCount + 1;
                            });
                        }
                        
                        // Submit the form via AJAX
                        fetch(form.action, {
                            method: 'POST',
                            body: new URLSearchParams(new FormData(form)),
                            headers: {
                                'Content-Type': 'application/x-www-form-urlencoded'
                            }
                        })
                        .then(response => {
                            if(response.ok) {
                                // Show success popup
                                showCartPopup();
                            } else {
                                // If add to cart failed, revert the count
                                if (cartCountElements) {
                                    cartCountElements.forEach(el => {
                                        const currentCount = parseInt(el.textContent) || 1;
                                        el.textContent = currentCount - 1;
                                    });
                                }
                            }
                        })
                        .catch(error => {
                            console.error('Error:', error);
                            // If error occurred, revert the count
                            if (cartCountElements) {
                                cartCountElements.forEach(el => {
                                    const currentCount = parseInt(el.textContent) || 1;
                                    el.textContent = currentCount - 1;
                                });
                            }
                        });
                    });
                });
            }
            
            // Add scroll effect to header
            window.addEventListener('scroll', function() {
                const header = document.querySelector('header');
                if (header) {
                    if (window.scrollY > 50) {
                        header.style.backgroundColor = 'rgba(0,0,0,0.9)';
                        header.style.padding = '1rem 0';
                        header.style.boxShadow = '0 2px 20px rgba(0,0,0,0.1)';
                    } else {
                        header.style.backgroundColor = 'transparent';
                        header.style.padding = '2rem 0';
                        header.style.boxShadow = 'none';
                    }
                }
            });
        });
    </script>
</body>
</html>