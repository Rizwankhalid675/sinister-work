                            <li>24-month unlimited mileage protection</li>
                            <li>No-hassle replacement policy</li>
                            <li>Dedicated warranty support team</li>
                            <li>Coverage for defects in materials and workmanship</li>
                            <li>Lifetime technical support</li>
                        </ul>
                        <a href="#product" class="btn btn-primary" style="margin-top: 1rem;">
                            <i class="fas fa-shield-alt btn-icon"></i> Shop with Confidence
                        </a>
                    </div>
                </div>
            </div>
        </section>
        
        <!-- CTA Section -->
        <section class="cta-section" id="cta" data-aos="fade">
            <div class="container">
                <h2>Stop Worrying About Oil Cooler Failure</h2>
                <p class="text-lead">Upgrade to the Sinister Diesel oil cooler today and enjoy peace of mind with improved cooling performance and reliability.</p>
                <form method="post" action="&mvt:global:sessionurl;" id="ctaAddToCartForm">
                    <input type="hidden" name="Action" value="ADPR">
                    <input type="hidden" name="Screen" value="PROD">
                    <input type="hidden" name="Store_Code" value="&mvte:store:code;">
                    <input type="hidden" name="Product_Code" value="&mvte:product:code;">
                    <input type="hidden" name="Quantity" value="1">
                    <button type="submit" class="btn btn-secondary">
                        <i class="fas fa-bolt btn-icon"></i> Add to Cart Now
                    </button>
                </form>
            </div>
        </section>
        
    <mvt:else>
        <!-- PRODUCT NOT FOUND -->
        <div class="section">
            <div class="container">
                <div style="text-align: center; max-width: 600px; margin: 0 auto; background: #fff; padding: 3rem; border-radius: var(--border-radius); box-shadow: var(--shadow-lg);">
                    <h2 style="color: var(--primary); margin-bottom: 1.5rem;">Product Loading Error</h2>
                    <h3 style="color: var(--text-primary); margin-bottom: 1.5rem;">We couldn't load product "sd-oc-6_0"</h3>
                    <p style="margin-bottom: 1.5rem;">Please verify:</p>
                    <ul class="feature-list" style="text-align: left; margin-bottom: 2.5rem;">
                        <li>The product exists in your Miva admin</li>
                        <li>The product is active and available</li>
                        <li>The product code matches exactly</li>
                    </ul>
                    <div class="btn-group">
                        <a href="/" class="btn btn-primary">
                            <i class="fas fa-home btn-icon"></i> Homepage
                        </a>
                        <a href="/contact-us.html" class="btn btn-secondary">
                            <i class="fas fa-headset btn-icon"></i> Contact Support
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </mvt:if>

    <mvt:item name="hdft" param="footer" />
    <mvt:item name="hdft" param="global_footer" />
    
    <!-- JavaScript Libraries -->
    <script src="https://unpkg.com/aos@2.3.1/dist/aos.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/@fancyapps/ui@5.0/dist/fancybox/fancybox.umd.js"></script>
    <script>
        // Initialize AOS animations
        document.addEventListener('DOMContentLoaded', function() {
            AOS.init({
                duration: 800,
                once: true,
                easing: 'ease-in-out-quad',
                offset: 100
            });
            
            // Initialize Fancybox
            Fancybox.bind("[data-fancybox]", {
                // Your custom options
            });
            
            // Smooth scrolling for anchor links
            document.querySelectorAll('a[href^="#"]').forEach(anchor => {
                anchor.addEventListener('click', function(e) {
                    e.preventDefault();
                    const target = document.querySelector(this.getAttribute('href'));
                    if (target) {
                        target.scrollIntoView({
                            behavior: 'smooth'
                        });
                    }
                });
            });
            
            // Testimonial Carousel
            const testimonials = document.querySelectorAll('.testimonial-card');
            const dots = document.querySelectorAll('.carousel-dot');
            let currentTestimonial = 0;
            let carouselInterval;
            
            function showTestimonial(index) {
                // Hide current testimonial
                testimonials[currentTestimonial].classList.remove('active');
                dots[currentTestimonial].classList.remove('active');
                
                // Update current index
                currentTestimonial = index;
                
                // Show next testimonial
                testimonials[currentTestimonial].classList.add('active');
                dots[currentTestimonial].classList.add('active');
            }
            
            function rotateTestimonials() {
                let nextIndex = (currentTestimonial + 1) % testimonials.length;
                showTestimonial(nextIndex);
            }
            
            // Start rotation every 5 seconds
            carouselInterval = setInterval(rotateTestimonials, 5000);
            
            // Add click handlers for dots
            dots.forEach((dot, index) => {
                dot.addEventListener('click', () => {
                    clearInterval(carouselInterval);
                    showTestimonial(index);
                    carouselInterval = setInterval(rotateTestimonials, 5000);
                });
            });
            
            // FAQ Accordion
            const faqItems = document.querySelectorAll('.faq-item');
            faqItems.forEach(item => {
                const question = item.querySelector('.faq-question');
                question.addEventListener('click', () => {
                    item.classList.toggle('active');
                });
            });
            
            // Cart Popup Functionality
            const cartPopupOverlay = document.getElementById('cartPopupOverlay');
            const cartPopup = document.getElementById('cartPopup');
            const keepShoppingBtn = document.getElementById('keepShoppingBtn');
            const addToCartForms = document.querySelectorAll('form[id^="addToCartForm"], form[id^="ctaAddToCartForm"]');
            
            function showCartPopup() {
                cartPopupOverlay.style.display = 'block';
                cartPopup.style.display = 'block';
                document.body.style.overflow = 'hidden';
            }
            
            function hideCartPopup() {
                cartPopupOverlay.style.display = 'none';
                cartPopup.style.display = 'none';
                document.body.style.overflow = '';
            }
            
            // Close popup when clicking overlay or keep shopping button
            cartPopupOverlay.addEventListener('click', hideCartPopup);
            keepShoppingBtn.addEventListener('click', function(e) {
                e.preventDefault();
                hideCartPopup();
            });
            
            // Handle form submissions
            if (addToCartForms) {
                addToCartForms.forEach(form => {
                    form.addEventListener('submit', function(e) {
                        e.preventDefault();
                        
                        // Immediately increment the cart count
                        const cartCountElements = document.querySelectorAll('span[data-hook="mini-basket-count"]');
                        if (cartCountElements) {
                            cartCountElements.forEach(el => {
                                const currentCount = parseInt(el.textContent) || 0;
                                el.textContent = currentCount + 1;
                            });
                        }
                        
                        // Submit the form via AJAX
                        fetch(form.action, {
                            method: 'POST',
                            body: new URLSearchParams(new FormData(form)),
                            headers: {
                                'Content-Type': 'application/x-www-form-urlencoded'
                            }
                        })
                        .then(response => {
                            if(response.ok) {
                                // Show success popup
                                showCartPopup();
                            } else {
                                // If add to cart failed, revert the count
                                if (cartCountElements) {
                                    cartCountElements.forEach(el => {
                                        const currentCount = parseInt(el.textContent) || 1;
                                        el.textContent = currentCount - 1;
                                    });
                                }
                            }
                        })
                        .catch(error => {
                            console.error('Error:', error);
                            // If error occurred, revert the count
                            if (cartCountElements) {
                                cartCountElements.forEach(el => {
                                    const currentCount = parseInt(el.textContent) || 1;
                                    el.textContent = currentCount - 1;
                                });
                            }
                        });
                    });
                });
            }
            
            // Add scroll effect to header
            const header = document.querySelector('header');
            if (header) {
                window.addEventListener('scroll', function() {
                    if (window.scrollY > 50) {
                        header.style.backgroundColor = 'rgba(0,0,0,0.95)';
                        header.style.padding = '1rem 0';
                        header.style.boxShadow = '0 5px 30px rgba(0,0,0,0.2)';
                    } else {
                        header.style.backgroundColor = 'transparent';
                        header.style.padding = '2rem 0';
                        header.style.boxShadow = 'none';
                    }
                });
            }
        });
    </script>
</body>
</html>