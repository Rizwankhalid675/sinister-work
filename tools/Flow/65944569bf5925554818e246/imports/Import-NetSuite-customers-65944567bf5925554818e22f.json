{
  "_id": "65944567bf5925554818e22f",
  "name": "Import NetSuite customers",
  "description": "Add or ignore customers in NetSuite using the configured custom field as the lookup identifier.",
  "responseTransform": {
    "type": "expression",
    "expression": {
      "version": "1"
    }
  },
  "_connectionId": "6594453f4f7cab7c220b187a",
  "distributed": true,
  "apiIdentifier": "id8ca83023",
  "hooks": {
    "preMap": {
      "function": "preMapFunction",
      "_scriptId": "65944566bf5925554818e214"
    }
  },
  "ignoreExisting": true,
  "ignoreMissing": false,
  "oneToMany": false,
  "lookups": [],
  "netsuite_da": {
    "useSS2Restlets": false,
    "restletVersion": "suitebundle",
    "operation": "add",
    "recordType": "customer",
    "internalIdLookup": {
      "expression": "[\"custentity_celigoat_miva_customerid\",\"is\",\"{{{id}}}\"]"
    },
    "lookups": [],
    "mapping": {
      "fields": [
        {
          "generate": "isperson",
          "hardCodedValue": "true",
          "internalId": false,
          "immutable": false,
          "discardIfEmpty": false
        },
        {
          "generate": "firstname",
          "extract": "{{#if FirstName}}{{FirstName}}{{else}}FNU{{/if}}",
          "internalId": false,
          "immutable": false,
          "discardIfEmpty": false
        },
        {
          "generate": "email",
          "extract": "pw_email",
          "internalId": false,
          "immutable": false,
          "discardIfEmpty": false
        },
        {
          "generate": "mobilephone",
          "extract": "ship_phone",
          "internalId": false,
          "immutable": false,
          "discardIfEmpty": false
        },
        {
          "generate": "companyname",
          "extract": "ship_comp",
          "internalId": false,
          "immutable": false,
          "discardIfEmpty": false
        },
        {
          "generate": "custentity_celigoat_miva_customerid",
          "extract": "id",
          "internalId": false,
          "immutable": false,
          "discardIfEmpty": false,
          "dataType": "string"
        },
        {
          "generate": "lastname",
          "extract": "{{#if LastName}}{{LastName}}{{else}}LNU{{/if}}",
          "internalId": false,
          "immutable": false,
          "discardIfEmpty": false
        },
        {
          "generate": "subsidiary",
          "discardIfEmpty": false,
          "immutable": false,
          "hardCodedValue": "1",
          "internalId": true
        },
        {
          "generate": "currency",
          "discardIfEmpty": false,
          "immutable": false,
          "hardCodedValue": "1",
          "internalId": true
        },
        {
          "generate": "customform",
          "discardIfEmpty": false,
          "immutable": false,
          "hardCodedValue": "355",
          "internalId": true
        },
        {
          "conditional": {
            "when": "ignore_if_set"
          },
          "generate": "category",
          "discardIfEmpty": false,
          "immutable": false,
          "hardCodedValue": "2",
          "internalId": true
        }
      ],
      "lists": [
        {
          "generate": "_billing_addressbook",
          "fields": [
            {
              "generate": "addr1",
              "extract": "bill_addr1",
              "internalId": false,
              "immutable": false,
              "discardIfEmpty": false
            },
            {
              "generate": "addr2",
              "extract": "bill_addr2",
              "internalId": false,
              "immutable": false,
              "discardIfEmpty": false
            },
            {
              "generate": "city",
              "extract": "bill_city",
              "internalId": false,
              "immutable": false,
              "discardIfEmpty": false
            },
            {
              "generate": "addrphone",
              "extract": "bill_phone",
              "internalId": false,
              "immutable": false,
              "discardIfEmpty": false
            },
            {
              "generate": "country",
              "extract": "bill_cntry",
              "internalId": true,
              "immutable": false,
              "discardIfEmpty": false
            },
            {
              "generate": "state",
              "extract": "bill_state",
              "internalId": false,
              "immutable": false,
              "discardIfEmpty": false
            },
            {
              "generate": "zip",
              "extract": "bill_zip",
              "internalId": false,
              "immutable": false,
              "discardIfEmpty": false
            },
            {
              "generate": "addressee",
              "extract": "{{join ' ' bill_fname bill_lname}}",
              "internalId": false,
              "immutable": false,
              "discardIfEmpty": true
            }
          ]
        },
        {
          "generate": "_shipping_addressbook",
          "fields": [
            {
              "generate": "addr1",
              "extract": "ship_addr1",
              "internalId": false,
              "immutable": false,
              "discardIfEmpty": false
            },
            {
              "generate": "addr2",
              "extract": "ship_addr2",
              "internalId": false,
              "immutable": false,
              "discardIfEmpty": false
            },
            {
              "generate": "city",
              "extract": "ship_city",
              "internalId": false,
              "immutable": false,
              "discardIfEmpty": false
            },
            {
              "generate": "addrphone",
              "extract": "ship_phone",
              "internalId": false,
              "immutable": false,
              "discardIfEmpty": false
            },
            {
              "generate": "country",
              "extract": "ship_cntry",
              "internalId": true,
              "immutable": false,
              "discardIfEmpty": false
            },
            {
              "generate": "state",
              "extract": "ship_state",
              "internalId": false,
              "immutable": false,
              "discardIfEmpty": false
            },
            {
              "generate": "zip",
              "extract": "ship_zip",
              "internalId": false,
              "immutable": false,
              "discardIfEmpty": false
            },
            {
              "generate": "addressee",
              "extract": "{{join ' ' ship_fname ship_lname}}",
              "internalId": false,
              "immutable": false,
              "discardIfEmpty": true
            }
          ]
        }
      ]
    }
  },
  "filter": {
    "type": "expression",
    "expression": {
      "version": "1"
    }
  },
  "adaptorType": "NetSuiteDistributedImport"
}